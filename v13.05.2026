</div>

<!-- ════ MODAL: DETTAGLIO SAL ════ -->
<div class="overlay" id="modal-sal-detail">
  <div class="modal modal--lg" style="max-height:92vh;padding:0;display:flex;flex-direction:column">
    <div class="modal__header" style="flex-shrink:0">
      <div>
        <div class="modal__title" id="sal-detail-title">Dettaglio SAL</div>
        <div style="font-size:12px;color:var(--tx-lighter);margin-top:2px" id="sal-detail-sub"></div>
      </div>
      <button class="modal__close" onclick="closeModal('modal-sal-detail')">&#10005;</button>
    </div>
    <div style="flex:1;overflow-y:auto;padding:20px" id="sal-detail-body"></div>
    <div class="modal__footer" style="flex-shrink:0">
      <button class="btn btn--ghost" onclick="closeModal('modal-sal-detail')">Chiudi</button>
      <button class="btn btn--primary btn--sm" onclick="openNoFromSal()">Genera N.O.</button>
    </div>
  </div>
</div>

<!-- ════ MODAL: PROFILO UTENTE ════ -->
<div class="overlay" id="modal-profilo">
  <div class="modal" style="max-width:440px">
    <div class="modal__header">
      <div class="modal__title">Il mio profilo</div>
      <button class="modal__close" onclick="closeModal('modal-profilo')">&#10005;</button>
    </div>
    <div class="modal__body">
      <div style="display:flex;align-items:center;gap:16px;margin-bottom:20px;padding:16px;background:var(--bg-primary-light);border-radius:var(--r-smooth)">
        <div style="width:56px;height:56px;border-radius:50%;background:var(--bg-primary);color:#fff;font-size:20px;font-weight:700;display:flex;align-items:center;justify-content:center" id="profilo-avatar-big">—</div>
        <div>
          <div style="font-size:16px;font-weight:700" id="profilo-nome-display">—</div>
          <div style="font-size:12px;color:var(--tx-lighter);margin-top:2px" id="profilo-email-display">—</div>
          <div style="margin-top:4px" id="profilo-ruolo-display"></div>
        </div>
      </div>

      <div id="profilo-error" style="display:none;margin-bottom:12px;padding:10px 14px;background:var(--bg-error-lighter);border:1px solid var(--bd-error);border-radius:var(--r-smooth);font-size:12px;color:var(--tx-error)"></div>
      <div id="profilo-success" style="display:none;margin-bottom:12px;padding:10px 14px;background:var(--bg-success-lighter);border:1px solid var(--bd-success);border-radius:var(--r-smooth);font-size:12px;color:var(--tx-success)"></div>

      <div class="field" style="margin-bottom:14px">
        <label class="field__label">Nome e Cognome</label>
        <div class="field__input"><input type="text" id="profilo-nome" placeholder="Nome Cognome"></div>
      </div>

      <div style="border-top:1px solid var(--bd-sec-light);margin:16px 0 14px;padding-top:14px">
        <div style="font-size:12px;font-weight:700;color:var(--tx-primary);margin-bottom:12px">Cambia password</div>
        <div class="field" style="margin-bottom:10px">
          <label class="field__label">Password attuale</label>
          <div class="field__input"><input type="password" id="profilo-pwd-old" placeholder="Password attuale"></div>
        </div>
        <div class="field" style="margin-bottom:10px">
          <label class="field__label">Nuova password</label>
          <div class="field__input"><input type="password" id="profilo-pwd-new" placeholder="Minimo 8 caratteri"></div>
        </div>
        <div class="field">
          <label class="field__label">Conferma nuova password</label>
          <div class="field__input"><input type="password" id="profilo-pwd-confirm" placeholder="Ripeti la nuova password"></div>
        </div>
      </div>
    </div>
    <div class="modal__footer">
      <button class="btn btn--ghost" onclick="closeModal('modal-profilo')">Chiudi</button>
      <button class="btn btn--primary" onclick="saveProfilo()">Salva modifiche</button>
    </div>
  </div>
</div>

<!-- ════ DROPDOWN PROFILO (overlay invisibile) ════ -->
<div id="profilo-dropdown" style="display:none;position:fixed;z-index:800;background:#fff;border:1px solid var(--bd-sec-light);border-radius:var(--r-smooth);box-shadow:0 8px 24px rgba(0,0,0,.12);min-width:200px;overflow:hidden">
  <div style="padding:12px 16px;border-bottom:1px solid var(--bd-sec-light);background:var(--bg-sec-lighter)">
    <div style="font-size:13px;font-weight:700" id="dd-nome">—</div>
    <div style="font-size:11px;color:var(--tx-lighter);margin-top:1px" id="dd-email">—</div>
  </div>
  <div style="padding:4px 0">
    <div onclick="openProfilo()" style="padding:9px 16px;font-size:13px;cursor:pointer;display:flex;align-items:center;gap:9px;transition:background .1s" onmouseover="this.style.background='var(--bg-sec-lighter)'" onmouseout="this.style.background=''">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      Il mio profilo
    </div>
    <div style="height:1px;background:var(--bd-sec-light);margin:2px 0"></div>
    <div onclick="doLogout()" style="padding:9px 16px;font-size:13px;cursor:pointer;display:flex;align-items:center;gap:9px;color:var(--tx-error);transition:background .1s" onmouseover="this.style.background='var(--bg-error-lighter)'" onmouseout="this.style.background=''">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      Esci
    </div>
  </div>
</div>

<!-- Modal: Invita utente (Admin only) -->
<div class="overlay" id="modal-invita-utente">
  <div class="modal" style="max-width:480px">
    <div class="modal__header">
      <div class="modal__title">Invita nuovo utente</div>
      <button class="modal__close" onclick="closeModal('modal-invita-utente')">&#10005;</button>
    </div>
    <div class="modal__body">
      <div class="notice notice--info" style="margin-bottom:16px;font-size:12px">
        &#128231; L'utente riceverà un'email con il link per impostare la password. Finché non completa il primo accesso, lo stato sarà "In attesa".
      </div>
      <div class="field" style="margin-bottom:14px">
        <label class="field__label">Email istituzionale</label>
        <div class="field__input"><input type="email" id="invite-email" placeholder="nome@icsc.it"></div>
      </div>
      <div class="field" style="margin-bottom:14px">
        <label class="field__label">Nome e Cognome</label>
        <div class="field__input"><input type="text" id="invite-name" placeholder="es. Mario Rossi"></div>
      </div>
      <div class="field" style="margin-bottom:14px">
        <label class="field__label">Ruolo</label>
        <select class="field-select" style="width:100%" id="invite-role">
          <option value="riscontro_tecnico">Riscontro Tecnico</option>
          <option value="admin">Admin</option>
        </select>
      </div>
      <div id="invite-result" style="display:none;margin-top:12px;font-size:13px;padding:10px 14px;border-radius:var(--r-smooth)"></div>
    </div>
    <div class="modal__footer">
      <button class="btn btn--ghost" onclick="closeModal('modal-invita-utente')">Annulla</button>
      <button class="btn btn--primary" id="invite-submit-btn" onclick="doInviteUser()">&#10133; Invia invito</button>
    </div>
  </div>
</div>

<!-- Modal: Nuova pratica (funzionale) -->
<div class="overlay" id="modal-nuova-pratica">
  <div class="modal modal--lg" style="max-height:92vh">
    <div class="modal__header">
      <div class="modal__title">Nuova pratica</div>
      <button class="modal__close" onclick="closeModal('modal-nuova-pratica')">&#10005;</button>
    </div>
    <div class="modal__body" style="overflow-y:auto">
      <div class="notice notice--info" style="margin-bottom:18px;font-size:12px">
        Inserisci i dati anagrafici della nuova pratica. Il codice rapporto deve essere univoco.
      </div>
      <div id="nuova-pratica-error" style="display:none;margin-bottom:14px;padding:10px 14px;background:var(--bg-error-lighter);border:1px solid var(--bd-error);border-radius:var(--r-smooth);font-size:12px;color:var(--tx-error)"></div>
      <div class="g2" style="gap:14px">
        <div class="field">
          <label class="field__label">N. Rapporto <span style="color:var(--tx-error)">*</span></label>
          <div class="field__input"><input type="text" id="np-rapporto" placeholder="es. 6300100"></div>
        </div>
        <div class="field">
          <label class="field__label">Denominazione beneficiario <span style="color:var(--tx-error)">*</span></label>
          <div class="field__input"><input type="text" id="np-beneficiario" placeholder="es. ASD Calcio Roma"></div>
        </div>
        <div class="field">
          <label class="field__label">Comune <span style="color:var(--tx-error)">*</span></label>
          <div class="field__input"><input type="text" id="np-comune" placeholder="es. Roma (RM)"></div>
        </div>
        <div class="field">
          <label class="field__label">Tipo mutuo <span style="color:var(--tx-error)">*</span></label>
          <select class="field-select" style="width:100%" id="np-tipo">
            <option value="">— Seleziona —</option>
            <option value="Ordinario Privato">Ordinario Privato</option>
            <option value="Light Privato">Light Privato</option>
            <option value="Ordinario EELL">Ordinario EELL</option>
          </select>
        </div>
        <div class="field">
          <label class="field__label">Ambito <span style="color:var(--tx-error)">*</span></label>
          <select class="field-select" style="width:100%" id="np-ambito">
            <option value="">— Seleziona —</option>
            <option value="Sport">Sport</option>
            <option value="Cultura">Cultura</option>
          </select>
        </div>
        <div class="field">
          <label class="field__label">Legge di riferimento</label>
          <select class="field-select" style="width:100%" id="np-legge">
            <option value="Legge 4101">Legge 4101</option>
            <option value="Legge 1461">Legge 1461</option>
            <option value="Altro">Altro</option>
          </select>
        </div>
        <div class="field">
          <label class="field__label">Importo deliberato (€) <span style="color:var(--tx-error)">*</span></label>
          <div class="field__input"><input type="text" id="np-importo" placeholder="0,00"></div>
        </div>
        <div class="field">
          <label class="field__label">Data stipula</label>
          <div class="field__input"><input type="date" id="np-stipula"></div>
        </div>
        <div class="field">
          <label class="field__label">Durata (mesi)</label>
          <div class="field__input"><input type="number" id="np-durata" placeholder="180" min="12" max="360"></div>
        </div>
        <div class="field">
          <label class="field__label">Inizio ammortamento</label>
          <div class="field__input"><input type="date" id="np-ammort"></div>
        </div>
        <div class="field">
          <label class="field__label">Garanzia immobiliare</label>
          <select class="field-select" style="width:100%" id="np-garanzia">
            <option value="Non prevista">Non prevista</option>
            <option value="Ipoteca di primo grado">Ipoteca di primo grado</option>
            <option value="Fideiussione">Fideiussione</option>
          </select>
        </div>
        <div class="field">
          <label class="field__label">CUP (solo EELL)</label>
          <div class="field__input"><input type="text" id="np-cup" placeholder="es. F69D22000940006"></div>
        </div>
        <div class="field" style="grid-column:1/-1">
          <label class="field__label">Oggetto del finanziamento <span style="color:var(--tx-error)">*</span></label>
          <div class="field__input field__input--area"><textarea id="np-oggetto" placeholder="Descrivi brevemente l'oggetto del finanziamento…" style="min-height:60px"></textarea></div>
        </div>
        <div class="field" style="grid-column:1/-1">
          <label class="field__label">Note operative</label>
          <div class="field__input field__input--area"><textarea id="np-note" placeholder="Note interne della pratica…" style="min-height:52px"></textarea></div>
        </div>
      </div>
    </div>
    <div class="modal__footer">
      <button class="btn btn--ghost" onclick="closeModal('modal-nuova-pratica')">Annulla</button>
      <button class="btn btn--primary" id="np-submit-btn" onclick="doCreaPratica()">&#10133; Crea pratica</button>
    </div>
  </div>
</div>

<!-- Modal: Modifica pratica (multi-tab Sonar style) -->
<div class="overlay" id="modal-edit-pratica">
  <div class="modal modal--lg" style="width:720px;max-height:92vh">

    <style>
      /* Sub-tab stile Sonar nella modal */
      .medit-tabs { display:flex; gap:2px; padding:0 20px; border-bottom:1px solid var(--bd-sec-light); background:var(--bg-sec-lighter); flex-shrink:0; }
      .medit-tab {
        padding:10px 16px; font-size:13px; font-weight:500; cursor:pointer;
        color:var(--tx-lighter); border-radius:var(--r-rounded) var(--r-rounded) 0 0;
        border:none; background:transparent; font-family:var(--ff-body);
        white-space:nowrap; transition:all .12s; position:relative; top:1px;
      }
      .medit-tab:hover { color:var(--tx-primary); }
      .medit-tab.is-active {
        background:var(--bg-primary); color:#fff; font-weight:700;
      }
      .medit-body { display:none; }
      .medit-body.is-active { display:block; }

      /* Upload row stile Sonar */
      .upload-row {
        display:flex; align-items:center; justify-content:space-between;
        padding:12px 16px; border:1.5px solid var(--bd-prim-light);
        border-radius:var(--r-smooth); cursor:pointer; background:var(--bg-inverse);
        transition:all .12s; margin-bottom:10px;
      }
      .upload-row:hover { background:var(--bg-primary-light); }
      .upload-row__label { font-size:13px; color:var(--tx-secondary); font-weight:500; }
      .upload-row__icon {
        width:22px; height:22px; border-radius:50%; border:1.5px solid var(--bd-primary);
        color:var(--tx-secondary); display:flex; align-items:center; justify-content:center;
        font-size:16px; font-weight:300; flex-shrink:0;
      }
      .upload-sub-label { font-size:11px; font-weight:700; color:var(--tx-lighter); text-transform:uppercase; letter-spacing:.05em; margin:18px 0 8px; }
    </style>

    <div class="modal__header">
      <div>
        <div class="modal__title">Modifica Pratica — 5978000</div>
