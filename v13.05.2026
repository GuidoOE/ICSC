<script>
function rSwitch(prefix, n) {
  for (var i = 1; i <= 6; i++) {
    var p = document.getElementById(prefix + 'p' + i);
    var s = document.getElementById(prefix + 's' + i);
    if (p) p.style.display = i === n ? 'block' : 'none';
    if (s) {
      s.classList.remove('is-active','is-done');
      if (i < n) s.classList.add('is-done');
      if (i === n) s.classList.add('is-active');
    }
  }
}
</script>



