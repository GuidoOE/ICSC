    </div>
    <div class="modal__body">
      <div class="notice notice--info" style="margin-bottom:14px;font-size:12px">
        📌 Stai per inserire il <strong>Saldo finale (SAL 2)</strong> con 2 catene documentali. Le righe verranno aggiunte nel tab <strong>Controllo eleggibilità</strong>.
      </div>
      <div style="font-size:13px;color:var(--tx-light);line-height:1.6">
        Documenti caricati: <strong>5 / 8</strong><br>
        Catene documentali da creare: <strong>2</strong><br>
        Importo totale: <strong style="color:var(--tx-secondary)">€ 170.018,00</strong>
      </div>
    </div>
    <div class="modal__footer">
      <button class="btn btn--ghost" onclick="closeModal('modal-ins-confirm')">Annulla</button>
      <button class="btn btn--primary" onclick="closeModal('modal-ins-confirm');alert('SAL inserito! Le catene documentali sono ora visibili nel tab Controllo eleggibilità.')">✓ Conferma inserimento</button>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════
     MODAL: CARICA DOCUMENTO (Supabase Storage)
═══════════════════════════════════════════════ -->
<div class="overlay" id="modal-upload-doc">
  <div class="modal" style="max-width:520px">
    <div class="modal__header">
      <div class="modal__title">Carica documento</div>
      <button class="modal__close" onclick="closeModal('modal-upload-doc')">&#10005;</button>
    </div>
    <div class="modal__body">
      <div class="field" style="margin-bottom:14px">
        <label class="field__label">Tipo documento</label>
        <select class="field-select" style="width:100%;height:38px" id="upload-doc-tipo">
          <option value="">— Seleziona tipo —</option>
          <option>Delibera / Contratto di mutuo</option>
          <option>Atto autorizzativo</option>
          <option>N.O. tecnico</option>
          <option>Fattura</option>
          <option>Bonifico / Quietanza</option>
          <option>SAL / Cert. pagamento</option>
          <option>Dichiarazione ICSC</option>
          <option>CRE / Collaudo</option>
          <option>Parere CONI</option>
          <option>DURC</option>
          <option>Parcella tecnica</option>
          <option>PEC</option>
          <option>Altro</option>
        </select>
      </div>
      <div class="field" style="margin-bottom:14px">
        <label class="field__label">Descrizione <span style="font-weight:400;color:var(--tx-lighter)">(opzionale)</span></label>
        <div class="field__input"><input type="text" id="upload-doc-desc" placeholder="Es. Fattura 31/2025 — Edilizia Bari SRL"></div>
      </div>
      <div id="upload-dropzone"
           style="border:2px dashed var(--bd-sec-light);border-radius:var(--r-smooth);padding:28px;text-align:center;cursor:pointer;background:var(--bg-sec-lighter);transition:border-color .15s,background .15s"
           onclick="document.getElementById('upload-file-input').click()"
           ondragover="event.preventDefault();this.style.borderColor='var(--bd-primary)';this.style.background='var(--bg-primary-light)'"
           ondragleave="this.style.borderColor='';this.style.background=''"
           ondrop="event.preventDefault();this.style.borderColor='';this.style.background='';handleUploadDrop(event)">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--tx-lighter)" stroke-width="1.5" style="margin:0 auto 8px;display:block"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        <div style="font-size:13px;font-weight:600;color:var(--tx-light)">Clicca per selezionare o trascina qui il file</div>
        <div style="font-size:11px;color:var(--tx-disable);margin-top:4px">PDF, Word, ZIP, Excel, immagini — max 20 MB</div>
      </div>
      <input type="file" id="upload-file-input" accept=".pdf,.doc,.docx,.zip,.xlsx,.xls,.png,.jpg,.jpeg" style="display:none" onchange="handleUploadFileSelect(this)">
      <div id="upload-file-preview" style="display:none;margin-top:12px;padding:10px 14px;background:var(--bg-primary-light);border:1px solid var(--bd-prim-light);border-radius:var(--r-smooth);align-items:center;gap:10px">
        <span style="font-size:18px;flex-shrink:0">&#128196;</span>
        <div style="flex:1;min-width:0">
          <div id="upload-file-name" style="font-size:13px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"></div>
          <div id="upload-file-size" style="font-size:11px;color:var(--tx-lighter);margin-top:2px"></div>
        </div>
        <button onclick="clearUploadFile()" style="border:none;background:none;color:var(--tx-error);cursor:pointer;font-size:16px;padding:0;flex-shrink:0">&#10005;</button>
      </div>
      <div id="upload-progress-wrap" style="display:none;margin-top:12px">
        <div style="font-size:12px;color:var(--tx-lighter);margin-bottom:5px" id="upload-progress-label">Caricamento in corso…</div>
        <div style="height:6px;background:var(--bg-sec-light);border-radius:3px;overflow:hidden">
          <div id="upload-progress-bar" style="height:100%;width:0%;background:var(--bg-primary);border-radius:3px;transition:width .2s"></div>
        </div>
      </div>
      <div id="upload-result" style="display:none;margin-top:12px;font-size:13px;padding:10px 14px;border-radius:var(--r-smooth)"></div>
    </div>
    <div class="modal__footer">
      <button class="btn btn--ghost" onclick="closeModal('modal-upload-doc');clearUploadState()">Annulla</button>
      <button class="btn btn--primary" id="upload-submit-btn" onclick="doUploadDoc()">&#11014; Carica documento</button>
    </div>
  </div>
</div>

<script>
/* ════════════════════════════════════════════════════════════
   SONAR — DATA LAYER
   Tutti i dati passano da qui. Sostituisci le funzioni _db.*
   con chiamate Supabase reali quando sei pronto.
   ════════════════════════════════════════════════════════════ */

/* ── Supabase config (imposta prima del deploy) ── */
var SB_URL  = 'https://INSERISCI-PROJECT-URL.supabase.co';
var SB_ANON = 'INSERISCI-ANON-KEY';
var SB_BUCKET = 'sonar-documenti';
var _sb = null;
try {
  if (window.supabase && !SB_URL.includes('INSERISCI')) {
    _sb = window.supabase.createClient(SB_URL, SB_ANON);
  }
} catch(e) {}

/* ── Sessione corrente ── */
var SESSION = {
  user: null,   // { id, email, nome, ruolo }
  pratiche: []  // pratiche assegnate a questo utente
};

/* ══════════════════════════════════════════════════════
   MOCK DATABASE (localStorage-backed, Supabase-shaped)
   Struttura identica a Supabase per swap futuro.
══════════════════════════════════════════════════════ */
var _store = {
  get: function(k) { try { return JSON.parse(localStorage.getItem('sonar_'+k)||'null'); } catch(e) { return null; } },
  set: function(k,v) { localStorage.setItem('sonar_'+k, JSON.stringify(v)); },
  del: function(k) { localStorage.removeItem('sonar_'+k); }
};

/* Inizializza admin di default se non esiste */
function _initDefaultAdmin() {
  var users = _store.get('users') || [];
  if (users.length === 0) {
    var adminUser = {
      id: 'usr_admin_001',
      email: 'admin@icsc.it',
      nome: 'Admin ICSC',
      ruolo: 'admin',
      pwd_hash: 'admin123',  // in produzione: Supabase Auth
      stato: 'attivo',
      created_at: new Date().toISOString()
    };
    _store.set('users', [adminUser]);
  }
}

/* ── DB functions (mock → replace with Supabase calls) ── */
var _db = {

  /* AUTH */
  signIn: async function(email, password) {
    if (_sb) {
      var r = await _sb.auth.signInWithPassword({email: email, password: password});
      if (r.error) return {error: r.error.message};
      var profile = await _db.getProfile(r.data.user.id);
      return {user: {id: r.data.user.id, email: email, nome: profile.nome, ruolo: profile.ruolo}};
    }
    // Mock
    var users = _store.get('users') || [];
    var u = users.find(function(x){ return x.email===email && x.pwd_hash===password; });
    if (!u) return {error: 'Credenziali non valide. Verifica email e password.'};
    if (u.stato === 'invitato') return {error: 'Devi completare la registrazione. Controlla la tua email per il link di invito.', invite_pending: true, user_id: u.id};
    return {user: {id: u.id, email: u.email, nome: u.nome, ruolo: u.ruolo}};
  },

  setPassword: async function(userId, nome, password) {
    if (_sb) {
      var r = await _sb.auth.updateUser({password: password});
      if (r.error) return {error: r.error.message};
      await _sb.from('profiles').update({nome: nome, stato: 'attivo'}).eq('id', userId);
      return {ok: true};
    }
    // Mock
    var users = _store.get('users') || [];
    var idx = users.findIndex(function(x){ return x.id===userId; });
    if (idx === -1) return {error: 'Utente non trovato.'};
    users[idx].pwd_hash = password;
    users[idx].nome = nome;
    users[idx].stato = 'attivo';
    _store.set('users', users);
    return {ok: true, user: users[idx]};
  },

  getProfile: async function(userId) {
    if (_sb) {
      var r = await _sb.from('profiles').select('*').eq('id', userId).single();
      return r.data || {};
    }
    var users = _store.get('users') || [];
    return users.find(function(x){ return x.id===userId; }) || {};
  },

  /* USERS (admin) */
  getUsers: async function() {
    if (_sb) {
      var r = await _sb.from('profiles').select('*').order('created_at');
      return r.data || [];
    }
    return _store.get('users') || [];
  },

  inviteUser: async function(email, nome, ruolo) {
    if (_sb) {
      var r = await _sb.auth.admin.inviteUserByEmail(email);
      if (r.error) return {error: r.error.message};
      await _sb.from('profiles').insert({id: r.data.user.id, email: email, nome: nome, ruolo: ruolo, stato: 'invitato'});
      return {ok: true};
    }
    // Mock
    var users = _store.get('users') || [];
    if (users.find(function(x){ return x.email===email; })) return {error: 'Email già registrata nel sistema.'};
    var newUser = {
      id: 'usr_' + Date.now(),
      email: email, nome: nome, ruolo: ruolo,
      pwd_hash: null, stato: 'invitato',
      created_at: new Date().toISOString()
    };
    users.push(newUser);
    _store.set('users', users);
    return {ok: true, user: newUser};
  },

  deleteUser: async function(userId) {
    if (_sb) {
      await _sb.from('profiles').delete().eq('id', userId);
      return {ok: true};
    }
    var users = (_store.get('users')||[]).filter(function(x){ return x.id!==userId; });
    _store.set('users', users);
    return {ok: true};
  },

  /* PRATICHE */
  getPratiche: async function(userId, ruolo) {
    if (_sb) {
      var q = _sb.from('pratiche').select('*').order('created_at', {ascending: false});
      if (ruolo !== 'admin') q = q.eq('assegnato_a', userId);
      var r = await q;
      return r.data || [];
    }
    var all = _store.get('pratiche') || [];
    if (ruolo === 'admin') return all;
    return all.filter(function(p){ return p.assegnato_a === userId; });
  },

  getPratica: async function(id) {
    if (_sb) {
      var r = await _sb.from('pratiche').select('*').eq('id', id).single();
      return r.data;
    }
    var all = _store.get('pratiche') || [];
    return all.find(function(p){ return p.id===id; }) || null;
  },

  createPratica: async function(data) {
    if (_sb) {
      var r = await _sb.from('pratiche').insert(data).select().single();
      if (r.error) return {error: r.error.message};
      return {ok: true, pratica: r.data};
    }
    var all = _store.get('pratiche') || [];
    if (all.find(function(p){ return p.rapporto===data.rapporto; })) return {error: 'Codice rapporto già esistente.'};
    var newP = Object.assign({}, data, {
      id: 'prat_'+Date.now(),
      created_at: new Date().toISOString(),
      stato: 'In lavorazione',
      erogato: 0,
      fase: 'Pre-ammortamento',
      sal_count: 0
    });
    all.push(newP);
    _store.set('pratiche', all);
    return {ok: true, pratica: newP};
  },

  updatePratica: async function(id, data) {
    if (_sb) {
      var r = await _sb.from('pratiche').update(data).eq('id', id);
      if (r.error) return {error: r.error.message};
      return {ok: true};
    }
    var all = _store.get('pratiche') || [];
    var idx = all.findIndex(function(p){ return p.id===id; });
    if (idx === -1) return {error: 'Pratica non trovata.'};
    all[idx] = Object.assign(all[idx], data);
    _store.set('pratiche', all);
    return {ok: true};
  },

  /* DOCUMENTI */
  getDocumenti: async function(praticaId) {
    if (_sb) {
      var r = await _sb.from('documenti').select('*').eq('pratica_id', praticaId).order('created_at', {ascending: false});
      return r.data || [];
    }
    return (_store.get('docs_' + praticaId) || []);
  },

  addDocumento: async function(praticaId, doc) {
    if (_sb) {
      var r = await _sb.from('documenti').insert(Object.assign({pratica_id: praticaId}, doc)).select().single();
      if (r.error) return {error: r.error.message};
      return {ok: true, doc: r.data};
    }
    var all = _store.get('docs_' + praticaId) || [];
    var newDoc = Object.assign({}, doc, {id: 'doc_'+Date.now(), pratica_id: praticaId, created_at: new Date().toISOString()});
    all.unshift(newDoc);
    _store.set('docs_' + praticaId, all);
    return {ok: true, doc: newDoc};
  }
};

/* ══════════════════════════════════════════════════════
   AUTH FLOWS
══════════════════════════════════════════════════════ */
_initDefaultAdmin();

async function doLogin() {
  var email  = document.getElementById('login-email').value.trim();
  var pwd    = document.getElementById('login-password').value.trim();
  var errEl  = document.getElementById('login-error');
  if (!email || !pwd) { errEl.textContent='⚠ Inserisci email e password.'; errEl.classList.add('is-visible'); return; }
  errEl.classList.remove('is-visible');

  var btn = document.querySelector('.login-form__submit');
  btn.textContent = 'Accesso in corso…'; btn.disabled = true;

  var res = await _db.signIn(email, pwd);
  btn.disabled = false;
  btn.innerHTML = 'Accedi <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>';

  if (res.error) {
    if (res.invite_pending) {
      // Mostra schermata set password
      _pendingUserId = res.user_id;
      document.getElementById('login-screen').classList.add('is-hidden');
      document.getElementById('setpwd-screen').classList.remove('is-hidden');
      document.getElementById('setpwd-email-label').textContent = 'Configurazione account per: ' + email;
      document.getElementById('setpwd-screen').dataset.userId = res.user_id;
      document.getElementById('setpwd-screen').dataset.email = email;
      return;
    }
    errEl.textContent = '⚠ ' + res.error;
    errEl.classList.add('is-visible');
    return;
  }

  _startSession(res.user);
}

var _pendingUserId = null;

async function doSetPassword() {
  var nome  = document.getElementById('setpwd-name').value.trim();
  var pwd1  = document.getElementById('setpwd-pwd1').value;
  var pwd2  = document.getElementById('setpwd-pwd2').value;
  var errEl = document.getElementById('setpwd-error');
  var screen = document.getElementById('setpwd-screen');

  errEl.classList.remove('is-visible');
  if (!nome)       { errEl.textContent='⚠ Inserisci il tuo nome.'; errEl.classList.add('is-visible'); return; }
  if (pwd1.length < 8) { errEl.textContent='⚠ La password deve essere di almeno 8 caratteri.'; errEl.classList.add('is-visible'); return; }
  if (pwd1 !== pwd2)   { errEl.textContent='⚠ Le password non coincidono.'; errEl.classList.add('is-visible'); return; }

  var btn = document.querySelector('#setpwd-screen .login-form__submit');
  btn.textContent = 'Attivazione in corso…'; btn.disabled = true;

  var userId = screen.dataset.userId || _pendingUserId;
  var email  = screen.dataset.email || '';
  var res = await _db.setPassword(userId, nome, pwd1);

  btn.disabled = false;
  btn.innerHTML = 'Attiva account e accedi <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>';

  if (res.error) {
    errEl.textContent = '⚠ ' + res.error;
    errEl.classList.add('is-visible');
    return;
  }

  screen.classList.add('is-hidden');
  _startSession({id: userId, email: email, nome: nome, ruolo: res.user ? res.user.ruolo : 'riscontro_tecnico'});
}

async function _startSession(user) {
  SESSION.user = user;
  document.getElementById('login-screen').classList.add('is-hidden');
  document.getElementById('setpwd-screen').classList.add('is-hidden');
  document.getElementById('app-shell').style.display = 'flex';

  // Aggiorna navbar
  var parts = user.nome ? user.nome.split(' ') : user.email.split('@')[0].split('.');
  var initials = parts.length >= 2 ? (parts[0][0] + parts[parts.length-1][0]).toUpperCase() : parts[0].slice(0,2).toUpperCase();
  var avatarEl = document.getElementById('nav-avatar');
  var usernameEl = document.getElementById('nav-username');
  var roleEl = document.getElementById('nav-role');
  if (avatarEl) avatarEl.textContent = initials;
  if (usernameEl) usernameEl.textContent = user.nome || user.email;
  if (roleEl) roleEl.textContent = user.ruolo === 'admin' ? 'Amministratore' : 'Riscontro Tecnico';

  // Mostra/nascondi ingranaggio admin nella navbar
  var adminGear = document.getElementById('btn-admin-gear');
  if (adminGear) adminGear.style.display = user.ruolo === 'admin' ? 'flex' : 'none';

  // Carica pratiche
  SESSION.pratiche = await _db.getPratiche(user.id, user.ruolo);
  renderDashboard();
}

function doLogout() {
  SESSION.user = null;
  SESSION.pratiche = [];
  if (_sb) _sb.auth.signOut();
  document.getElementById('app-shell').style.display = 'none';
  document.getElementById('login-screen').classList.remove('is-hidden');
  document.getElementById('login-email').value = '';
  document.getElementById('login-password').value = '';
}

/* ══════════════════════════════════════════════════════
   DASHBOARD RENDER
══════════════════════════════════════════════════════ */
function renderDashboard() {
  var list = document.getElementById('dash-list');
  if (!list) return;
  var searchEl = document.getElementById('dash-search');
  var q = searchEl ? searchEl.value.toLowerCase() : '';
  var pratiche = SESSION.pratiche.filter(function(p) {
    if (!q) return true;
    return (p.beneficiario||'').toLowerCase().includes(q)
        || (p.comune||'').toLowerCase().includes(q)
        || (p.rapporto||'').toLowerCase().includes(q);
  });

  if (pratiche.length === 0) {
    list.innerHTML = '<div style="text-align:center;padding:48px 0;color:var(--tx-lighter);font-size:13px">'
      + '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="display:block;margin:0 auto 10px;opacity:.4"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>'
      + (q ? 'Nessuna pratica corrisponde alla ricerca.' : 'Nessuna pratica assegnata. Usa "Nuova pratica" per iniziare.')
      + '</div>';
    return;
  }

  list.innerHTML = pratiche.map(function(p) {
    var importo = parseFloat(p.importo || 0);
    var erogato = parseFloat(p.erogato || 0);
    var pct = importo > 0 ? Math.round(erogato / importo * 100) : 0;
    var barColor = pct >= 100 ? 'var(--bg-success)' : 'var(--bg-primary)';
    var faseHtml = _faseBadge(p.fase);
    var ambitoHtml = p.ambito === 'Sport'
      ? '<span class="badge badge--green">Sport</span>'
      : '<span class="badge badge--blue">Cultura</span>';
    return '<div style="border:1px solid var(--bd-sec-light);border-radius:var(--r-smooth);background:var(--bg-inverse);margin-bottom:8px;overflow:hidden;transition:box-shadow .15s" '
      + 'onmouseover="this.style.boxShadow=\'0 2px 12px rgba(68,0,179,.1)\'" onmouseout="this.style.boxShadow=\'\'">'
      + '<div style="display:flex;align-items:stretch;gap:0">'
      + '  <div style="flex:1;padding:16px 20px;cursor:pointer" onclick="goPraticaById(\''+p.id+'\')">'
      + '    <div style="font-size:15px;font-weight:700;color:var(--tx-primary);margin-bottom:3px">'+escHtml(p.beneficiario||'—')+'</div>'
      + '    <div style="font-size:11px;color:var(--tx-lighter);font-family:var(--ff-mono);margin-bottom:6px">Rapporto '+escHtml(p.rapporto||'—')+'</div>'
      + '    <div style="display:flex;gap:6px;flex-wrap:wrap">'
      + '      <span class="badge badge--violet">'+escHtml(p.tipo_mutuo||'—')+'</span>'
      + '      '+ambitoHtml+'      '+faseHtml
      + '      <span style="font-size:11px;color:var(--tx-lighter);align-self:center">'+escHtml(p.comune||'—')+'</span>'
      + '    </div>'
      + '  </div>'
      + '  <div style="width:1px;background:var(--bd-sec-light);flex-shrink:0"></div>'
      + '  <div style="width:200px;padding:16px 20px;display:flex;flex-direction:column;justify-content:center;flex-shrink:0;cursor:pointer" onclick="goPraticaById(\''+p.id+'\')">'
      + '    <div style="font-size:13px;font-weight:700;color:var(--tx-primary);margin-bottom:2px">€ '+_fmt(importo)+'</div>'
      + '    <div style="font-size:11px;color:var(--tx-lighter);margin-bottom:10px">Importo deliberato</div>'
      + '    <div style="font-size:12px;font-weight:600;color:var(--tx-secondary)">Avanzamento spesa</div>'
      + '    <div style="height:6px;background:var(--bg-sec-light);border-radius:3px;margin-top:5px;overflow:hidden">'
      + '      <div style="width:'+pct+'%;height:100%;background:'+barColor+';border-radius:3px"></div>'
      + '    </div>'
      + '    <div style="font-size:12px;color:var(--tx-lighter);margin-top:4px;text-align:right;font-family:var(--ff-mono)">'+pct+'%</div>'
      + '  </div>'
      + '  <div style="width:32px;background:var(--bg-sec-lighter);display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0" onclick="goPraticaById(\''+p.id+'\')">'
      + '    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--tx-lighter)" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>'
      + '  </div>'
      + '</div></div>';
  }).join('');
}

function _faseBadge(fase) {
  var map = {
    'Pre-ammortamento': 'badge--amber',
    'Ammortamento': 'badge--green',
    'In lavorazione': 'badge--violet',
    'Chiusa': 'badge--gray'
  };
  return '<span class="badge '+(map[fase]||'badge--gray')+'">'+escHtml(fase||'—')+'</span>';
}

function _fmt(n) {
  return Number(n).toLocaleString('it-IT', {minimumFractionDigits:2, maximumFractionDigits:2});
}
function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

/* ══════════════════════════════════════════════════════
   NUOVA PRATICA
══════════════════════════════════════════════════════ */
async function doCreaPratica() {
  var rapporto    = document.getElementById('np-rapporto').value.trim();
  var beneficiario= document.getElementById('np-beneficiario').value.trim();
  var comune      = document.getElementById('np-comune').value.trim();
  var tipo        = document.getElementById('np-tipo').value;
  var ambito      = document.getElementById('np-ambito').value;
  var legge       = document.getElementById('np-legge').value;
  var importo     = document.getElementById('np-importo').value.replace(/\./g,'').replace(',','.');
  var stipula     = document.getElementById('np-stipula').value;
  var durata      = document.getElementById('np-durata').value;
  var ammort      = document.getElementById('np-ammort').value;
  var garanzia    = document.getElementById('np-garanzia').value;
  var cup         = document.getElementById('np-cup').value.trim();
  var oggetto     = document.getElementById('np-oggetto').value.trim();
  var note        = document.getElementById('np-note').value.trim();
  var errEl       = document.getElementById('nuova-pratica-error');

  errEl.style.display = 'none';
  var missing = [];
  if (!rapporto)     missing.push('N. Rapporto');
  if (!beneficiario) missing.push('Beneficiario');
  if (!comune)       missing.push('Comune');
  if (!tipo)         missing.push('Tipo mutuo');
  if (!ambito)       missing.push('Ambito');
  if (!oggetto)      missing.push('Oggetto del finanziamento');

  if (missing.length > 0) {
    errEl.textContent = '⚠ Campi obbligatori mancanti: ' + missing.join(', ');
    errEl.style.display = 'block';
    return;
  }

  var btn = document.getElementById('np-submit-btn');
  btn.disabled = true; btn.textContent = 'Creazione in corso…';

  var praticaData = {
    rapporto: rapporto,
    beneficiario: beneficiario,
    comune: comune,
    tipo_mutuo: tipo,
    ambito: ambito,
    legge: legge,
    importo: parseFloat(importo) || 0,
    data_stipula: stipula || null,
    durata_mesi: parseInt(durata) || null,
    inizio_ammortamento: ammort || null,
    garanzia: garanzia,
    cup: cup,
    oggetto: oggetto,
    note: note,
    assegnato_a: SESSION.user ? SESSION.user.id : null,
    stato: 'In lavorazione',
    fase: 'Pre-ammortamento',
    erogato: 0
  };

  var res = await _db.createPratica(praticaData);
  btn.disabled = false;
  btn.innerHTML = '&#10133; Crea pratica';

  if (res.error) {
    errEl.textContent = '⚠ ' + res.error;
    errEl.style.display = 'block';
    return;
  }

  SESSION.pratiche.unshift(res.pratica);
  renderDashboard();
  closeModal('modal-nuova-pratica');

  // Pulisci form
  ['np-rapporto','np-beneficiario','np-comune','np-importo','np-stipula','np-durata','np-ammort','np-cup','np-oggetto','np-note'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.value = '';
  });
  document.getElementById('np-tipo').value = '';
  document.getElementById('np-ambito').value = '';

  // Apri pratica appena creata
  setTimeout(function() { goPraticaById(res.pratica.id); }, 200);
}

/* ══════════════════════════════════════════════════════
   ADMIN — GESTIONE UTENTI
══════════════════════════════════════════════════════ */
async function goAdmin() {
  document.querySelectorAll('.page').forEach(function(p){ p.classList.remove('is-visible'); });
  document.getElementById('page-admin').classList.add('is-visible');
  document.querySelectorAll('.sb-item').forEach(function(i){ i.classList.remove('is-active'); });
  await renderAdminUsers();
  renderSqlExport();
}

async function renderAdminUsers() {
  var list = document.getElementById('admin-user-list');
  var badge = document.getElementById('admin-user-count');
  var users = await _db.getUsers();
  if (badge) badge.textContent = users.length + ' utenti';
  if (!list) return;
  if (users.length === 0) {
    list.innerHTML = '<div style="padding:24px;text-align:center;color:var(--tx-lighter);font-size:13px">Nessun utente.</div>';
    return;
  }
  list.innerHTML = users.map(function(u) {
    var statoHtml = u.stato === 'attivo'
      ? '<span class="sem sem--verde"><span class="sem__dot"></span>Attivo</span>'
      : '<span class="sem sem--arancio"><span class="sem__dot"></span>In attesa</span>';
    var ruoloHtml = u.ruolo === 'admin'
      ? '<span class="badge badge--violet">Admin</span>'
      : '<span class="badge badge--gray">Riscontro Tecnico</span>';
    var canDelete = u.ruolo !== 'admin' || (SESSION.user && SESSION.user.id !== u.id);
    return '<div style="display:grid;grid-template-columns:1fr 200px 120px 140px 90px;gap:0;padding:11px 20px;border-bottom:1px solid var(--bd-sec-light);align-items:center">'
      + '  <div>'
      + '    <div style="font-size:13px;font-weight:600">'+escHtml(u.nome||'—')+'</div>'
      + '    <div style="font-size:11px;color:var(--tx-lighter);margin-top:1px">'+escHtml(u.email)+'</div>'
      + '  </div>'
      + '  <div style="font-size:12px;color:var(--tx-lighter)">'+escHtml(u.email)+'</div>'
      + '  <div>'+ruoloHtml+'</div>'
      + '  <div>'+statoHtml+'</div>'
      + '  <div style="display:flex;gap:4px;justify-content:flex-end">'
      + (canDelete ? '    <button class="btn btn--ghost btn--xs" style="color:var(--tx-error)" onclick="confirmDeleteUser(\''+u.id+'\',\''+escHtml(u.nome||u.email)+'\')">&#128465;</button>' : '')
      + '  </div>'
      + '</div>';
  }).join('');
}

async function doInviteUser() {
  var email = document.getElementById('invite-email').value.trim();
  var nome  = document.getElementById('invite-name').value.trim();
  var ruolo = document.getElementById('invite-role').value;
  var btn   = document.getElementById('invite-submit-btn');
  var res2  = document.getElementById('invite-result');

  res2.style.display = 'none';
  if (!email || !nome) {
    _showResult(res2, 'error', '⚠ Inserisci email e nome.');
    return;
  }

  btn.disabled = true; btn.textContent = 'Invio in corso…';
  var res = await _db.inviteUser(email, nome, ruolo);
  btn.disabled = false; btn.innerHTML = '&#10133; Invia invito';

  if (res.error) { _showResult(res2, 'error', '⚠ ' + res.error); return; }

  _showResult(res2, 'success', '✅ Invito creato per ' + escHtml(email) + '. In modalità mock: accedi con email e password vuota per simulare il primo accesso.');
  document.getElementById('invite-email').value = '';
  document.getElementById('invite-name').value = '';
  await renderAdminUsers();
  setTimeout(function() { closeModal('modal-invita-utente'); res2.style.display='none'; }, 3000);
}

async function confirmDeleteUser(id, nome) {
  if (!confirm('Eliminare l\'utente "' + nome + '"? L\'azione è irreversibile.')) return;
  await _db.deleteUser(id);
  await renderAdminUsers();
}

function _showResult(el, type, html) {
  el.style.display = 'block';
  el.style.background = type === 'success' ? 'var(--bg-success-lighter)' : 'var(--bg-error-lighter)';
  el.style.border = '1px solid ' + (type === 'success' ? 'var(--bd-success)' : 'var(--bd-error)');
  el.style.color = type === 'success' ? 'var(--tx-success)' : 'var(--tx-error)';
  el.innerHTML = html;
}

/* ══════════════════════════════════════════════════════
   SQL EXPORT (per setup Supabase)
══════════════════════════════════════════════════════ */
var SUPABASE_SQL = `-- ============================================================
--  SONAR — Schema Supabase (esegui nel SQL Editor)
-- ============================================================

-- Profili utenti (estende auth.users)
CREATE TABLE IF NOT EXISTS public.profiles (
  id          UUID PRIMARY KEY REFERENCES auth.users(id) ON DELETE CASCADE,
  email       TEXT NOT NULL,
  nome        TEXT,
  ruolo       TEXT NOT NULL DEFAULT 'riscontro_tecnico' CHECK (ruolo IN ('admin','riscontro_tecnico')),
  stato       TEXT NOT NULL DEFAULT 'invitato' CHECK (stato IN ('invitato','attivo')),
  created_at  TIMESTAMPTZ DEFAULT NOW()
);

-- Trigger: crea profilo automaticamente al signup
CREATE OR REPLACE FUNCTION public.handle_new_user()
RETURNS TRIGGER AS $$
BEGIN
  INSERT INTO public.profiles (id, email, ruolo, stato)
  VALUES (NEW.id, NEW.email, 'riscontro_tecnico', 'invitato')
  ON CONFLICT (id) DO NOTHING;
  RETURN NEW;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

DROP TRIGGER IF EXISTS on_auth_user_created ON auth.users;
CREATE TRIGGER on_auth_user_created
  AFTER INSERT ON auth.users
  FOR EACH ROW EXECUTE FUNCTION public.handle_new_user();

-- Pratiche
CREATE TABLE IF NOT EXISTS public.pratiche (
  id                   UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  rapporto             TEXT NOT NULL UNIQUE,
  beneficiario         TEXT NOT NULL,
  comune               TEXT,
  tipo_mutuo           TEXT,
  ambito               TEXT CHECK (ambito IN ('Sport','Cultura')),
  legge                TEXT,
  importo              NUMERIC(14,2) DEFAULT 0,
  erogato              NUMERIC(14,2) DEFAULT 0,
  data_stipula         DATE,
  durata_mesi          INTEGER,
  inizio_ammortamento  DATE,
  garanzia             TEXT,
  cup                  TEXT,
  oggetto              TEXT,
  note                 TEXT,
  stato                TEXT DEFAULT 'In lavorazione',
  fase                 TEXT DEFAULT 'Pre-ammortamento',
  sal_count            INTEGER DEFAULT 0,
  assegnato_a          UUID REFERENCES public.profiles(id),
  created_at           TIMESTAMPTZ DEFAULT NOW(),
  updated_at           TIMESTAMPTZ DEFAULT NOW()
);

-- Documenti
CREATE TABLE IF NOT EXISTS public.documenti (
  id          UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  pratica_id  UUID NOT NULL REFERENCES public.pratiche(id) ON DELETE CASCADE,
  tipo        TEXT,
  nome        TEXT,
  file_name   TEXT,
  file_path   TEXT,
  url         TEXT,
  dimensione  TEXT,
  caricato_da UUID REFERENCES public.profiles(id),
  created_at  TIMESTAMPTZ DEFAULT NOW()
);

-- RLS: abilita Row Level Security
ALTER TABLE public.profiles  ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.pratiche  ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.documenti ENABLE ROW LEVEL SECURITY;

-- Policies profiles
CREATE POLICY "Utente vede solo il proprio profilo"
  ON public.profiles FOR SELECT
  USING (auth.uid() = id);

CREATE POLICY "Admin vede tutti i profili"
  ON public.profiles FOR SELECT
  USING (EXISTS (SELECT 1 FROM public.profiles WHERE id=auth.uid() AND ruolo='admin'));

CREATE POLICY "Admin gestisce profili"
  ON public.profiles FOR ALL
  USING (EXISTS (SELECT 1 FROM public.profiles WHERE id=auth.uid() AND ruolo='admin'));

-- Policies pratiche
CREATE POLICY "Utente vede pratiche assegnate"
  ON public.pratiche FOR SELECT
  USING (assegnato_a = auth.uid()
    OR EXISTS (SELECT 1 FROM public.profiles WHERE id=auth.uid() AND ruolo='admin'));

CREATE POLICY "Utente modifica pratiche assegnate"
  ON public.pratiche FOR UPDATE
  USING (assegnato_a = auth.uid()
    OR EXISTS (SELECT 1 FROM public.profiles WHERE id=auth.uid() AND ruolo='admin'));

CREATE POLICY "Utente inserisce pratiche"
  ON public.pratiche FOR INSERT
  WITH CHECK (auth.uid() IS NOT NULL);

-- Policies documenti
CREATE POLICY "Accesso documenti tramite pratica"
  ON public.documenti FOR ALL
  USING (EXISTS (
    SELECT 1 FROM public.pratiche
    WHERE id = documenti.pratica_id
    AND (assegnato_a = auth.uid()
      OR EXISTS (SELECT 1 FROM public.profiles WHERE id=auth.uid() AND ruolo='admin'))
  ));

-- Storage bucket (esegui separatamente dal dashboard Supabase > Storage)
-- Crea bucket: sonar-documenti (privato)
-- INSERT INTO storage.buckets (id, name, public) VALUES ('sonar-documenti', 'sonar-documenti', false);`;

function renderSqlExport() {
  var el = document.getElementById('sql-export');
  if (el) el.textContent = SUPABASE_SQL;
}

function copySql() {
  navigator.clipboard.writeText(SUPABASE_SQL).then(function() {
    var btn = event.target;
    btn.textContent = '✓ Copiato!';
    setTimeout(function(){ btn.innerHTML='&#128203; Copia SQL'; }, 2000);
  });
}

/* ══════════════════════════════════════════════════════
   UPLOAD DOCUMENTO (collegato a pratica corrente)
══════════════════════════════════════════════════════ */
var _uploadFile = null;

/* ══════════════════════════════════════════════════════
   NAVIGAZIONE PAGINE (override)
══════════════════════════════════════════════════════ */

/* ─── UPLOAD DOCUMENTO ─── */
var _uploadFile = null;

function handleUploadFileSelect(input) {
  if (input.files && input.files[0]) _setUploadFile(input.files[0]);
}
function handleUploadDrop(event) {
  var file = event.dataTransfer.files[0];
  if (file) _setUploadFile(file);
}
function _setUploadFile(file) {
  _uploadFile = file;
  var preview = document.getElementById('upload-file-preview');
  preview.style.display = 'flex';
  document.getElementById('upload-file-name').textContent = file.name;
  var kb = file.size / 1024;
  document.getElementById('upload-file-size').textContent = kb < 1024 ? kb.toFixed(0) + ' KB' : (kb/1024).toFixed(1) + ' MB';
  document.getElementById('upload-result').style.display = 'none';
}
function clearUploadFile() {
  _uploadFile = null;
  document.getElementById('upload-file-preview').style.display = 'none';
  document.getElementById('upload-file-input').value = '';
}
function clearUploadState() {
  clearUploadFile();
  document.getElementById('upload-progress-wrap').style.display = 'none';
  document.getElementById('upload-result').style.display = 'none';
  var tipo = document.getElementById('upload-doc-tipo');
  var desc = document.getElementById('upload-doc-desc');
  if (tipo) tipo.value = '';
  if (desc) desc.value = '';
}

function _uploadShowResult(type, html) {
  var el = document.getElementById('upload-result');
  el.style.display = 'block';
  el.style.background = type === 'success' ? 'var(--bg-success-lighter)' : 'var(--bg-error-lighter)';
  el.style.border = '1px solid ' + (type === 'success' ? 'var(--bd-success)' : 'var(--bd-error)');
  el.style.color = type === 'success' ? 'var(--tx-success)' : 'var(--tx-error)';
  el.innerHTML = html;
}

function _injectDocIntoUI(fileName, tipo, desc, url) {
  var kb = _uploadFile ? (_uploadFile.size / 1024).toFixed(0) + ' KB' : '—';
  var today = new Date().toLocaleDateString('it-IT');
  var displayName = desc || fileName;
  var actionsBtns = url
    ? '<a href="' + url + '" target="_blank" class="btn btn--ghost btn--xs">&#128065;</a><a href="' + url + '" download class="btn btn--ghost btn--xs">&#11015;</a>'
    : '<button class="btn btn--ghost btn--xs" disabled>&#11015;</button>';

  // Inserisci nel fascicolo
  var fascBadge = document.getElementById('fasc-tot-badge');
  if (fascBadge) {
    var n = parseInt(fascBadge.textContent) || 0;
    fascBadge.textContent = (n + 1) + ' documenti';
  }
  var fascBody = document.getElementById('fasc-docs');
  if (fascBody) {
    var row = document.createElement('div');
    row.className = 'doc-row';
    row.innerHTML = '<div class="doc-icon doc-icon--pdf">&#128196;</div>'
      + '<div class="doc-info"><div class="doc-name">' + displayName + '</div>'
      + '<div class="doc-meta">PDF &#183; ' + kb + ' &#183; ' + today + ' &#183; Caricato manualmente</div></div>'
      + '<span class="badge badge--gray" style="flex-shrink:0">' + tipo + '</span>'
      + '<span class="sem sem--verde" style="flex-shrink:0"><span class="sem__dot"></span>Acquisito</span>'
      + '<div class="doc-actions">' + actionsBtns + '</div>';
    fascBody.insertBefore(row, fascBody.firstChild);
  }
}

/* ─── Rendi gli upload-btn del wizard apertura modal ─── */
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.upload-btn:not([data-sb-bound])').forEach(function(btn) {
    btn.setAttribute('data-sb-bound', '1');
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      openModal('modal-upload-doc');
    });
  });
});
</script>

<!-- Modal: Dettaglio Item (catena documentale) -->
<div class="overlay" id="modal-item-detail">
  <div class="modal modal--lg" style="max-width:760px;width:100%;max-height:90vh;display:flex;flex-direction:column;padding:0">
    <div class="modal__header" style="flex-shrink:0">
      <div>
        <div class="modal__title" id="mid-title">Dettaglio Item</div>
        <div id="mid-semaforo" style="margin-top:6px"></div>
      </div>
      <button class="modal__close" onclick="closeModal('modal-item-detail')">✕</button>
    </div>
    <div style="flex:1;overflow-y:auto;padding:20px">
      <div class="g2" style="gap:14px;margin-bottom:20px">
        <div>
          <div class="section-label" style="margin-bottom:10px">Anagrafica SAL</div>
          <div class="field-row"><span class="field-row__label">Tipo</span><span class="field-row__value" id="mid-tipo"></span></div>
          <div class="field-row"><span class="field-row__label">Progressivo</span><span class="field-row__value field-row__value--mono" id="mid-progr"></span></div>
          <div class="field-row"><span class="field-row__label">Data</span><span class="field-row__value field-row__value--mono" id="mid-data"></span></div>
          <div class="field-row"><span class="field-row__label">Importo</span><span class="field-row__value field-row__value--mono" style="font-weight:700;color:var(--tx-secondary)" id="mid-importo"></span></div>
          <div class="field-row"><span class="field-row__label">DL</span><span class="field-row__value" id="mid-dl"></span></div>
          <div class="field-row"><span class="field-row__label">Impresa</span><span class="field-row__value" id="mid-impresa"></span></div>
          <div class="field-row" style="border-bottom:none;align-items:flex-start"><span class="field-row__label">Oggetto</span><span class="field-row__value" id="mid-oggetto" style="font-size:12px;color:var(--tx-lighter)"></span></div>
        </div>
        <div>
          <div class="section-label" style="margin-bottom:10px">Presenza documenti</div>
          <div id="mid-docs"></div>
        </div>
      </div>
      <div class="section-label" style="margin-bottom:10px">Catene documentali associate</div>
      <div style="overflow-x:auto">
        <table style="width:100%;border-collapse:collapse;font-size:12px">
          <thead>
            <tr style="background:var(--bg-sec-lighter)">
              <th style="padding:7px 12px;text-align:left;font-size:10px;font-weight:700;color:var(--tx-lighter);text-transform:uppercase">Procedura</th>
              <th style="padding:7px 12px;text-align:left;font-size:10px;font-weight:700;color:var(--tx-lighter);text-transform:uppercase">Contratto</th>
              <th style="padding:7px 12px;text-align:left;font-size:10px;font-weight:700;color:var(--tx-lighter);text-transform:uppercase">Fattura</th>
              <th style="padding:7px 12px;text-align:left;font-size:10px;font-weight:700;color:var(--tx-lighter);text-transform:uppercase">Pagamento</th>
              <th style="padding:7px 12px;text-align:right;font-size:10px;font-weight:700;color:var(--tx-lighter);text-transform:uppercase">Importo</th>
            </tr>
          </thead>
          <tbody id="mid-catene"></tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
/* ══════════════════════════════════════════════════════
   PRATICA DETAIL — carica tutti i tab
══════════════════════════════════════════════════════ */

async function goPraticaById(id) {
  _currentPraticaId = id;
  var p = await _db.getPratica(id);
  if (!p) return;
  _currentPratica = p;

  // Header
  var bc = document.getElementById('pratica-breadcrumb');
  var title = document.getElementById('pratica-title');
  if (bc) bc.textContent = (p.rapporto||'—') + ' — ' + (p.beneficiario||'—');
  if (title) title.textContent = (p.beneficiario||'—') + ' — ' + (p.comune||'—');

  var meta = document.getElementById('pratica-meta');
  if (meta) {
    var ab = p.ambito==='Cultura'?'badge--blue':'badge--green';
    meta.innerHTML = '<span class="badge badge--violet">'+escHtml(p.tipo_mutuo||'—')+'</span>'
      +'<span class="badge '+ab+'">'+escHtml(p.ambito||'—')+'</span>'
      +'<span class="badge badge--amber">'+escHtml(p.fase||'—')+'</span>'
      +'<span style="font-size:12px;color:var(--tx-lighter)">Rapp. <strong>'+escHtml(p.rapporto||'—')+'</strong> · '+escHtml(p.legge||'—')+'</span>';
  }

  // Carica tutti i tab
  await _loadTabAnagrafica(p);
  await _loadTabQTE(p);
  await _loadTabSAL(p);
  await _loadTabFascicolo(p);
  await _loadTabMonitoraggio(p);

  goPratica();
  switchTab('anagrafica', document.querySelector('#pratica-tabs .tab'));
}

var _currentPraticaId = null;
var _currentPratica = null;
var _dirtyTabs = {};

function markDirty(tab) {
  _dirtyTabs[tab] = true;
  var dirty = document.getElementById(tab+'-dirty-msg');
  var saved = document.getElementById(tab+'-save-msg');
  if (dirty) dirty.style.display = 'inline';
  if (saved) saved.style.display = 'none';
}

/* ── TAB 1: ANAGRAFICA ── */
async function _loadTabAnagrafica(p) {
  // KPI
  var importo = parseFloat(p.importo||0);
  var erogato = parseFloat(p.erogato||0);
  document.getElementById('kpi-importo').textContent = '€ '+_fmt(importo);
  document.getElementById('kpi-erogato').textContent = '€ '+_fmt(erogato);
  document.getElementById('kpi-residuo').textContent = '€ '+_fmt(importo-erogato);
  var sals = _store.get('sals_'+p.id)||[];
  document.getElementById('kpi-sal').textContent = sals.length;

  // Anagrafica fields
  var rows = [
    ['Denominazione', p.beneficiario],
    ['Comune', p.comune],
    ['Legge di riferimento', p.legge],
    ['Tipo mutuo', p.tipo_mutuo],
    ['Ambito', p.ambito],
    ['Data stipula', p.data_stipula ? new Date(p.data_stipula).toLocaleDateString('it-IT') : '—'],
    ['Durata', p.durata_mesi ? p.durata_mesi+' mesi' : '—'],
    ['Inizio ammortamento', p.inizio_ammortamento ? new Date(p.inizio_ammortamento).toLocaleDateString('it-IT') : '—'],
    ['Garanzia', p.garanzia||'—'],
    ['CUP', p.cup||'—'],
    ['Oggetto', p.oggetto||'—']
  ];
  var af = document.getElementById('anagrafica-fields');
  if (af) af.innerHTML = rows.map(function(r,i){
    return '<div class="field-row"'+(i===rows.length-1?' style="border-bottom:none"':'')+'>'
      +'<span class="field-row__label">'+r[0]+'</span>'
      +'<span class="field-row__value" style="font-size:12px">'+escHtml(String(r[1]||'—'))+'</span>'
      +'</div>';
  }).join('');

  // Stato badge
  var statoBadge = document.getElementById('pratica-stato-badge');
  var statoMap = {
    'In lavorazione':'sem--arancio','In attesa documenti':'sem--grigio',
    'In verifica':'sem--arancio','In firma N.O.':'sem--viola','Chiusa':'sem--grigio'
  };
  if (statoBadge) statoBadge.className = 'sem '+(statoMap[p.stato]||'sem--grigio');
  var statoTxt = document.getElementById('pratica-stato-txt');
  if (statoTxt) statoTxt.textContent = p.stato||'—';

  // Selects
  var faseEl = document.getElementById('edit-fase');
  var statoEl = document.getElementById('edit-stato');
  var noteEl  = document.getElementById('edit-note');
  if (faseEl)  faseEl.value  = p.fase  || 'Pre-ammortamento';
  if (statoEl) statoEl.value = p.stato || 'In lavorazione';
  if (noteEl)  noteEl.value  = p.note  || '';
  _dirtyTabs['anagrafica'] = false;
  var dirty = document.getElementById('anagrafica-dirty-msg');
  if (dirty) dirty.style.display = 'none';

  // Avanzamento steps
  _renderAvanzamento(p, sals);
}

function _renderAvanzamento(p, sals) {
  var el = document.getElementById('avanzamento-steps');
  if (!el) return;
  var fasi = [
    {label:'Stipula contratto', sub: p.data_stipula ? new Date(p.data_stipula).toLocaleDateString('it-IT') : 'Data da inserire', done: !!p.data_stipula},
    {label:'Pre-ammortamento', sub:'Fase iniziale del mutuo', done: true}
  ];
  sals.forEach(function(s,i){
    fasi.push({label:'SAL '+s.progressivo+' — '+s.tipo, sub:'€ '+_fmt(s.importo)+' · '+new Date(s.data).toLocaleDateString('it-IT'), done:true, erogato:s.stato_erogazione==='Erogato'});
  });
  fasi.push({label:'Chiusura pratica', sub:'Da completare', done: p.stato==='Chiusa'});

  el.innerHTML = '<div class="stepper">'+fasi.map(function(f,i){
    var dotClass = f.done ? 'step__dot--done' : (i===fasi.length-1?'step__dot--todo':'step__dot--todo');
    var lineClass = f.done&&i<fasi.length-1 ? 'step__line--done' : '';
    var icon = f.done ? '✓' : (i+1);
    return '<div class="step">'
      +'<div class="step__spine">'
      +'<div class="step__dot '+dotClass+'">'+icon+'</div>'
      +(i<fasi.length-1?'<div class="step__line '+lineClass+'"></div>':'')
      +'</div>'
      +'<div class="step__info">'
      +'<div class="step__title'+(f.done?'':' step__title--todo')+'">'+escHtml(f.label)+'</div>'
      +'<div class="step__sub">'+escHtml(f.sub)+'</div>'
      +'</div></div>';
  }).join('')+'</div>';
}

async function saveAnagrafica() {
  if (!_currentPraticaId) return;
  var fase  = document.getElementById('edit-fase').value;
  var stato = document.getElementById('edit-stato').value;
  var note  = document.getElementById('edit-note').value;
  var res = await _db.updatePratica(_currentPraticaId, {fase:fase, stato:stato, note:note});
  if (res.error) { alert('Errore: '+res.error); return; }
  _currentPratica.fase = fase; _currentPratica.stato = stato; _currentPratica.note = note;
  _dirtyTabs['anagrafica'] = false;
  var dirty = document.getElementById('anagrafica-dirty-msg');
  var saved = document.getElementById('anagrafica-save-msg');
  if (dirty) dirty.style.display = 'none';
  if (saved) { saved.style.display = 'inline'; setTimeout(function(){saved.style.display='none';},2000); }
  // Aggiorna badge
  var statoTxt = document.getElementById('pratica-stato-txt');
  if (statoTxt) statoTxt.textContent = stato;
  // Aggiorna in SESSION
  var idx = SESSION.pratiche.findIndex(function(p){return p.id===_currentPraticaId;});
  if (idx>-1) { SESSION.pratiche[idx].fase=fase; SESSION.pratiche[idx].stato=stato; SESSION.pratiche[idx].note=note; }
}

/* ── TAB 2: QTE ── */
async function _loadTabQTE(p) {
  var voci = _store.get('qte_'+p.id) || [];
  _renderQTE(voci);
}

function _renderQTE(voci) {
  var tbody = document.getElementById('qte-tbody');
  var tfoot = document.getElementById('qte-tfoot');
  if (!tbody) return;

  if (voci.length === 0) {
    tbody.innerHTML = '<tr><td colspan="7" style="padding:28px;text-align:center;color:var(--tx-lighter);font-size:13px">Nessuna voce. Clicca "+ Voce" per aggiungere.</td></tr>';
    if (tfoot) tfoot.innerHTML = '';
    return;
  }

  var totCosto=0, totAmm=0, totAppr=0, totContr=0;
  tbody.innerHTML = voci.map(function(v,i){
    var contr = (parseFloat(v.approvato||0)) * (parseFloat(v.intensita||0)) / 100;
    totCosto += parseFloat(v.costo||0);
    totAmm   += parseFloat(v.ammissibile||0);
    totAppr  += parseFloat(v.approvato||0);
    totContr += contr;
    return '<tr>'
      +'<td><input style="width:100%;border:1px solid var(--bd-sec-light);border-radius:2px;padding:4px 8px;font-family:var(--ff-body);font-size:13px;font-weight:600;outline:none" value="'+escHtml(v.voce||'')+'" oninput="qteUpdateRow('+i+',\'voce\',this.value)" placeholder="Voce di spesa…"></td>'
      +'<td><input style="width:100%;border:1px solid var(--bd-sec-light);border-radius:2px;padding:4px 8px;font-family:var(--ff-mono);font-size:12px;text-align:right;outline:none" value="'+_fmt(v.costo||0)+'" oninput="qteUpdateRow('+i+',\'costo\',this.value)" onblur="qteReformat(this)"></td>'
      +'<td><input style="width:100%;border:1px solid var(--bd-sec-light);border-radius:2px;padding:4px 8px;font-family:var(--ff-mono);font-size:12px;text-align:right;outline:none" value="'+_fmt(v.ammissibile||0)+'" oninput="qteUpdateRow('+i+',\'ammissibile\',this.value)" onblur="qteReformat(this)"></td>'
      +'<td><input style="width:100%;border:1px solid var(--bd-sec-light);border-radius:2px;padding:4px 8px;font-family:var(--ff-mono);font-size:12px;text-align:right;outline:none" value="'+_fmt(v.approvato||0)+'" oninput="qteUpdateRow('+i+',\'approvato\',this.value)" onblur="qteReformat(this)"></td>'
      +'<td><input style="width:100%;border:1px solid var(--bd-sec-light);border-radius:2px;padding:4px 8px;font-family:var(--ff-mono);font-size:12px;text-align:right;outline:none" value="'+(v.intensita||50)+'" oninput="qteUpdateRow('+i+',\'intensita\',this.value)"></td>'
      +'<td style="text-align:right;font-family:var(--ff-mono);font-size:12px;font-weight:600;padding:7px 14px;color:var(--tx-secondary)">'+_fmt(contr)+'</td>'
      +'<td style="padding:0 4px"><button style="border:none;background:none;color:var(--tx-error);cursor:pointer;font-size:16px;padding:0 4px" onclick="qteDelRow('+i+')">×</button></td>'
      +'</tr>';
  }).join('');

  if (tfoot) tfoot.innerHTML = '<tr style="background:var(--bg-primary-light)">'
    +'<td style="padding:9px 14px;font-weight:700;color:var(--tx-secondary)">Totale</td>'
    +'<td style="padding:9px 14px;text-align:right;font-family:var(--ff-mono);font-weight:700;color:var(--tx-secondary)">'+_fmt(totCosto)+'</td>'
    +'<td style="padding:9px 14px;text-align:right;font-family:var(--ff-mono);font-weight:700;color:var(--tx-secondary)">'+_fmt(totAmm)+'</td>'
    +'<td style="padding:9px 14px;text-align:right;font-family:var(--ff-mono);font-weight:700;color:var(--tx-secondary)">'+_fmt(totAppr)+'</td>'
    +'<td></td>'
    +'<td style="padding:9px 14px;text-align:right;font-family:var(--ff-mono);font-weight:700;color:var(--tx-secondary)">'+_fmt(totContr)+'</td>'
    +'<td></td></tr>';
}

var _qteData = [];
function qteUpdateRow(i, field, val) {
  if (!_qteData[i]) return;
  _qteData[i][field] = val.replace(/\./g,'').replace(',','.');
  markDirty('qte');
  _renderQTE(_qteData);
}
function qteReformat(input) {
  var v = parseFloat(input.value.replace(/\./g,'').replace(',','.')) || 0;
  input.value = _fmt(v);
}
function qteAddRow() {
  _qteData.push({voce:'',costo:0,ammissibile:0,approvato:0,intensita:50});
  markDirty('qte');
  _renderQTE(_qteData);
}
function qteDelRow(i) {
  _qteData.splice(i,1);
  markDirty('qte');
  _renderQTE(_qteData);
}
async function saveQTE() {
  if (!_currentPraticaId) return;
  _store.set('qte_'+_currentPraticaId, _qteData);
  _dirtyTabs['qte'] = false;
  var dirty = document.getElementById('qte-dirty-msg');
  var saved = document.getElementById('qte-save-msg');
  if (dirty) dirty.style.display='none';
  if (saved) { saved.style.display='inline'; setTimeout(function(){saved.style.display='none';},2000); }
}

/* ── TAB 3: SAL / GESTIONE SVINCOLO ── */
var _salCateneCount = 0;
var _salPendingDocs = [];
var _salCurrentBtn  = null;
var _salCurrentDocTipo = '';

/* ── Wizard SAL — step navigation ── */
function salWizStep(n) {
  for (var i=1;i<=4;i++) {
    var panel = document.getElementById('sal-wp-'+i);
    var step  = document.getElementById('sal-ws-'+i);
    var numEl = document.getElementById('sal-ws-'+i+'-num');
    if (panel) panel.style.display = i===n ? 'block' : 'none';
    if (step) {
      step.style.color       = i===n ? 'var(--tx-secondary)' : 'var(--tx-lighter)';
      step.style.fontWeight  = i===n ? '600' : '500';
      step.style.borderBottom= i===n ? '3px solid var(--bd-primary)' : '3px solid transparent';
    }
    if (numEl && i!==1) {
      numEl.style.background = i===n ? 'var(--bg-primary)' : i<n ? 'var(--bg-success)' : 'var(--bg-sec-light)';
      numEl.style.color      = i===n||i<n ? '#fff' : 'var(--tx-lighter)';
      numEl.textContent      = i<n ? '✓' : String(i);
    }
  }
  if (n===4) _buildSALRiepilogo();
}

/* ── Carica tab SAL ── */
async function _loadTabSAL(p) {
  var sals = _store.get('sals_'+p.id)||[];
  _renderSALList(sals);
}

function _renderSALList(sals) {
  var list = document.getElementById('sal-list');
  if (!list) return;
  if (sals.length===0) {
    list.innerHTML = '<div class="card"><div class="card__body" style="text-align:center;color:var(--tx-lighter);font-size:13px;padding:32px">'
      +'<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="display:block;margin:0 auto 8px;opacity:.4"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>'
      +'Nessun SAL inserito. Clicca "Nuovo SAL" per iniziare.</div></div>';
    return;
  }
  var statoMap = {'In verifica':'sem--arancio','Conforme':'sem--verde','Non conforme':'sem--rosso','In firma N.O.':'sem--viola','Erogato':'sem--verde','da lavorare':'sem--grigio'};
  var ctrlMap = {'da lavorare':'sem--grigio','In verifica':'sem--arancio','Conforme':'sem--verde','Non conforme':'sem--rosso','In firma N.O.':'sem--viola','bozza':'sem--grigio'};
  list.innerHTML = sals.map(function(s){
    var tipoClass = s.tipo==='Saldo finale'?'tag--saldo':s.tipo==='Anticipazione'?'tag--ant':'tag--sal';
    var nCatene = (s.catene||[]).length;
    return '<div class="card" style="border-left:4px solid var(--bg-emphasis)">'
      +'<div class="card__header">'
      +'<div style="display:flex;align-items:center;gap:10px">'
      +'<span class="tag '+tipoClass+'">'+escHtml(s.tipo)+'</span>'
      +'<span style="font-size:14px;font-weight:700">#'+s.progressivo+' — '+escHtml(s.oggetto||'SAL')+'</span>'
      +'<span class="badge badge--gray">'+nCatene+' catene</span>'
      +'</div>'
      +'<div style="display:flex;align-items:center;gap:8px">'
      +'<span class="sem '+(statoMap[s.stato_controllo]||'sem--grigio')+'"><span class="sem__dot"></span>'+escHtml(s.stato_controllo||'da lavorare')+'</span>'
      +'<button class="btn btn--tertiary btn--xs" onclick="openSALDetail(\''+s.id+'\')">Apri</button>'
      +'</div></div>'
      +'<div class="card__body">'
      +'<div style="display:grid;grid-template-columns:repeat(5,1fr);gap:12px;font-size:12px">'
      +'<div><div style="color:var(--tx-lighter);font-size:10px;text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px">Data</div><div style="font-family:var(--ff-mono)">'+new Date(s.data).toLocaleDateString('it-IT')+'</div></div>'
      +'<div><div style="color:var(--tx-lighter);font-size:10px;text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px">Importo</div><div style="font-family:var(--ff-mono);font-weight:700;color:var(--tx-secondary)">&#8364; '+_fmt(s.importo)+'</div></div>'
      +'<div><div style="color:var(--tx-lighter);font-size:10px;text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px">DL</div><div>'+escHtml(s.dl||'&#8212;')+'</div></div>'
      +'<div><div style="color:var(--tx-lighter);font-size:10px;text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px">Erogazione</div><div><span class="sem '+(s.stato_erogazione==='Erogato'?'sem--verde':'sem--grigio')+'"><span class="sem__dot"></span>'+escHtml(s.stato_erogazione||'In attesa')+'</span></div></div>'
      +'<div><div style="color:var(--tx-lighter);font-size:10px;text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px">Controllo</div><div><span class="sem '+(ctrlMap[s.stato_controllo]||'sem--grigio')+'"><span class="sem__dot"></span>'+escHtml(s.stato_controllo||'da lavorare')+'</span></div></div>'
      +'</div></div></div>';
  }).join('');
}

/* ── Reset modal SAL ── */
function openModalNuovoSAL() {
  _salCateneCount = 0;
  _salPendingDocs = [];
  document.getElementById('sal-catene-container').innerHTML = '';
  document.getElementById('sal-catene-badge').textContent = '0';
  var oggi = new Date().toISOString().split('T')[0];
  document.getElementById('sal-data').value = oggi;
  var sals = _store.get('sals_'+(_currentPraticaId||''))||[];
  document.getElementById('sal-progr').value = sals.length+1;
  document.getElementById('sal-tipo').value = 'SAL intermedio';
  ['sal-importo','sal-dl','sal-impresa','sal-oggetto','sal-note'].forEach(function(id){
    var el=document.getElementById(id); if(el) el.value='';
  });
  document.querySelectorAll('#sal-docs-checklist .upload-btn').forEach(function(b){
    b.classList.remove('is-uploaded'); b.innerHTML='&#11014; Carica';
  });
  document.getElementById('sal-error').style.display='none';
  _salCatenaFiles = {};
  salWizStep(1);
  openModal('modal-nuovo-sal');
}

/* ── Aggiunge una catena nel wizard ── */
function salAddCatena() {
  _salCateneCount++;
  var n = _salCateneCount;
  var container = document.getElementById('sal-catene-container');

  var div = document.createElement('div');
  div.id = 'sal-catena-'+n;
  div.style.cssText = 'border:1.5px solid var(--bd-sec-light);border-radius:var(--r-smooth);background:var(--bg-inverse);overflow:hidden';

  // 5 document fields: proc, contr, inc, fat, pag
  var docFields = [
    {key:'proc',  label:'Procedura',            ph:'es. ICSC-6300-001', hint:'Codice procedura di affidamento'},
    {key:'contr', label:'Contratto aperto',      ph:'es. CT-2025-001',   hint:'Riferimento contratto quadro'},
    {key:'inc',   label:'Incarico/attingimento', ph:'es. INC-4521',      hint:'Numero incarico specifico'},
    {key:'fat',   label:'Fattura',               ph:'es. FAT-31/2025',   hint:'Numero fattura fornitore'},
    {key:'pag',   label:'Pagamento/bonifico',    ph:'es. PAG-2025-031',  hint:'Riferimento bonifico/quietanza'}
  ];

  // Build the 5 document cells (top grid)
  var docCells = docFields.map(function(f) {
    return '<div style="padding:8px 12px;border-right:1px solid var(--bd-sec-light);min-width:0">'
      + '<div style="font-size:10px;font-weight:700;color:var(--tx-lighter);text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px">'+f.label+'</div>'
      + '<input type="text" name="cat_'+f.key+'" placeholder="'+f.ph+'" title="'+f.hint
      +  '" style="width:100%;border:none;outline:none;font-family:var(--ff-body);font-size:12px;background:transparent;padding:0;margin-bottom:6px"'
      +  ' oninput="salCheckCatenaStatus('+n+')">'
      + '<div style="display:flex;align-items:center;gap:4px;margin-top:2px">'
      + '<button type="button" class="cat-upload-btn" data-catena="'+n+'" data-field="'+f.key
      +   '" onclick="salCatenaUpload('+n+',\''+f.key+'\',this)"'
      +   ' style="font-size:10px;font-weight:600;padding:2px 7px;border-radius:3px;border:1px solid var(--bd-prim-light);color:var(--tx-secondary);background:var(--bg-primary-light);cursor:pointer;white-space:nowrap;flex-shrink:0">&#11014; Doc</button>'
      + '<span class="cat-doc-name" id="cat-docname-'+n+'-'+f.key
      +   '" style="font-size:10px;color:var(--tx-lighter);overflow:hidden;text-overflow:ellipsis;white-space:nowrap"></span>'
      + '</div>'
      + '</div>';
  }).join('');

  div.innerHTML =
    '<div style="display:flex;align-items:center;justify-content:space-between;padding:9px 14px;background:var(--bg-sec-lighter);border-bottom:1px solid var(--bd-sec-light)">'
    +'<span style="font-size:12px;font-weight:700;color:var(--tx-secondary)">Catena '+n+'</span>'
    +'<div style="display:flex;align-items:center;gap:8px">'
    +'<span class="sal-catena-status sem sem--grigio" id="sal-cat-status-'+n+'"><span class="sem__dot"></span>Incompleta</span>'
    +'<button type="button" onclick="document.getElementById(\'sal-catena-'+n+'\').remove();salUpdateCateneCount()" style="border:none;background:none;color:var(--tx-error);cursor:pointer;font-size:16px;padding:0;line-height:1" title="Elimina catena">&#10005;</button>'
    +'</div></div>'
    // Row 1: 5 document elements
    +'<div style="display:grid;grid-template-columns:repeat(5,1fr);gap:0;border-bottom:1px solid var(--bd-sec-light)">'
    +docCells
    +'</div>'
    // Row 2: fornitore, importi, tipologia
    +'<div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:0">'
    +_salCatenaFieldHtml(n,'forn','Fornitore','es. Edilizia Bari SRL','Ragione sociale del fornitore')
    +_salCatenaFieldHtml(n,'imp_inerente','Importo inerente (€)','0,00','Importo della spesa inerente','number')
    +_salCatenaFieldHtml(n,'imp_rendicontabile','Importo rendicontabile (€)','0,00','Importo rendicontabile','number')
    +_salCatenaFieldHtml(n,'tipologia','Tipologia spesa','Lavori','Natura della spesa','select','Lavori|Spese tecniche|Attrezzature|Oneri sicurezza|Contributi istituzionali|Altro')
    +'</div>';

  container.appendChild(div);
  salUpdateCateneCount();
  div.querySelectorAll('input,select').forEach(function(el){
    el.addEventListener('input',  function(){ salCheckCatenaStatus(n); });
    el.addEventListener('change', function(){ salCheckCatenaStatus(n); });
  });
}

/* Genera un campo testo/select per la riga 2 della catena (fornitore, importi, tipologia) */
function _salCatenaFieldHtml(n, field, label, placeholder, hint, type, options) {
  type = type || 'text';
  var inputHtml;
  if (type === 'select') {
    var opts = (options||'').split('|').map(function(o){
      return '<option value="'+escHtml(o)+'">'+escHtml(o)+'</option>';
    }).join('');
    inputHtml = '<select name="cat_'+field+'" class="field-select"'
      + ' style="width:100%;height:32px;font-size:12px;border:none;border-radius:0;background:transparent;outline:none"'
      + ' title="'+escHtml(hint||label)+'">'+opts+'</select>';
  } else {
    var extraStyle = (type === 'number') ? 'text-align:right;font-family:var(--ff-mono);' : '';
    inputHtml = '<input type="text" name="cat_'+field+'"'
      + ' placeholder="'+escHtml(placeholder)+'"'
      + ' title="'+escHtml(hint||label)+'"'
      + ' style="width:100%;border:none;outline:none;font-family:var(--ff-body);font-size:12px;background:transparent;padding:0;'+extraStyle+'"'
      + ' oninput="salCheckCatenaStatus('+n+')">';
  }
  return '<div style="padding:8px 12px;border-right:1px solid var(--bd-sec-light)">'
    + '<div style="font-size:10px;font-weight:700;color:var(--tx-lighter);text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px">'+escHtml(label)+'</div>'
    + inputHtml
    + '</div>';
}

/* Aggiorna badge contatore catene nello step 2 */
function salUpdateCateneCount() {
  var n = document.querySelectorAll('#sal-catene-container [id^="sal-catena-"]').length;
  var badge = document.getElementById('sal-catene-badge');
  if (badge) badge.textContent = n;
}

/* Aggiorna lo stato (semaforo) della catena n in base ai campi compilati */
function salCheckCatenaStatus(n) {
  var div = document.getElementById('sal-catena-'+n);
  if (!div) return;
  var proc  = ((div.querySelector('[name="cat_proc"]')  || {}).value || '').trim();
  var contr = ((div.querySelector('[name="cat_contr"]') || {}).value || '').trim();
  var fat   = ((div.querySelector('[name="cat_fat"]')   || {}).value || '').trim();
  var pag   = ((div.querySelector('[name="cat_pag"]')   || {}).value || '').trim();
  var statusEl = document.getElementById('sal-cat-status-'+n);
  if (!statusEl) return;
  if (proc && contr && fat && pag) {
    statusEl.className = 'sal-catena-status sem sem--verde';
    statusEl.innerHTML = '<span class="sem__dot"></span>Catena completa';
  } else if (proc && contr && fat) {
    statusEl.className = 'sal-catena-status sem sem--arancio';
    statusEl.innerHTML = '<span class="sem__dot"></span>Pagamento mancante';
  } else {
    var filled = [proc, contr, fat].filter(Boolean).length;
    statusEl.className = 'sal-catena-status sem sem--' + (filled > 0 ? 'arancio' : 'grigio');
    statusEl.innerHTML = '<span class="sem__dot"></span>Incompleta' + (filled > 0 ? ' ('+filled+'/3)' : '');
  }
}

/* Upload documento allegato al SAL (lista documenti obbligatori step 3) */
function salUploadDoc(btn, tipo) {
  _salCurrentBtn      = btn;
  _salCurrentDocTipo  = tipo;
  var inp = document.getElementById('sal-file-input');
  if (inp) { inp.value = ''; inp.click(); }
}

function salFileSelected(input) {
  if (!input || !input.files || !input.files[0]) return;
  var file = input.files[0];
  _salPendingDocs.push({ tipo: _salCurrentDocTipo, file: file, nome: file.name });
  if (_salCurrentBtn) {
    _salCurrentBtn.classList.add('is-uploaded');
    _salCurrentBtn.innerHTML = '&#10003; ' + file.name.substring(0, 18) + (file.name.length > 18 ? '&#8230;' : '');
  }
  input.value = '';
}

/* Upload documento per singolo elemento catena */
// key: "catenaN_field" -> {nome, dataUrl, size}  (dataUrl è base64 per persistenza)
var _salCatenaFiles = {};
var _salCatenaCurrentTarget = null;

function salCatenaUpload(catenaNum, field, btn) {
  _salCatenaCurrentTarget = {n: catenaNum, field: field, btn: btn};
  var inp = document.getElementById('sal-catena-file-input');
  if (!inp) {
    inp = document.createElement('input');
    inp.type = 'file'; inp.id = 'sal-catena-file-input';
    inp.accept = '.pdf,.doc,.docx,.jpg,.jpeg,.png,.zip,.xlsx';
    inp.style.display = 'none';
    document.body.appendChild(inp);
  }
  inp.onchange = salCatenaFileSelected;
  inp.value = '';
  inp.click();
}

function salCatenaFileSelected() {
  var inp = document.getElementById('sal-catena-file-input');
  if (!inp || !inp.files || !inp.files[0] || !_salCatenaCurrentTarget) return;
  var file = inp.files[0];
  var target = _salCatenaCurrentTarget;
  var key = target.n + '_' + target.field;

  // Leggi come base64 DataURL per poterlo salvare in localStorage e visualizzare
  var reader = new FileReader();
  reader.onload = function(e) {
    var dataUrl = e.target.result;
    var sizeKb  = (file.size / 1024).toFixed(0);

    _salCatenaFiles[key] = {
      nome:    file.name,
      dataUrl: dataUrl,     // base64 — usato come src per visualizzazione
      size:    sizeKb + ' KB',
      type:    file.type
    };

    // Aggiorna UI pulsante
    var btn = target.btn;
    if (btn) {
      btn.style.background   = 'var(--bg-success-lighter)';
      btn.style.color        = 'var(--tx-success)';
      btn.style.borderColor  = 'var(--bd-success)';
      btn.innerHTML = '&#10003; Doc';
    }
    // Aggiorna nome file
    var nameEl = document.getElementById('cat-docname-' + target.n + '-' + target.field);
    if (nameEl) {
      nameEl.textContent = file.name.substring(0, 22) + (file.name.length > 22 ? '…' : '');
    }
  };
  reader.readAsDataURL(file);
  _salCatenaCurrentTarget = null;
  inp.value = '';
}


/* ── Raccoglie catene dal form ── */
function _collectSALCatene() {
  var catene = [];
  document.querySelectorAll('#sal-catene-container [id^="sal-catena-"]').forEach(function(div){
    var idMatch = div.id.match(/sal-catena-(\d+)/);
    var n = idMatch ? idMatch[1] : null;
    var docs = {};
    if (n) {
      ['proc','contr','inc','fat','pag'].forEach(function(field){
        var key = n+'_'+field;
        if (_salCatenaFiles[key]) {
          var fd = _salCatenaFiles[key];
          docs[field] = {nome: fd.nome, dataUrl: fd.dataUrl, size: fd.size, type: fd.type};
        }
      });
    }
    catene.push({
      proc:              ((div.querySelector('[name="cat_proc"]')||{}).value||'').trim(),
      contr:             ((div.querySelector('[name="cat_contr"]')||{}).value||'').trim(),
      inc:               ((div.querySelector('[name="cat_inc"]')||{}).value||'').trim(),
      fat:               ((div.querySelector('[name="cat_fat"]')||{}).value||'').trim(),
      pag:               ((div.querySelector('[name="cat_pag"]')||{}).value||'').trim(),
      forn:              ((div.querySelector('[name="cat_forn"]')||{}).value||'').trim(),
      imp_inerente:      ((div.querySelector('[name="cat_imp_inerente"]')||{}).value||'0').replace(/\./g,'').replace(',','.'),
      imp_rendicontabile:((div.querySelector('[name="cat_imp_rendicontabile"]')||{}).value||'0').replace(/\./g,'').replace(',','.'),
      tipologia:         ((div.querySelector('[name="cat_tipologia"]')||{}).value||'Lavori'),
      stato_checklist:   'da lavorare',
      docs: docs   // {proc:{nome,url}, contr:{...}, inc:{...}, fat:{...}, pag:{...}}
    });
  });
  return catene;
}

/* ── Build riepilogo step 4 ── */
function _buildSALRiepilogo() {
  var tipo    = document.getElementById('sal-tipo').value;
  var progr   = document.getElementById('sal-progr').value;
  var data    = document.getElementById('sal-data').value;
  var importo = document.getElementById('sal-importo').value;
  var dl      = document.getElementById('sal-dl').value;
  var impresa = document.getElementById('sal-impresa').value;

  // Anagrafica
  var anagEl = document.getElementById('sal-riepilogo-anag');
  if (anagEl) {
    var tipoClass = tipo==='Saldo finale'?'tag--saldo':tipo==='Anticipazione'?'tag--ant':'tag--sal';
    anagEl.innerHTML = [
      ['Tipo','<span class="tag '+tipoClass+'">'+escHtml(tipo)+'</span>'],
      ['Progressivo','<span style="font-family:var(--ff-mono)">'+escHtml(progr)+'</span>'],
      ['Data','<span style="font-family:var(--ff-mono)">'+(data?new Date(data).toLocaleDateString('it-IT'):'—')+'</span>'],
      ['Importo','<span style="font-family:var(--ff-mono);font-weight:700;color:var(--tx-secondary)">&#8364; '+_fmt(parseFloat((importo||'0').replace(/\./g,'').replace(',','.'))||0)+'</span>'],
      ['DL',escHtml(dl||'—')],
      ['Impresa',escHtml(impresa||'—')]
    ].map(function(r,i){
      return '<div class="field-row"'+(i===5?' style="border-bottom:none"':'')+'><span class="field-row__label">'+r[0]+'</span><span class="field-row__value">'+r[1]+'</span></div>';
    }).join('');
  }

  // Documenti
  var docsEl = document.getElementById('sal-riepilogo-docs');
  if (docsEl) {
    var allDocLabels = ['SAL firmato DL','Cert. pagamento DL','Dichiarazione SAL ICSC','Fatture lavori','Bonifici','DURC','Parcella tecnica','CRE Collaudo','Parere CONI'];
    var uploadedTypes = _salPendingDocs.map(function(d){return d.tipo;});
    docsEl.innerHTML = allDocLabels.map(function(l){
      var ok = uploadedTypes.indexOf(l) > -1;
      var semClass = ok ? 'sem--verde' : l==='Parcella tecnica'||l==='CRE Collaudo'||l==='Parere CONI' ? 'sem--grigio' : 'sem--rosso';
      var semLabel = ok ? 'OK' : l==='Parcella tecnica'||l==='CRE Collaudo'||l==='Parere CONI' ? 'N/A' : 'Mancante';
      return '<div><span class="sem '+semClass+'" style="font-size:10px;padding:2px 7px;margin-right:6px"><span class="sem__dot"></span>'+semLabel+'</span>'+escHtml(l)+'</div>';
    }).join('');
  }

  // Catene
  var catene = _collectSALCatene();
  var badge = document.getElementById('sal-riepilogo-catene-badge');
  if (badge) badge.textContent = catene.length+' catene';
  var tbody = document.getElementById('sal-riepilogo-catene-tbody');
  if (tbody) {
    if (catene.length===0) {
      tbody.innerHTML = '<tr><td colspan="7" style="padding:14px;text-align:center;color:var(--tx-lighter);font-size:12px">Nessuna catena definita. Torna allo step 2 per aggiungerne.</td></tr>';
    } else {
      tbody.innerHTML = catene.map(function(c){
        var pagCell = c.pag
          ? '<span class="cd-link">'+escHtml(c.pag)+'</span> <span class="cd-ok">&#9679;</span>'
          : '<span style="color:var(--tx-warning);font-size:11px">&#8987; In attesa</span>';
        return '<tr style="border-bottom:1px solid var(--bd-sec-light)">'
          +'<td style="padding:7px 12px">'+escHtml(c.proc||'—')+(c.docs&&c.docs.proc?'<span style="margin-left:3px">&#128196;</span>':'')+'</td>'
          +'<td style="padding:7px 12px">'+escHtml(c.contr||'—')+(c.docs&&c.docs.contr?'<span style="margin-left:3px">&#128196;</span>':'')+'</td>'
          +'<td style="padding:7px 12px">'+escHtml(c.inc||'—')+(c.docs&&c.docs.inc?'<span style="margin-left:3px">&#128196;</span>':'')+'</td>'
          +'<td style="padding:7px 12px">'+escHtml(c.fat||'—')+(c.docs&&c.docs.fat?'<span style="margin-left:3px">&#128196;</span>':'')+'</td>'
          +'<td style="padding:7px 12px">'+pagCell+'</td>'
          +'<td style="padding:7px 12px;text-align:right;font-family:var(--ff-mono)">'+_fmt(parseFloat(c.imp_inerente)||0)+' &#8364;</td>'
          +'<td style="padding:7px 12px;text-align:right;font-family:var(--ff-mono)">'+_fmt(parseFloat(c.imp_rendicontabile)||0)+' &#8364;</td>'
          +'</tr>';
      }).join('');
    }
  }
}

/* ── Salva SAL ── */
async function doSaveSAL(bozza) {
  var tipo    = document.getElementById('sal-tipo').value;
  var progr   = parseInt(document.getElementById('sal-progr').value)||1;
  var data    = document.getElementById('sal-data').value;
  var importo = document.getElementById('sal-importo').value.replace(/\./g,'').replace(',','.');
  var dl      = document.getElementById('sal-dl').value.trim();
  var impresa = document.getElementById('sal-impresa').value.trim();
  var oggetto = document.getElementById('sal-oggetto').value.trim();
  var note    = document.getElementById('sal-note').value.trim();
  var errEl   = document.getElementById('sal-error');

  errEl.style.display='none';
  if (!data) {
    salWizStep(1);
    errEl.textContent='&#9888; Inserisci la data di presentazione.';
    errEl.style.display='block';
    return;
  }
  if (!importo||isNaN(parseFloat(importo))) {
    salWizStep(1);
    errEl.textContent='&#9888; Inserisci un importo valido.';
    errEl.style.display='block';
    return;
  }

  var catene = _collectSALCatene();
  var btn = document.getElementById('sal-submit-btn');
  if (btn) { btn.disabled=true; btn.textContent='Salvataggio&#8230;'; }

  var salData = {
    id: 'sal_'+Date.now(),
    pratica_id: _currentPraticaId,
    tipo: tipo,
    progressivo: progr,
    data: data,
    importo: parseFloat(importo)||0,
    dl: dl,
    impresa: impresa,
    oggetto: oggetto,
    note: note,
    catene: catene,
    stato_controllo: bozza ? 'bozza' : 'da lavorare',
    stato_erogazione: 'In attesa',
    created_at: new Date().toISOString()
  };

  // Salva
  var sals = _store.get('sals_'+_currentPraticaId)||[];
  sals.push(salData);
  _store.set('sals_'+_currentPraticaId, sals);

  if (!bozza) {
    _creaRichiestaFromSAL(salData);
    _aggiornaCateneEleggibilita(sals);
    // Salva documenti SAL nel fascicolo
    var docs = _store.get('docs_'+_currentPraticaId)||[];
    _salPendingDocs.forEach(function(d){
      docs.unshift({id:'doc_'+Date.now()+'_'+Math.random(), pratica_id:_currentPraticaId,
        tipo:d.tipo, nome:d.nome, file_name:d.nome, categoria:'SAL',
        sal_ref:'SAL '+progr, dimensione:'&#8212;', created_at:new Date().toISOString()});
    });
    _store.set('docs_'+_currentPraticaId, docs);
  }

  if (btn) { btn.disabled=false; btn.innerHTML='&#10003; Conferma e inserisci SAL'; }
  _salCatenaFiles = {};
  closeModal('modal-nuovo-sal');
  await goPraticaById(_currentPraticaId);
}

function updateSALStato(salId, campo, valore) {
  var sals = _store.get('sals_'+(_currentPraticaId||''))||[];
  var idx = sals.findIndex(function(s){return s.id===salId;});
  if (idx > -1) {
    sals[idx][campo] = valore;
    _store.set('sals_'+(_currentPraticaId||''), sals);
    var richieste = _store.get('richieste_'+(_currentPraticaId||''))||[];
    var ridx = richieste.findIndex(function(r){return r.sal_id===salId;});
    if (ridx > -1) {
      if (campo==='stato_controllo')  richieste[ridx].stato_controllo  = valore;
      if (campo==='stato_erogazione') richieste[ridx].stato_erogazione = valore;
      _store.set('richieste_'+(_currentPraticaId||''), richieste);
    }
    if (campo==='stato_erogazione' && valore==='Erogato') {
      var tot = sals.filter(function(s){return s.stato_erogazione==='Erogato';})
                    .reduce(function(sum,s){return sum+parseFloat(s.importo||0);},0);
      _db.updatePratica(_currentPraticaId, {erogato: tot});
    }
    _renderSALList(sals);
  }
}

function _creaRichiestaFromSAL(sal) {
  var richieste = _store.get('richieste_'+(_currentPraticaId||''))||[];
  if (richieste.find(function(r){return r.sal_id===sal.id;})) return;
  richieste.push({
    id: 'req_'+Date.now(), sal_id: sal.id,
    sal_progressivo: sal.progressivo, tipo: sal.tipo,
    data: sal.data, importo: sal.importo,
    stato_controllo: 'da lavorare', stato_erogazione: 'In attesa',
    note: sal.note||''
  });
  _store.set('richieste_'+(_currentPraticaId||''), richieste);
}


/* ── Aggiorna catene per il tab Controllo ── */
function _aggiornaCateneEleggibilita(sals) {
  // Legge le catene già salvate per preservare checklist e ownership
  var existing = _store.get('catene_'+_currentPraticaId) || [];
  var existingMap = {};
  existing.forEach(function(c) {
    existingMap[c.sal_id + '_' + c.catena_n] = c;
  });

  var tuttiCatene = [];
  sals.forEach(function(s) {
    (s.catene||[]).forEach(function(c, i) {
      var mapKey = s.id + '_' + (i+1);
      var prev   = existingMap[mapKey] || {};
      tuttiCatene.push({
        sal_tipo: s.tipo,
        sal_progr: s.progressivo,
        sal_id: s.id,
        catena_n: i+1,
        // campi testo
        proc:  c.proc  || '',
        contr: c.contr || '',
        inc:   c.inc   || '',
        fat:   c.fat   || '',
        pag:   c.pag   || '',
        forn:  c.forn  || '',
        tipologia: c.tipologia || '',
        imp_inerente:       parseFloat(c.imp_inerente)       || 0,
        imp_rendicontabile: parseFloat(c.imp_rendicontabile) || 0,
        // documenti allegati (base64 dataUrl)
        docs: c.docs || {},
        // stato checklist e ownership: preserva valori esistenti
        stato_checklist: prev.stato_checklist || c.stato_checklist || 'da lavorare',
        checklist:       prev.checklist       || c.checklist       || {},
        ownership:       prev.ownership       || c.ownership       || ''
      });
    });
  });
  _store.set('catene_'+_currentPraticaId, tuttiCatene);
}

/* ── Render tabella Controllo Eleggibilità ── */

function _salStatusIcon(val) {
  if (!val) return '<span style="color:var(--tx-disable);font-size:13px">&#9675;</span>';
  return '<span class="cd-ok">&#9679;</span>';
}
function _salStatusIconPag(val) {
  if (!val) return '<span style="color:var(--tx-warning);font-size:11px">&#8987; In attesa</span>';
  return '<span class="cd-ok">&#9679;</span>';
}

function _renderCatenaRow(c, i) {
  var tipoClass = c.sal_tipo==='Saldo finale' ? 'tag--saldo'
                : c.sal_tipo==='Anticipazione' ? 'tag--ant' : 'tag--sal';

  var statoMap = {
    'da lavorare':    {icon:'<span style="color:var(--tx-disable);font-size:16px">&#9675;</span>',  cls:'color:var(--tx-lighter)',  label:'da lavorare'},
    'in lavorazione': {icon:'<span style="color:var(--tx-warning);font-size:16px">&#9646;</span>', cls:'color:var(--tx-warning)',  label:'in lavorazione'},
    'conforme':       {icon:'<span style="color:var(--tx-success);font-size:16px">&#9679;</span>', cls:'color:var(--tx-success)',  label:'conforme'},
    'non conforme':   {icon:'<span style="color:var(--tx-error);font-size:16px">&#10005;</span>',  cls:'color:var(--tx-error)',    label:'non conforme'}
  };
  var st = statoMap[c.stato_checklist] || statoMap['da lavorare'];
  var isAssigned = !!c.ownership;
  var flagClass = isAssigned ? 'flag-r flag-r--active' : 'flag-r';
  var searchData = [c.proc, c.contr, c.fat, c.forn].join(' ').toLowerCase();
  var docs = c.docs || {};

  /* Helper: render a document cell — clickable if has value */
  function docCell(field, val) {
    var docObj  = docs[field];
    var hasDoc  = docObj && docObj.nome;
    // pallino: verde se valore + doc, arancio se solo valore, grigio se vuoto
    var semIcon = !val
      ? '<span style="color:var(--tx-disable);font-size:13px">&#9675;</span>'
      : (hasDoc
          ? '<span style="color:var(--tx-success);font-size:13px">&#9679;</span>'
          : '<span style="color:var(--tx-warning);font-size:13px">&#9679;</span>');
    var docIcon = hasDoc
      ? '<span style="font-size:10px;margin-left:2px" title="'+escHtml(docObj.nome)+'">&#128196;</span>'
      : '';
    if (!val) {
      return '<td><div class="cd-cell"><span style="color:var(--tx-lighter);font-size:11px">&#8212;</span></div></td>';
    }
    return '<td style="cursor:pointer" onclick="event.stopPropagation();openElementoDetail('+i+',\''+field+'\')" title="'+(hasDoc?'Documento allegato — ':'')+escHtml(val)+'">'
      + '<div class="cd-cell">'
      + '<span class="cd-link">'+escHtml(val)+'</span>'
      + semIcon
      + docIcon
      + '</div></td>';
  }

  var cells = [
    '<td><div class="'+flagClass+'" style="width:18px;height:18px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0">R</div></td>',
    '<td><span class="tag '+tipoClass+'" style="font-size:10px;white-space:nowrap">'+escHtml(c.sal_tipo||'SAL')+' #'+c.sal_progr+'</span></td>',
    docCell('proc',  c.proc),
    docCell('contr', c.contr),
    docCell('inc',   c.inc),
    docCell('fat',   c.fat),
    docCell('pag',   c.pag),
    '<td style="text-align:center">'+(isAssigned
      ? '<div style="font-size:11px;font-weight:600;color:var(--tx-secondary)">'+escHtml(c.ownership)+'</div>'
      : '<button class="btn-assegna" onclick="event.stopPropagation();assignCatena('+i+')">ASSEGNA</button>')+'</td>',
    '<td style="text-align:right;font-family:var(--ff-mono);font-size:12px">'+_fmt(c.imp_inerente||0)+' &#8364;</td>',
    '<td style="text-align:right;font-family:var(--ff-mono);font-size:12px;'+st.cls+'">'+_fmt(c.imp_rendicontabile||0)+' &#8364;</td>',
    '<td style="border-left:2px solid var(--bd-sec-light);background:var(--bg-sec-lighter);min-width:150px">'
      + '<div style="display:flex;align-items:center;gap:6px;padding:0 4px">'
      + st.icon
      + '<div><div style="font-size:12px;font-weight:600;'+st.cls+'">'+st.label+'</div>'
      + '<div style="font-size:10px;color:var(--tx-lighter)">singolo controllo</div></div></div></td>'
  ];

  return '<tr style="cursor:pointer" onclick="openCatenaDetail('+i+')" data-search="'+escHtml(searchData)+'">'
    + cells.join('') + '</tr>';
}
function filtCatene(q) {
  var tbody = document.getElementById('ctrl-tbody');
  if (!tbody) return;
  tbody.querySelectorAll('tr').forEach(function(tr){
    var search = tr.dataset.search||'';
    tr.style.display = !q || search.includes(q.toLowerCase()) ? '' : 'none';
  });
}

function assignCatena(i) {
  var nome = (SESSION.user && SESSION.user.nome) ? SESSION.user.nome.toUpperCase() : 'OPERATORE';
  var catene = _store.get('catene_'+_currentPraticaId)||[];
  if (catene[i]) {
    catene[i].ownership = nome;
    _store.set('catene_'+_currentPraticaId, catene);
    _renderCatene(catene);
  }
}

/* ── Apre dettaglio catena con checklist ── */

var _currentCatenaIdx = -1;

function catenaClSet(catenaIdx, itemId, val, btn) {
  var catene = _store.get('catene_'+_currentPraticaId)||[];
  if (!catene[catenaIdx]) return;
  if (!catene[catenaIdx].checklist) catene[catenaIdx].checklist = {};
  catene[catenaIdx].checklist[itemId] = val;
  _store.set('catene_'+_currentPraticaId, catene);
  // Update UI
  var row = document.getElementById('catdet-'+catenaIdx+'-'+itemId);
  if (row) {
    row.querySelectorAll('.cl-btn').forEach(function(b){ b.classList.remove('is-on'); });
    btn.classList.add('is-on');
  }
  // Auto-update stato catena
  _autoUpdateCatenaStato(catenaIdx, catene);
}

function _autoUpdateCatenaStato(idx, catene) {
  var c = catene[idx];
  if (!c.checklist) return;
  var vals = Object.values(c.checklist);
  if (vals.length === 0) return;
  var hasNo = vals.includes('no');
  var hasDv = vals.includes('dv');
  var allSiOrNa = vals.every(function(v){ return v==='si'||v==='na'; });
  if (hasNo) catene[idx].stato_checklist = 'non conforme';
  else if (hasDv) catene[idx].stato_checklist = 'in lavorazione';
  else if (allSiOrNa && vals.length >= 4) catene[idx].stato_checklist = 'conforme';
  else catene[idx].stato_checklist = 'in lavorazione';
  _store.set('catene_'+_currentPraticaId, catene);
}

/* ── Apre dettaglio singolo elemento catena (Procedura/Contratto/ecc.) ── */
function openElementoDetail(catenaIdx, field) {
  var catene = _store.get('catene_'+(_currentPraticaId||''))||[];
  var c = catene[catenaIdx];
  if (!c) return;

  var mid = field; // 'proc','contr','inc','fat','pag'
  var docs = c.docs || {};
  var doc  = docs[field];
  var cl   = (c.elem_checklist && c.elem_checklist[field]) || {};

  /* ── Configurazione per entità ── */
  var cfg = {
    proc: {
      label: 'Procedura',
      rows: [
        ['Codice procedura',      c.proc   || '—'],
        ['Tipologia spesa',       c.tipologia || '—'],
        ['Fornitore',             c.forn   || '—'],
        ['Contratto aperto rif.', c.contr  || '—']
      ],
      checklist: [
        {id:'tipo_ok',    label:'Tipologia di affidamento corretta (diretto/gara/cottimo)'},
        {id:'soglia_ok',  label:'Soglia CIG/ANAC rispettata'},
        {id:'cig_ok',     label:'CIG presente e coerente'},
        {id:'pubbl_ok',   label:'Adeguata pubblicità / comunicazione'},
        {id:'resp_ok',    label:'RUP/responsabile del procedimento nominato'},
        {id:'doc_ok',     label:'Documentazione di gara/affidamento allegata'}
      ]
    },
    contr: {
      label: 'Contratto aperto',
      rows: [
        ['Riferimento contratto',  c.contr  || '—'],
        ['Fornitore/Contraente',   c.forn   || '—'],
        ['Rif. procedura',         c.proc   || '—'],
        ['Importo inerente',       '€ '+_fmt(c.imp_inerente||0)],
        ['Importo rendicontabile', '€ '+_fmt(c.imp_rendicontabile||0)]
      ],
      checklist: [
        {id:'stipulato_ok', label:'Contratto regolarmente stipulato e firmato'},
        {id:'validita_ok',  label:'Contratto in corso di validità alla data SAL'},
        {id:'oggetto_ok',   label:'Oggetto del contratto coerente con il finanziamento'},
        {id:'importo_ok',   label:'Importo del contratto congruente con QTE'},
        {id:'cig_contr',    label:'CIG associato al contratto presente'},
        {id:'esec_ok',      label:'Esecutore regolarmente identificato'}
      ]
    },
    inc: {
      label: 'Incarico / Attingimento',
      rows: [
        ['Rif. incarico',          c.inc    || '—'],
        ['Rif. contratto aperto',  c.contr  || '—'],
        ['Fornitore',              c.forn   || '—'],
        ['Tipologia',              c.tipologia || '—']
      ],
      checklist: [
        {id:'rif_contr_ok',  label:'Incarico riferito a contratto aperto valido'},
        {id:'prest_ok',      label:'Prestazione/attingimento coerente con oggetto SAL'},
        {id:'parcella_ok',   label:'Importo parcella/attingimento congruente'},
        {id:'durc_ok',       label:'DURC in corso di validità'},
        {id:'firme_ok',      label:'Atto di incarico regolarmente firmato'},
        {id:'qte_inc_ok',    label:'Spesa tecnica rientra nel QTE approvato'}
      ]
    },
    fat: {
      label: 'Fattura',
      rows: [
        ['N. Fattura',             c.fat    || '—'],
        ['Fornitore',              c.forn   || '—'],
        ['Importo inerente',       '€ '+_fmt(c.imp_inerente||0)],
        ['Importo rendicontabile', '€ '+_fmt(c.imp_rendicontabile||0)],
        ['Rif. contratto',         c.contr  || '—'],
        ['Pagamento rif.',         c.pag    || '—']
      ],
      checklist: [
        {id:'non_proforma',   label:'Fattura non proforma, fiscalmente valida'},
        {id:'non_dup',        label:'Fattura non già rendicontata in SAL precedenti'},
        {id:'inerente',       label:'Spesa inerente all\'oggetto del finanziamento'},
        {id:'imponibile_ok',  label:'Imponibile e IVA correttamente indicati'},
        {id:'data_ok',        label:'Data fattura entro il periodo di eleggibilità'},
        {id:'importo_qte',    label:'Importo coerente con il QTE approvato'},
        {id:'fornitore_ok',   label:'Fornitore coincide con il contraente del contratto'}
      ]
    },
    pag: {
      label: 'Pagamento / Bonifico',
      rows: [
        ['Rif. pagamento',         c.pag    || '—'],
        ['Fattura di riferimento', c.fat    || '—'],
        ['Fornitore',              c.forn   || '—'],
        ['Importo pagamento',      '€ '+_fmt(c.imp_inerente||0)]
      ],
      checklist: [
        {id:'importo_corr',  label:'Importo del bonifico corrisponde alla fattura'},
        {id:'causale_ok',    label:'Causale del bonifico corretta e tracciabile'},
        {id:'iban_ok',       label:'IBAN beneficiario verificato e tracciabile'},
        {id:'data_suc',      label:'Data pagamento successiva alla data fattura'},
        {id:'no_contanti',   label:'Pagamento effettuato tramite strumenti tracciabili (no contanti)'},
        {id:'estratto_ok',   label:'Estratto conto / ricevuta bonifico allegata'}
      ]
    }
  };

  var entity = cfg[field];
  if (!entity) return;

  /* Aggiorna header modal */
  var titleEl = document.getElementById('elem-'+mid+'-title');
  var subEl   = document.getElementById('elem-'+mid+'-sub');
  if (titleEl) titleEl.textContent = entity.label + (c[field] ? ': ' + c[field] : '');
  if (subEl)   subEl.textContent   = 'Catena #' + c.catena_n + ' — ' + escHtml(c.sal_tipo||'SAL') + ' #' + c.sal_progr
    + (c.forn ? ' · ' + escHtml(c.forn) : '');

  /* Costruisce body */
  var infoHtml = entity.rows.map(function(r, i2) {
    var isLast = i2 === entity.rows.length - 1;
    return '<div class="field-row"' + (isLast ? ' style="border-bottom:none"' : '') + '>'
      + '<span class="field-row__label">' + escHtml(r[0]) + '</span>'
      + '<span class="field-row__value" style="font-family:var(--ff-mono);font-size:12px;font-weight:600">'
      + escHtml(String(r[1])) + '</span></div>';
  }).join('');

  /* Documento allegato */
  var docHtml;
  if (doc && doc.nome) {
    var viewBtn = doc.dataUrl
      ? '<a href="' + doc.dataUrl + '" target="_blank" class="btn btn--primary btn--xs">&#128065; Visualizza</a>'
        + '<a href="' + doc.dataUrl + '" download="' + escHtml(doc.nome) + '" class="btn btn--ghost btn--xs">&#11015; Scarica</a>'
      : '<span style="font-size:11px;color:var(--tx-lighter)">Nessuna anteprima</span>';
    docHtml = '<div style="margin-top:16px;padding:12px 14px;background:var(--bg-primary-light);border:1px solid var(--bd-prim-light);border-radius:var(--r-smooth)">'
      + '<div style="font-size:10px;font-weight:700;color:var(--tx-lighter);text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px">Documento allegato</div>'
      + '<div style="display:flex;align-items:center;gap:10px">'
      + '<span style="font-size:22px;flex-shrink:0">&#128196;</span>'
      + '<div style="flex:1;min-width:0">'
      + '<div style="font-size:13px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + escHtml(doc.nome) + '</div>'
      + '<div style="font-size:11px;color:var(--tx-lighter);margin-top:1px">' + (doc.size||'—') + '</div>'
      + '</div>'
      + '<div style="display:flex;gap:6px;flex-shrink:0">' + viewBtn + '</div>'
      + '</div></div>';
  } else {
    docHtml = '<div style="margin-top:16px;padding:10px 14px;background:var(--bg-sec-lighter);border:1px solid var(--bd-sec-light);border-radius:var(--r-smooth);font-size:12px;color:var(--tx-lighter)">'
      + '&#128203; Nessun documento allegato — carica il documento nella sezione "Inserisci SAL" per questa entità.'
      + '</div>';
  }

  /* Checklist specifica */
  var clHtml = '<div style="margin-top:16px">'
    + '<div class="section-label" style="margin-bottom:8px">Checklist di controllo</div>'
    + '<div style="border:1px solid var(--bd-sec-light);border-radius:var(--r-smooth);overflow:hidden">'
    + entity.checklist.map(function(item, idx) {
        var val = cl[item.id] || '';
        var isLast = idx === entity.checklist.length - 1;
        function mkBtn(v, lbl, cls) {
          return '<button class="cl-btn cl-btn--' + cls + (val===v ? ' is-on' : '')
            + '" onclick="setElemCheckItem(' + catenaIdx + ',\'' + field + '\',\'' + item.id + '\',\'' + v + '\',this)">' + lbl + '</button>';
        }
        return '<div class="cl-item"' + (isLast ? ' style="border-bottom:none"' : '') + '>'
          + '<div class="cl-item__text"><div class="cl-item__label">' + escHtml(item.label) + '</div></div>'
          + '<div class="cl-item__btns">'
          + mkBtn('si','SI','si') + mkBtn('no','NO','no') + mkBtn('dv','DA VAL.','dv') + mkBtn('na','N/A','na')
          + '</div></div>';
      }).join('')
    + '</div></div>';

  /* Stato controllo elemento */
  var statoVals = Object.values(cl);
  var elemStato = statoVals.length === 0 ? 'Da verificare'
    : statoVals.includes('no') ? 'Non conforme'
    : statoVals.includes('dv') ? 'In verifica'
    : statoVals.every(function(v){ return v==='si'||v==='na'; }) ? 'Conforme'
    : 'In verifica';
  var statoColor = elemStato==='Conforme' ? 'var(--tx-success)'
    : elemStato==='Non conforme' ? 'var(--tx-error)'
    : elemStato==='In verifica'  ? 'var(--tx-warning)'
    : 'var(--tx-lighter)';
  var statoBadge = '<div style="display:flex;align-items:center;gap:8px;margin-bottom:14px;padding:8px 12px;background:var(--bg-sec-lighter);border-radius:var(--r-smooth)">'
    + '<span style="font-size:11px;color:var(--tx-lighter)">Stato elemento:</span>'
    + '<span style="font-size:12px;font-weight:700;color:'+statoColor+'">'+elemStato+'</span>'
    + '</div>';

  var bodyEl = document.getElementById('elem-'+mid+'-body');
  if (bodyEl) bodyEl.innerHTML = statoBadge
    + '<div style="border:1px solid var(--bd-sec-light);border-radius:var(--r-smooth);overflow:hidden;margin-bottom:0">' + infoHtml + '</div>'
    + docHtml
    + clHtml;

  /* Salva indice per saveElemChecklist */
  _elemDetailCatenaIdx = catenaIdx;
  _elemDetailField     = field;

  openModal('modal-elem-' + mid);
}

/* Indici correnti per save */
var _elemDetailCatenaIdx = -1;
var _elemDetailField     = '';

/* Imposta un item della checklist elemento */
function setElemCheckItem(catenaIdx, field, itemId, val, btn) {
  var catene = _store.get('catene_'+(_currentPraticaId||''))||[];
  if (!catene[catenaIdx]) return;
  if (!catene[catenaIdx].elem_checklist)        catene[catenaIdx].elem_checklist = {};
  if (!catene[catenaIdx].elem_checklist[field]) catene[catenaIdx].elem_checklist[field] = {};
  catene[catenaIdx].elem_checklist[field][itemId] = val;
  _store.set('catene_'+(_currentPraticaId||''), catene);
  /* aggiorna bottoni */
  var row = btn.closest('.cl-item__btns');
  if (row) row.querySelectorAll('.cl-btn').forEach(function(b){ b.classList.remove('is-on'); });
  btn.classList.add('is-on');
  /* aggiorna badge stato */
  var cl = catene[catenaIdx].elem_checklist[field];
  var vals = Object.values(cl);
  var stato = vals.includes('no') ? 'Non conforme'
    : vals.includes('dv') ? 'In verifica'
    : vals.every(function(v){ return v==='si'||v==='na'; }) ? 'Conforme'
    : 'In verifica';
  var color = stato==='Conforme' ? 'var(--tx-success)'
    : stato==='Non conforme' ? 'var(--tx-error)' : 'var(--tx-warning)';
  var badgeEl = document.querySelector('#elem-'+field+'-body [style*="Stato elemento"]');
  if (badgeEl) {
    var span = badgeEl.querySelector('span:last-child');
    if (span) { span.textContent = stato; span.style.color = color; }
  }
}

/* Salva e chiude il modal elemento */
function saveElemChecklist(mid) {
  closeModal('modal-elem-'+mid);
  /* Aggiorna la tabella Controllo se visibile */
  var catene = _store.get('catene_'+(_currentPraticaId||''))||[];
  if (catene.length) _renderCatene(catene);
}


function saveCatenaChecklist() {
  var catene = _store.get('catene_'+_currentPraticaId)||[];
  _autoUpdateCatenaStato(_currentCatenaIdx, catene);
  closeModal('modal-catena-detail');
  _renderCatene(catene);
}


function openNoFromSal() { closeModal('modal-sal-detail'); }

/* openSALDetail — apre il modal dettaglio di un SAL specifico */
function openSALDetail(salId) {
  var sals = _store.get('sals_'+(_currentPraticaId||''))||[];
  var sal = sals.find(function(s){return s.id===salId;});
  if (!sal) return;

  var tipoClass = sal.tipo==='Saldo finale'?'tag--saldo':sal.tipo==='Anticipazione'?'tag--ant':'tag--sal';
  var detailTitle = document.getElementById('sal-detail-title');
  var detailSub   = document.getElementById('sal-detail-sub');
  var detailBody  = document.getElementById('sal-detail-body');
  if (detailTitle) detailTitle.textContent = 'SAL '+sal.progressivo+' — '+sal.tipo;
  if (detailSub)   detailSub.textContent   = '€ '+_fmt(sal.importo)+' · '+new Date(sal.data).toLocaleDateString('it-IT');
  if (detailBody) {
    detailBody.innerHTML =
      '<div class="g2" style="gap:14px;margin-bottom:16px">'
      +'<div class="card" style="margin:0"><div class="card__header" style="padding:10px 16px"><span class="card__title" style="font-size:13px">Dati SAL</span></div><div class="card__body" style="padding:14px">'
      +[['Tipo','<span class="tag '+tipoClass+'">'+escHtml(sal.tipo)+'</span>'],
        ['Progressivo','<strong style="font-family:var(--ff-mono)">'+(sal.progressivo||'—')+'</strong>'],
        ['Data',new Date(sal.data).toLocaleDateString('it-IT')],
        ['Importo','<strong style="font-family:var(--ff-mono);color:var(--tx-secondary)">€ '+_fmt(sal.importo)+'</strong>'],
        ['DL',escHtml(sal.dl||'—')],
        ['Impresa',escHtml(sal.impresa||'—')]
       ].map(function(r,i2){
         return '<div class="field-row"'+(i2===5?' style="border-bottom:none"':'')+'><span class="field-row__label">'+r[0]+'</span><span class="field-row__value" style="font-size:12px">'+r[1]+'</span></div>';
       }).join('')
      +'<div class="field-row" style="border-bottom:none;align-items:flex-start"><span class="field-row__label">Oggetto</span><span class="field-row__value" style="font-size:12px">'+escHtml(sal.oggetto||'—')+'</span></div>'
      +'</div></div>'
      +'<div class="card" style="margin:0"><div class="card__header" style="padding:10px 16px"><span class="card__title" style="font-size:13px">Aggiorna stato</span></div><div class="card__body" style="padding:14px">'
      +'<div class="field" style="margin-bottom:12px"><label class="field__label" style="font-size:11px">Stato controllo</label>'
      +'<select class="field-select" style="width:100%" id="sal-det-ctrl" onchange="updateSALStato(\''+sal.id+'\',\'stato_controllo\',this.value)">'
      +['da lavorare','In verifica','Conforme','Non conforme','In firma N.O.'].map(function(s){return '<option'+(s===sal.stato_controllo?' selected':'')+'>'+s+'</option>';}).join('')
      +'</select></div>'
      +'<div class="field"><label class="field__label" style="font-size:11px">Stato erogazione</label>'
      +'<select class="field-select" style="width:100%" id="sal-det-erog" onchange="updateSALStato(\''+sal.id+'\',\'stato_erogazione\',this.value)">'
      +['In attesa','Erogato','Sospeso'].map(function(s){return '<option'+(s===sal.stato_erogazione?' selected':'')+'>'+s+'</option>';}).join('')
      +'</select></div>'
      +'</div></div>'
      +'</div>'
      +((sal.catene&&sal.catene.length>0)
        ? '<div class="section-label" style="margin-bottom:10px">Catene documentali ('+sal.catene.length+')</div>'
          +'<div style="overflow-x:auto"><table class="ctrl-table"><thead><tr>'
          +'<th>#</th><th>Procedura</th><th>Contratto</th><th>Incarico</th><th>Fattura</th><th>Pagamento</th><th style="text-align:right">Imp. inerente</th><th style="text-align:right">Imp. rendicont.</th>'
          +'</tr></thead><tbody>'
          +sal.catene.map(function(c,ci){
            return '<tr><td class="mono">'+(ci+1)+'</td>'
              +'<td>'+escHtml(c.proc||'—')+'</td>'
              +'<td>'+escHtml(c.contr||'—')+'</td>'
              +'<td>'+escHtml(c.inc||'—')+'</td>'
              +'<td>'+escHtml(c.fat||'—')+'</td>'
              +'<td>'+(c.pag?escHtml(c.pag):'<span style="color:var(--tx-warning);font-size:11px">⏳ In attesa</span>')+'</td>'
              +'<td style="text-align:right;font-family:var(--ff-mono)">€ '+_fmt(c.imp_inerente||0)+'</td>'
              +'<td style="text-align:right;font-family:var(--ff-mono)">€ '+_fmt(c.imp_rendicontabile||0)+'</td>'
              +'</tr>';
          }).join('')
          +'</tbody></table></div>'
        : '<div class="notice notice--info" style="font-size:12px">Nessuna catena documentale associata a questo SAL.</div>');
  }
  openModal('modal-sal-detail');
}

/* ── TAB 4: CONTROLLO ELEGGIBILITÀ ── */
async function _loadTabCatene() {
  var catene = _store.get('catene_'+_currentPraticaId)||[];
  _renderCatene(catene);
}

function _renderCatene(catene) {
  var list = document.getElementById('catene-list');
  if (!list) return;

  if (catene.length === 0) {
    list.innerHTML = '<div class="card"><div class="card__body" style="text-align:center;color:var(--tx-lighter);font-size:13px;padding:32px">'
      +'<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="display:block;margin:0 auto 8px;opacity:.4"><path d="M10 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7l-4-4z"/><polyline points="14 3 14 8 20 8"/></svg>'
      +'Le catene documentali vengono create automaticamente quando si inserisce un SAL. Inserisci prima un SAL nel tab "Gestione svincolo".'
      +'</div></div>';
    return;
  }

  // KPI di sintesi
  var nConformi    = catene.filter(function(c){return c.stato_checklist==='Conforme';}).length;
  var nNonConformi = catene.filter(function(c){return c.stato_checklist==='Non conforme';}).length;
  var nInVerifica  = catene.filter(function(c){return !c.stato_checklist||c.stato_checklist==='In verifica'||c.stato_checklist==='Da verificare';}).length;
  var totInerente  = catene.reduce(function(s,c){return s+(parseFloat(c.imp_inerente)||0);},0);
  var totRendicont = catene.reduce(function(s,c){return s+(parseFloat(c.imp_rendicont)||0);},0);
  var pctCtrl = catene.length>0?Math.round(nConformi/catene.length*100):0;

  list.innerHTML =
    // ── KPI bar ──
    '<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:0;margin-bottom:16px">'
    +'<div class="ctrl-kpi"><div class="ctrl-kpi__title">Avanzamento</div>'
    +'<div class="ctrl-kpi__row"><span class="ctrl-kpi__label">Spesa inerente:</span><span class="ctrl-kpi__val">€ '+_fmt(totInerente)+'</span></div>'
    +'<div class="ctrl-kpi__row"><span class="ctrl-kpi__label">Di cui rendicontabile:</span><span class="ctrl-kpi__val" style="color:var(--tx-success)">€ '+_fmt(totRendicont)+'</span></div>'
    +'</div>'
    +'<div class="ctrl-kpi"><div class="ctrl-kpi__title">Catene</div>'
    +'<div class="ctrl-kpi__row"><span class="ctrl-kpi__label">Totale:</span><span class="ctrl-kpi__val">'+catene.length+'</span></div>'
    +'<div class="ctrl-kpi__row"><span class="ctrl-kpi__label">Conformi:</span><span class="ctrl-kpi__val" style="color:var(--tx-success)">'+nConformi+'</span></div>'
    +'</div>'
    +'<div class="ctrl-kpi"><div class="ctrl-kpi__title">Stato</div>'
    +'<div class="ctrl-kpi__row"><span class="ctrl-kpi__label">In verifica:</span><span class="ctrl-kpi__val" style="color:var(--tx-warning)">'+nInVerifica+'</span></div>'
    +'<div class="ctrl-kpi__row"><span class="ctrl-kpi__label">Non conformi:</span><span class="ctrl-kpi__val" style="color:var(--tx-error)">'+nNonConformi+'</span></div>'
    +'</div>'
    +'<div class="ctrl-kpi" style="border-top-color:var(--bg-sec-light)">'
    +'<div class="ctrl-kpi__title" style="font-size:12px">Catene controllate</div>'
    +'<div style="font-size:22px;font-weight:700;font-family:var(--ff-mono);color:var(--tx-primary);margin-top:4px">'+nConformi+' / '+catene.length+' <span style="font-size:12px;color:var(--tx-lighter);font-family:var(--ff-body);font-weight:400">'+pctCtrl+'%</span></div>'
    +'<div class="kpi__bar" style="margin-top:6px"><div class="kpi__bar-fill progress__fill--primary" style="width:'+pctCtrl+'%"></div></div>'
    +'</div>'
    +'</div>'

    // ── Toolbar ──
    +'<div class="row-sb" style="margin-bottom:12px">'
    +'<div style="font-size:12px;color:var(--tx-light)"><strong>Fai click su una riga</strong> per aprire il dettaglio e compilare la checklist.</div>'
    +'<div class="row gap-8">'
    +'<div class="nav-search" style="max-width:220px;height:30px">'
    +'<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>'
    +'<input type="text" id="ctrl-search" placeholder="Cerca catena…" style="font-size:12px" oninput="filterCatene(this.value)">'
    +'</div>'
    +'</div>'
    +'</div>'

    // ── Tabella ──
    +'<div class="card"><div class="ctrl-table-wrap"><table class="ctrl-table" id="ctrl-catene-table"><thead><tr>'
    +'<th style="width:28px"></th>'
    +'<th style="background:var(--bg-sec-dark);color:#fff;font-size:11px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;white-space:nowrap">Item</th>'
    +'<th>Procedura</th>'
    +'<th>Contratto aperto</th>'
    +'<th>Incarico / Attingimento</th>'
    +'<th>Fattura</th>'
    +'<th>Pagamento</th>'
    +'<th style="text-align:right">Imp. inerente</th>'
    +'<th style="text-align:right">Imp. rendicontabile</th>'
    +'<th class="th-stato" style="background:var(--bg-secondary);color:#fff;text-align:center;border-left:2px solid var(--bd-secondary)">Stato del controllo</th>'
    +'</tr></thead>'
    +'<tbody id="ctrl-catene-tbody">'
    + _buildCateneRows(catene)
    +'</tbody></table></div></div>';
}

function _buildCateneRows(catene) {
  return catene.map(function(c, i) {
    var salTagClass = c.sal_tipo==='Saldo finale'?'tag--saldo':c.sal_tipo==='Anticipazione'?'tag--ant':'tag--sal';
    var salLabel    = c.sal_tipo==='Saldo finale'?'Saldo':'SAL '+c.sal_progr;
    var stato       = c.stato_checklist || 'Da verificare';
    var docs        = c.docs || {};

    /* Semaforo per ogni entità basato sulla checklist elemento */
    function elemSemaphore(field) {
      var cl = (c.elem_checklist && c.elem_checklist[field]) || {};
      var vals = Object.values(cl);
      if (!c[field]) return 'disable';   // campo vuoto
      if (vals.length === 0) return 'pending';                          // non controllato
      if (vals.includes('no'))  return 'error';
      if (vals.includes('dv'))  return 'warn';
      if (vals.every(function(v){ return v==='si'||v==='na'; })) return 'ok';
      return 'warn';
    }

    /* Cella cliccabile per ogni entità */
    function entityCell(field, display) {
      if (!c[field]) return '<td><span style="color:var(--tx-lighter);font-size:11px">—</span></td>';
      var sem = elemSemaphore(field);
      var hasDoc = docs[field] && docs[field].nome;
      var semHtml = {
        ok:      '<span style="color:var(--tx-success);font-size:13px">&#9679;</span>',
        error:   '<span style="color:var(--tx-error);font-size:13px">&#10005;</span>',
        warn:    '<span style="color:var(--tx-warning);font-size:13px">&#9646;</span>',
        pending: '<span style="color:var(--tx-disable);font-size:13px">&#9675;</span>',
        disable: '<span style="color:var(--tx-disable);font-size:13px">&#9675;</span>'
      }[sem] || '';
      var docIcon = hasDoc ? '<span style="font-size:10px;margin-left:2px" title="'+escHtml(docs[field].nome)+'">&#128196;</span>' : '';
      var extraLine = '';
      if (field==='proc' && c.tipologia) extraLine = '<div style="font-size:10px;color:var(--tx-lighter);margin-top:1px">'+escHtml(c.tipologia)+'</div>';
      if (field==='contr' && c.forn)     extraLine = '<div style="font-size:10px;color:var(--tx-lighter);margin-top:1px">'+escHtml(c.forn)+'</div>';
      if (field==='inc'   && c.forn)     extraLine = '<div style="font-size:10px;color:var(--tx-lighter);margin-top:1px">'+escHtml(c.forn)+'</div>';
      return '<td style="cursor:pointer;vertical-align:top" onclick="event.stopPropagation();openElementoDetail('+i+',\''+field+'\')" title="Apri dettaglio '+escHtml(field)+'">'
        + '<div class="cd-cell">'
        + '<span class="cd-link">'+escHtml(display || c[field])+'</span>'
        + semHtml
        + docIcon
        + '</div>'
        + extraLine
        + '</td>';
    }

    /* Pagamento: può essere N/A */
    function pagCell() {
      if (!c.pag) return '<td><span style="color:var(--tx-lighter);font-size:11px">—</span></td>';
      var sem = elemSemaphore('pag');
      var hasDoc = docs['pag'] && docs['pag'].nome;
      var semHtml = {
        ok:      '<span style="color:var(--tx-success);font-size:13px">&#9679;</span>',
        error:   '<span style="color:var(--tx-error);font-size:13px">&#10005;</span>',
        warn:    '<span style="color:var(--tx-warning);font-size:13px">&#9646;</span>',
        pending: '<span style="color:var(--tx-disable);font-size:13px">&#9675;</span>',
        disable: '<span style="color:var(--tx-disable);font-size:13px">&#9675;</span>'
      }[sem] || '';
      var docIcon = hasDoc ? '<span style="font-size:10px;margin-left:2px">&#128196;</span>' : '';
      return '<td style="cursor:pointer;vertical-align:top" onclick="event.stopPropagation();openElementoDetail('+i+',\'pag\')" title="Apri dettaglio pagamento">'
        + '<div class="cd-cell"><span class="cd-link">'+escHtml(c.pag)+'</span>'+semHtml+docIcon+'</div>'
        + '</td>';
    }

    /* Importo rendicontabile */
    var impI = parseFloat(c.imp_inerente||0);
    var impR = parseFloat(c.imp_rendicont||c.imp_rendicontabile||0);
    var impRColor = stato==='Conforme'?'var(--tx-success)':stato==='Non conforme'?'var(--tx-error)':'var(--tx-warning)';

    /* Stato catena */
    var statoConfig = {
      'Conforme':      {icon:'&#9679;', color:'var(--tx-success)',  label:'conforme'},
      'Non conforme':  {icon:'&#10005;',color:'var(--tx-error)',    label:'non conforme'},
      'In verifica':   {icon:'&#9646;', color:'var(--tx-warning)',  label:'in lavorazione'},
      'Da verificare': {icon:'&#9675;', color:'var(--tx-disable)',  label:'da lavorare'}
    };
    var sc = statoConfig[stato] || statoConfig['Da verificare'];

    return '<tr id="ctrl-row-'+i+'" data-catena-idx="'+i+'">'+'<td style="cursor:pointer" onclick="openCatenaDetail('+i+')"><div class="flag-r'+(c.ownership?' flag-r--active':'')+'" style="width:18px;height:18px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700">R</div></td>'+'<td style="cursor:pointer" onclick="openCatenaDetail('+i+')"><span class="tag '+salTagClass+'" style="font-size:10px;white-space:nowrap">'+escHtml(salLabel)+'</span></td>'+ entityCell('proc',  c.proc)+ entityCell('contr', c.contr)+ entityCell('inc',   c.inc || c.forn)+ entityCell('fat',   c.fat)+ pagCell()+'<td style="text-align:right;font-family:var(--ff-mono);font-size:12px;cursor:pointer" onclick="openCatenaDetail('+i+')">'+_fmt(impI)+' &#8364;</td>'+'<td style="text-align:right;font-family:var(--ff-mono);font-size:12px;color:'+impRColor+';cursor:pointer" onclick="openCatenaDetail('+i+')">'+_fmt(impR)+' &#8364;</td>'+'<td class="td-stato" style="border-left:2px solid var(--bd-sec-light);background:var(--bg-sec-lighter);min-width:160px;cursor:pointer" onclick="openCatenaDetail('+i+')">'+'<div style="display:flex;align-items:center;gap:6px;margin-bottom:4px">'+'<span style="color:'+sc.color+';font-size:16px">'+sc.icon+'</span>'+'<div><div style="font-size:12px;font-weight:600;color:'+sc.color+'">'+sc.label+'</div>'+'<div style="font-size:10px;color:var(--tx-lighter)">catena #'+c.catena_n+'</div></div>'+'</div>'+'<select class="field-select" style="height:24px;font-size:10px;width:100%" onclick="event.stopPropagation()" onchange="updateCatenaStato('+i+',this.value)">'+['Da verificare','In verifica','Conforme','Non conforme'].map(function(s){return '<option'+(s===stato?' selected':'')+'>'+s+'</option>';}).join('')+'</select>'+'</td>'+'</tr>';
  }).join('');
}

function filterCatene(q) {
  var catene = _store.get('catene_'+_currentPraticaId)||[];
  var filtered = q ? catene.filter(function(c){
    var haystack = [c.proc,c.contr,c.inc,c.fat,c.pag,c.forn].join(' ').toLowerCase();
    return haystack.includes(q.toLowerCase());
  }) : catene;
  var tbody = document.getElementById('ctrl-catene-tbody');
  if (tbody) tbody.innerHTML = _buildCateneRows(filtered);
}

function openCatenaDetail(i) {
  var catene = _store.get('catene_'+_currentPraticaId)||[];
  var c = catene[i];
  if (!c) return;
  _currentCatenaIdx = i;  // aggiorna indice per saveCatenaChecklist

  var salTagClass = c.sal_tipo==='Saldo finale'?'tag--saldo':c.sal_tipo==='Anticipazione'?'tag--ant':'tag--sal';
  var salLabel    = c.sal_tipo==='Saldo finale'?'Saldo':'SAL '+c.sal_progr;

  var html = '<div class="g2" style="gap:14px;margin-bottom:16px">'
    +'<div class="card" style="margin:0"><div class="card__header" style="padding:10px 16px"><span class="card__title" style="font-size:13px">Anagrafica catena</span>'
    +'<span class="tag '+salTagClass+'" style="font-size:10px">'+escHtml(salLabel)+'</span></div>'
    +'<div class="card__body" style="padding:14px">'
    +[
      ['Procedura', c.proc+(c.proc_tipo?' ('+c.proc_tipo+')':'')],
      ['Contratto aperto', c.contr+(c.contr_sa?'<br><span style="font-size:11px;color:var(--tx-lighter)">SA: '+escHtml(c.contr_sa)+'</span>':'')],
      ['Incarico / Attingimento', c.inc||'—'],
      ['Fornitore', c.forn||'—'],
      ['Fattura', c.fat+(c.fat_data?'<br><span style="font-size:11px;color:var(--tx-lighter)">'+new Date(c.fat_data).toLocaleDateString('it-IT')+'</span>':'')],
      ['Pagamento', c.pag+(c.pag_stato==='attesa'?' <span style="font-size:10px;color:var(--tx-warning)">(in attesa)</span>':c.pag_stato==='na'?' <span style="font-size:11px;color:var(--tx-disable)">N/A</span>':'')]
    ].map(function(r,idx){
      return '<div class="field-row"'+(idx===5?' style="border-bottom:none"':'')+'>'
        +'<span class="field-row__label">'+r[0]+'</span>'
        +'<span class="field-row__value" style="font-size:12px">'+r[1]+'</span>'
        +'</div>';
    }).join('')
    +'</div></div>'

    +'<div class="card" style="margin:0"><div class="card__header" style="padding:10px 16px"><span class="card__title" style="font-size:13px">Importi e stato</span></div>'
    +'<div class="card__body" style="padding:14px">'
    +'<div class="field-row"><span class="field-row__label">Imp. inerente</span><span class="field-row__value mono" style="font-weight:700">€ '+_fmt(c.imp_inerente||0)+'</span></div>'
    +'<div class="field-row"><span class="field-row__label">Imp. rendicontabile</span><span class="field-row__value mono" style="font-weight:700;color:var(--tx-success)">€ '+_fmt(c.imp_rendicont||0)+'</span></div>'
    +'<div class="field-row" style="border-bottom:none;align-items:flex-start"><span class="field-row__label">Stato controllo</span>'
    +'<select class="field-select" style="width:160px" id="catena-detail-stato-'+i+'" onchange="updateCatenaStato('+i+',this.value);document.getElementById(\'catena-detail-stato-'+i+'\').closest(\'.overlay\') && document.querySelectorAll(\'#ctrl-catene-tbody tr\')[0] && filterCatene(\'\')">'
    +['Da verificare','In verifica','Conforme','Non conforme'].map(function(s){return '<option'+(s===(c.stato_checklist||'Da verificare')?' selected':'')+'>'+s+'</option>';}).join('')
    +'</select></div>'
    +'</div></div>'
    +'</div>'

    // Documenti allegati alla catena
    +(function() {
      var docs  = c.docs || {};
      var campi = [
        {key:'proc',  label:'Procedura'},
        {key:'contr', label:'Contratto aperto'},
        {key:'inc',   label:'Incarico / Attingimento'},
        {key:'fat',   label:'Fattura'},
        {key:'pag',   label:'Pagamento / Bonifico'}
      ];
      var docRows = campi.filter(function(f){ return docs[f.key] && docs[f.key].nome; });
      if (docRows.length === 0) return '<div class="section-label" style="margin-bottom:10px">Documenti allegati</div>'
        +'<div style="margin-bottom:16px;padding:10px 14px;background:var(--bg-sec-lighter);border:1px solid var(--bd-sec-light);border-radius:var(--r-smooth);font-size:12px;color:var(--tx-lighter)">Nessun documento allegato a questa catena.</div>';
      var rows = docRows.map(function(f, idx) {
        var d = docs[f.key];
        var isLast = idx === docRows.length - 1;
        var viewBtn = d.dataUrl
          ? '<a href="'+d.dataUrl+'" target="_blank" class="btn btn--primary btn--xs" style="flex-shrink:0">&#128065; Visualizza</a>'
            +'<a href="'+d.dataUrl+'" download="'+escHtml(d.nome)+'" class="btn btn--ghost btn--xs" style="flex-shrink:0">&#11015; Scarica</a>'
          : '<span style="font-size:11px;color:var(--tx-lighter)">Nessuna anteprima</span>';
        return '<div class="doc-row"'+(isLast?' style="border-bottom:none"':'')+'>'
          +'<div style="width:28px;height:28px;border-radius:4px;background:var(--bg-error-lighter);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:14px">&#128196;</div>'
          +'<div class="doc-info" style="flex:1;min-width:0">'
          +'<div class="doc-name" style="font-size:12px;font-weight:600">'+escHtml(d.nome)+'</div>'
          +'<div class="doc-meta">'+escHtml(f.label)+(d.size?' · '+escHtml(d.size):'')+'</div>'
          +'</div>'
          +'<div style="display:flex;gap:6px;flex-shrink:0">'+viewBtn+'</div>'
          +'</div>';
      }).join('');
      return '<div class="section-label" style="margin-bottom:10px">Documenti allegati ('+docRows.length+')</div>'
        +'<div style="border:1px solid var(--bd-sec-light);border-radius:var(--r-smooth);overflow:hidden;margin-bottom:16px">'+rows+'</div>';
    })()

    // Checklist controllo
    +'<div class="section-label" style="margin-bottom:10px">Checklist di controllo</div>'
    +_buildCatenaChecklist(i, c)

    // Note
    +'<div class="field" style="margin-top:16px"><label class="field__label">Note di controllo</label>'
    +'<div class="field__input field__input--area"><textarea id="catena-note-'+i+'" style="min-height:60px" placeholder="Note sul controllo di questa catena…" oninput="saveCatenaNota('+i+',this.value)">'+escHtml(c.note_controllo||'')+'</textarea></div></div>';

  // Scrive nel modal corretto: modal-catena-detail
  var modalTitle = document.getElementById('catena-detail-title');
  var modalSub   = document.getElementById('catena-detail-sub');
  var modalBody  = document.getElementById('catena-detail-body');
  if (modalTitle) modalTitle.textContent = 'Catena #'+c.catena_n+' — '+escHtml(c.sal_tipo||'SAL')+' #'+c.sal_progr;
  if (modalSub)   modalSub.textContent   = escHtml(c.proc||'—')+(c.forn?' · '+escHtml(c.forn):'')+(c.imp_inerente?' · € '+_fmt(c.imp_inerente):'');
  if (modalBody)  modalBody.innerHTML    = html;

  // Aggiorna il pulsante Salva nel footer fisso del modal
  var saveBtn = document.querySelector('#modal-catena-detail .modal__footer .btn--primary');
  if (saveBtn) {
    saveBtn.textContent = 'Salva checklist';
    saveBtn.onclick = function(){ salvaChecklist(i); };
  }

  openModal('modal-catena-detail');
}

function _buildCatenaChecklist(i, c) {
  var cl = c.checklist || {};
  var items = [
    {id:'fat_valida',    label:'Fattura non proforma, fiscalmente valida'},
    {id:'non_duplicata', label:'Fattura non duplicata in SAL precedenti'},
    {id:'inerente',      label:'Spesa inerente all\'oggetto del finanziamento'},
    {id:'bonifico',      label:'Bonifico allegato e corrispondente all\'importo'},
    {id:'contr_ok',      label:'Contratto regolarmente stipulato e firmato'},
    {id:'proc_ok',       label:'Procedura di acquisto conforme alla normativa'}
  ];
  return '<div style="border:1px solid var(--bd-sec-light);border-radius:var(--r-smooth);overflow:hidden">'
    +items.map(function(item, idx){
      var val = cl[item.id] || '';
      function btn(v, label, cls){
        return '<button class="cl-btn cl-btn--'+cls+(val===v?' is-on':'')
          +'" onclick="setCatenaCheckItem('+i+',\''+item.id+'\',\''+v+'\',this)">'+label+'</button>';
      }
      return '<div class="cl-item" id="cat-cl-'+i+'-'+item.id+'"'+(idx===items.length-1?' style="border-bottom:none"':'')+'>'
        +'<div class="cl-item__text"><div class="cl-item__label">'+escHtml(item.label)+'</div></div>'
        +'<div class="cl-item__btns">'
        +btn('si','SI','si')+btn('no','NO','no')+btn('dv','DA VAL.','dv')+btn('na','N/A','na')
        +'</div></div>';
    }).join('')
    +'</div>';
}

function setCatenaCheckItem(catenaIdx, itemId, val, btn) {
  var catene = _store.get('catene_'+_currentPraticaId)||[];
  if (!catene[catenaIdx]) return;
  if (!catene[catenaIdx].checklist) catene[catenaIdx].checklist = {};
  catene[catenaIdx].checklist[itemId] = val;
  _store.set('catene_'+_currentPraticaId, catene);
  // Aggiorna bottoni
  var container = btn.closest('.cl-item__btns');
  container.querySelectorAll('.cl-btn').forEach(function(b){ b.classList.remove('is-on'); });
  btn.classList.add('is-on');
}

function salvaChecklist(i) {
  var catene = _store.get('catene_'+_currentPraticaId)||[];
  var c = catene[i];
  if (!c) return;
  // Auto-determina stato da checklist
  var cl = c.checklist || {};
  var vals = Object.values(cl);
  if (vals.length > 0) {
    var hasNo = vals.includes('no');
    var hasDv = vals.includes('dv');
    if (!c.stato_checklist || c.stato_checklist==='Da verificare') {
      c.stato_checklist = hasNo ? 'Non conforme' : hasDv ? 'In verifica' : 'Conforme';
    }
  }
  _store.set('catene_'+_currentPraticaId, catene);
  closeModal('modal-catena-detail');
  _renderCatene(catene);
}

function saveCatenaNota(i, val) {
  var catene = _store.get('catene_'+_currentPraticaId)||[];
  if (catene[i]) { catene[i].note_controllo = val; _store.set('catene_'+_currentPraticaId, catene); }
}

function updateCatenaStato(i, stato) {
  var catene = _store.get('catene_'+_currentPraticaId)||[];
  if (catene[i]) {
    catene[i].stato_checklist = stato;
    _store.set('catene_'+_currentPraticaId, catene);
    _renderCatene(catene);
  }
}

/* ── TAB 5: RICHIESTE ED EROGAZIONI ── */
async function _loadTabRichieste(p) {
  var richieste = _store.get('richieste_'+(p?p.id:_currentPraticaId))||[];
  var tbody = document.getElementById('richieste-tbody');
  var badge = document.getElementById('richieste-count-badge');
  var tabBadge = document.getElementById('tab-richieste-count');
  if (badge) badge.textContent = richieste.length+' richieste';
  if (tabBadge) tabBadge.textContent = richieste.length;
  if (!tbody) return;
  if (richieste.length===0) {
    tbody.innerHTML='<tr><td colspan="7" style="text-align:center;color:var(--tx-lighter);padding:32px;font-size:13px">Nessuna richiesta. Verranno create automaticamente dai SAL.</td></tr>';
    return;
  }
  var tipoClass={'SAL intermedio':'tag--sal','Saldo finale':'tag--saldo','Anticipazione':'tag--ant'};
  var ctrlMap={'In verifica':'sem--arancio','Conforme':'sem--verde','Non conforme':'sem--rosso','In firma N.O.':'sem--viola'};
  var erogMap={'In attesa':'sem--grigio','Erogato':'sem--verde','Sospeso':'sem--arancio'};
  tbody.innerHTML = richieste.map(function(r){
    return '<tr>'
      +'<td class="mono">#'+r.sal_progressivo+'</td>'
      +'<td><span class="tag '+(tipoClass[r.tipo]||'tag--sal')+'">'+escHtml(r.tipo)+'</span></td>'
      +'<td class="mono">'+new Date(r.data).toLocaleDateString('it-IT')+'</td>'
      +'<td class="mono" style="font-weight:700;color:var(--tx-secondary)">€ '+_fmt(r.importo)+'</td>'
      +'<td><span class="sem '+(ctrlMap[r.stato_controllo]||'sem--grigio')+'"><span class="sem__dot"></span>'+escHtml(r.stato_controllo||'—')+'</span></td>'
      +'<td><span class="sem '+(erogMap[r.stato_erogazione]||'sem--grigio')+'"><span class="sem__dot"></span>'+escHtml(r.stato_erogazione||'—')+'</span></td>'
      +'<td><button class="btn btn--ghost btn--xs" onclick="openSALDetail(\''+r.sal_id+'\')">Dettaglio SAL</button></td>'
      +'</tr>';
  }).join('');
}

/* ── TAB 6: FASCICOLO ── */
async function _loadTabFascicolo(p) {
  var docs = _store.get('docs_'+p.id)||[];
  _renderFascicoloCategorie(docs);
}

function _renderFascicoloCategorie(docs) {
  var el = document.getElementById('fascicolo-categorie');
  if (!el) return;
  var categorie = ['Delibera / Contratto','SAL','N.O. tecnico','Fatture','Bonifici','DURC','Atti autorizzativi','Altro'];
  el.innerHTML = categorie.map(function(cat){
    var catDocs = docs.filter(function(d){return (d.categoria||d.tipo||'Altro')===cat;});
    return '<div class="card" style="margin-bottom:8px">'
      +'<div class="card__header" style="cursor:pointer" onclick="fascToggle2(this)">'
      +'<div style="display:flex;align-items:center;gap:8px">'
      +'<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>'
      +'<span class="card__title" style="font-size:13px">'+escHtml(cat)+'</span>'
      +'<span class="badge badge--gray">'+catDocs.length+' file</span>'
      +'</div>'
      +'<span style="font-size:12px;color:var(--tx-lighter)">▼</span>'
      +'</div>'
      +'<div class="fasc-cat-body card__body-0">'
      +(catDocs.length===0
        ?'<div style="padding:14px 16px;font-size:12px;color:var(--tx-lighter)">Nessun documento in questa categoria. <span style="color:var(--tx-secondary);cursor:pointer" onclick="openUploadWithCat(\''+cat+'\')">Carica ▲</span></div>'
        :catDocs.map(function(d){
          var actBtns = d.url
            ?'<a href="'+escHtml(d.url)+'" target="_blank" class="btn btn--ghost btn--xs">&#128065;</a><a href="'+escHtml(d.url)+'" download class="btn btn--ghost btn--xs">&#11015;</a>'
            :'<button class="btn btn--ghost btn--xs" disabled>&#11015;</button>';
          return '<div class="doc-row">'
            +'<div class="doc-icon doc-icon--pdf">&#128196;</div>'
            +'<div class="doc-info"><div class="doc-name">'+escHtml(d.nome||d.file_name||'—')+'</div>'
            +'<div class="doc-meta">'+escHtml(d.dimensione||'—')+' · '+new Date(d.created_at).toLocaleDateString('it-IT')+(d.sal_ref?' · '+escHtml(d.sal_ref):'')+'</div></div>'
            +'<span class="sem sem--verde" style="flex-shrink:0"><span class="sem__dot"></span>Acquisito</span>'
            +'<div class="doc-actions">'+actBtns+'</div>'
            +'</div>';
        }).join('')
      )
      +'<div style="padding:8px 16px;border-top:1px solid var(--bd-sec-light)">'
      +'<button class="btn btn--ghost btn--xs" onclick="openUploadWithCat(\''+cat+'\')">&#11014; Aggiungi documento in questa categoria</button>'
      +'</div>'
      +'</div>'
      +'</div>';
  }).join('');
}

function fascToggle2(header) {
  var body = header.nextElementSibling;
  var icon = header.querySelector('span:last-child');
  if (!body) return;
  var open = body.style.display!=='none';
  body.style.display = open?'none':'block';
  if (icon) icon.textContent = open?'▶':'▼';
}

var _uploadCatOverride = null;
function openUploadWithCat(cat) {
  _uploadCatOverride = cat;
  openModal('modal-upload-doc');
}

/* ── TAB 7: MONITORAGGIO ── */
async function _loadTabMonitoraggio(p) {
  var sals = _store.get('sals_'+p.id)||[];
  var aggiornamenti = _store.get('agg_'+p.id)||[];

  // Fasi procedurali
  var fasieEl = document.getElementById('monit-fasi');
  if (fasieEl) {
    var fasi = [];
    if (p.data_stipula) fasi.push({label:'Stipula contratto',data:new Date(p.data_stipula).toLocaleDateString('it-IT'),done:true,type:'done'});
    sals.forEach(function(s){
      fasi.push({label:s.tipo+' #'+s.progressivo,data:new Date(s.data).toLocaleDateString('it-IT'),importo:'€ '+_fmt(s.importo),done:s.stato_erogazione==='Erogato',type:s.stato_erogazione==='Erogato'?'done':'active'});
    });
    fasi.push({label:'Chiusura pratica',data:'—',done:p.stato==='Chiusa',type:p.stato==='Chiusa'?'done':'todo'});

    fasieEl.innerHTML = '<div class="timeline">'+fasi.map(function(f,i){
      var dotClass = f.type==='done'?'tl-dot--done':f.type==='active'?'tl-dot--active':'tl-dot--todo';
      var connClass = f.type==='done'?'tl-connector--done':'';
      return '<div class="tl-item">'
        +'<div class="tl-spine"><div class="tl-dot '+dotClass+'"></div>'+(i<fasi.length-1?'<div class="tl-connector '+connClass+'"></div>':'')+'</div>'
        +'<div class="tl-body"><div class="tl-title">'+escHtml(f.label)+'</div>'
        +'<div class="tl-meta">'+escHtml(f.data)+(f.importo?' · <strong>'+escHtml(f.importo)+'</strong>':'')+'</div>'
        +'</div></div>';
    }).join('')+'</div>';
  }

  // Aggiornamenti manuali
  var aggEl = document.getElementById('monit-aggiornamenti');
  if (aggEl) {
    if (aggiornamenti.length===0) {
      aggEl.innerHTML = '<div style="padding:24px;text-align:center;color:var(--tx-lighter);font-size:12px">Nessun aggiornamento inserito.</div>';
    } else {
      aggEl.innerHTML = aggiornamenti.slice().reverse().map(function(a){
        return '<div class="doc-row">'
          +'<div style="width:32px;height:32px;border-radius:50%;background:var(--bg-primary-light);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:12px">&#128197;</div>'
          +'<div class="doc-info"><div class="doc-name">'+escHtml(a.tipo||'Aggiornamento')+(a.pct?'  <span style="font-size:11px;color:var(--tx-secondary)">'+a.pct+'%</span>':'')+'</div>'
          +'<div class="doc-meta">'+new Date(a.data).toLocaleDateString('it-IT')+' · '+escHtml(a.desc||'—')+'</div></div>'
          +'</div>';
      }).join('');
    }
  }
}

async function doSaveAggiornamento() {
  var tipo = document.getElementById('agg-tipo').value;
  var data = document.getElementById('agg-data').value;
  var pct  = document.getElementById('agg-pct').value;
  var desc = document.getElementById('agg-desc').value.trim();
  if (!data||!desc) { alert('Inserisci data e descrizione.'); return; }
  var agg = _store.get('agg_'+_currentPraticaId)||[];
  agg.push({id:'agg_'+Date.now(),tipo:tipo,data:data,pct:pct||null,desc:desc,created_at:new Date().toISOString()});
  _store.set('agg_'+_currentPraticaId, agg);
  closeModal('modal-nuovo-aggiornamento');
  document.getElementById('agg-desc').value='';
  document.getElementById('agg-pct').value='';
  await _loadTabMonitoraggio(_currentPratica);
}

/* ── MODIFICA ANAGRAFICA PRATICA ── */
function openEditAnagrafica() {
  var p = _currentPratica;
  if (!p) return;
  document.getElementById('eap-rapporto').value     = p.rapporto||'';
  document.getElementById('eap-beneficiario').value = p.beneficiario||'';
  document.getElementById('eap-comune').value       = p.comune||'';
  document.getElementById('eap-tipo').value         = p.tipo_mutuo||'Ordinario Privato';
  document.getElementById('eap-ambito').value       = p.ambito||'Sport';
  document.getElementById('eap-legge').value        = p.legge||'Legge 4101';
  document.getElementById('eap-importo').value      = _fmt(p.importo||0);
  document.getElementById('eap-stipula').value      = p.data_stipula||'';
  document.getElementById('eap-durata').value       = p.durata_mesi||'';
  document.getElementById('eap-ammort').value       = p.inizio_ammortamento||'';
  document.getElementById('eap-garanzia').value     = p.garanzia||'Non prevista';
  document.getElementById('eap-cup').value          = p.cup||'';
  document.getElementById('eap-oggetto').value      = p.oggetto||'';
  openModal('modal-edit-pratica-info');
}

async function saveEditAnagrafica() {
  var data = {
    beneficiario: document.getElementById('eap-beneficiario').value.trim(),
    comune:       document.getElementById('eap-comune').value.trim(),
    tipo_mutuo:   document.getElementById('eap-tipo').value,
    ambito:       document.getElementById('eap-ambito').value,
    legge:        document.getElementById('eap-legge').value,
    importo:      parseFloat((document.getElementById('eap-importo').value||'0').replace(/\./g,'').replace(',','.'))||0,
    data_stipula: document.getElementById('eap-stipula').value||null,
    durata_mesi:  parseInt(document.getElementById('eap-durata').value)||null,
    inizio_ammortamento: document.getElementById('eap-ammort').value||null,
    garanzia:     document.getElementById('eap-garanzia').value,
    cup:          document.getElementById('eap-cup').value.trim(),
    oggetto:      document.getElementById('eap-oggetto').value.trim()
  };
  if (!data.beneficiario) { alert('Il beneficiario è obbligatorio.'); return; }
  var res = await _db.updatePratica(_currentPraticaId, data);
  if (res.error) { alert('Errore: '+res.error); return; }
  Object.assign(_currentPratica, data);
  var idx = SESSION.pratiche.findIndex(function(p){return p.id===_currentPraticaId;});
  if (idx>-1) Object.assign(SESSION.pratiche[idx], data);
  closeModal('modal-edit-pratica-info');
  await goPraticaById(_currentPraticaId);
}

/* ── OVERRIDE openModal per btn-edit-pratica ── */
document.addEventListener('DOMContentLoaded', function(){
  var btn = document.getElementById('btn-edit-pratica');
  if (btn) btn.onclick = openEditAnagrafica;
});

/* ── TAB SWITCH: aggiorna anche catene quando si apre controllo ── */
var _origSwitchTab = switchTab;
switchTab = function(id, el) {
  _origSwitchTab(id, el);
  if (id==='controllo') { var c=_store.get('catene_'+_currentPraticaId)||[]; _renderCatene(c); }
  if (id==='quadro') { _qteData=_store.get('qte_'+_currentPraticaId)||[]; _renderQTE(_qteData); }
};

/* ── PROFILO UTENTE ── */
function toggleProfiloDropdown(event) {
  event.stopPropagation();
  var dd = document.getElementById('profilo-dropdown');
  var btn = document.getElementById('nav-user-btn');
  var rect = btn.getBoundingClientRect();
  dd.style.top  = (rect.bottom+4)+'px';
  dd.style.right = (window.innerWidth-rect.right)+'px';
  dd.style.left  = 'auto';
  var isOpen = dd.style.display==='block';
  dd.style.display = isOpen?'none':'block';
  if (!isOpen) {
    var u = SESSION.user||{};
    document.getElementById('dd-nome').textContent  = u.nome||u.email||'—';
    document.getElementById('dd-email').textContent = u.email||'—';
  }
}
document.addEventListener('click', function(e){
  var dd = document.getElementById('profilo-dropdown');
  if (dd && !dd.contains(e.target) && e.target.id!=='nav-user-btn') dd.style.display='none';
});

function openProfilo() {
  document.getElementById('profilo-dropdown').style.display='none';
  var u = SESSION.user||{};
  var parts = u.nome?u.nome.split(' '):[];
  var initials = parts.length>=2?(parts[0][0]+parts[parts.length-1][0]).toUpperCase():u.email?u.email.slice(0,2).toUpperCase():'—';
  document.getElementById('profilo-avatar-big').textContent = initials;
  document.getElementById('profilo-nome-display').textContent = u.nome||'—';
  document.getElementById('profilo-email-display').textContent = u.email||'—';
  document.getElementById('profilo-ruolo-display').innerHTML = u.ruolo==='admin'?'<span class="badge badge--violet">Admin</span>':'<span class="badge badge--gray">Riscontro Tecnico</span>';
  document.getElementById('profilo-nome').value = u.nome||'';
  document.getElementById('profilo-pwd-old').value='';
  document.getElementById('profilo-pwd-new').value='';
  document.getElementById('profilo-pwd-confirm').value='';
  document.getElementById('profilo-error').style.display='none';
  document.getElementById('profilo-success').style.display='none';
  openModal('modal-profilo');
}

async function saveProfilo() {
  var nome    = document.getElementById('profilo-nome').value.trim();
  var pwdOld  = document.getElementById('profilo-pwd-old').value;
  var pwdNew  = document.getElementById('profilo-pwd-new').value;
  var pwdConf = document.getElementById('profilo-pwd-confirm').value;
  var errEl   = document.getElementById('profilo-error');
  var okEl    = document.getElementById('profilo-success');
  errEl.style.display='none'; okEl.style.display='none';

  if (!nome) { errEl.textContent='⚠ Inserisci il tuo nome.'; errEl.style.display='block'; return; }

  // Se ha compilato il campo nuova password
  if (pwdNew) {
    if (pwdNew.length<8) { errEl.textContent='⚠ La nuova password deve essere di almeno 8 caratteri.'; errEl.style.display='block'; return; }
    if (pwdNew!==pwdConf) { errEl.textContent='⚠ Le password non coincidono.'; errEl.style.display='block'; return; }
    // Verifica vecchia password (mock)
    if (!_sb) {
      var users = _store.get('users')||[];
      var u = users.find(function(x){return x.id===SESSION.user.id;});
      if (u && u.pwd_hash && u.pwd_hash!==pwdOld) { errEl.textContent='⚠ Password attuale non corretta.'; errEl.style.display='block'; return; }
      var res = await _db.setPassword(SESSION.user.id, nome, pwdNew);
      if (res.error) { errEl.textContent='⚠ '+res.error; errEl.style.display='block'; return; }
    }
  } else {
    // Solo aggiorna nome
    var users = _store.get('users')||[];
    var idx = users.findIndex(function(x){return x.id===SESSION.user.id;});
    if (idx>-1) { users[idx].nome=nome; _store.set('users',users); }
  }

  SESSION.user.nome = nome;
  var parts = nome.split(' ');
  var initials = parts.length>=2?(parts[0][0]+parts[parts.length-1][0]).toUpperCase():nome.slice(0,2).toUpperCase();
  var avatarEl = document.getElementById('nav-avatar');
  var usernameEl = document.getElementById('nav-username');
  if (avatarEl) avatarEl.textContent=initials;
  if (usernameEl) usernameEl.textContent=nome;

  okEl.textContent='✅ Profilo aggiornato con successo.';
  okEl.style.display='block';
  setTimeout(function(){ closeModal('modal-profilo'); },1500);
}

/* ── UPLOAD DOCUMENTO: inietta in fascicolo con categoria ── */
async function doUploadDoc() {
  var tipo = (document.getElementById('upload-doc-tipo')||{}).value || _uploadCatOverride || '';
  var desc = ((document.getElementById('upload-doc-desc')||{}).value||'').trim();
  var resultEl = document.getElementById('upload-result');
  var progressWrap = document.getElementById('upload-progress-wrap');
  var progressBar  = document.getElementById('upload-progress-bar');
  var progressLbl  = document.getElementById('upload-progress-label');
  var submitBtn    = document.getElementById('upload-submit-btn');

  if (!tipo) { _showResult(resultEl,'error','⚠ Seleziona il tipo di documento.'); return; }
  if (!_uploadFile) { _showResult(resultEl,'error','⚠ Seleziona un file da caricare.'); return; }
  if (!_currentPraticaId) { _showResult(resultEl,'error','⚠ Apri prima una pratica.'); return; }

  submitBtn.disabled=true;
  if (progressWrap) progressWrap.style.display='block';

  var publicUrl=null;
  if (_sb) {
    var path=_currentPraticaId+'/'+tipo.replace(/[\s\/()]/g,'_')+'/'+Date.now()+'_'+_uploadFile.name.replace(/[^a-zA-Z0-9.\-_]/g,'_');
    var fk=0, iv=setInterval(function(){fk=Math.min(fk+8,80);if(progressBar)progressBar.style.width=fk+'%';},120);
    var r=await _sb.storage.from(SB_BUCKET).upload(path,_uploadFile,{cacheControl:'3600',upsert:false});
    clearInterval(iv);
    if(r.error){submitBtn.disabled=false;if(progressBar)progressBar.style.width='0%';_showResult(resultEl,'error','❌ '+r.error.message);return;}
    var urlR=_sb.storage.from(SB_BUCKET).getPublicUrl(path);
    publicUrl=urlR.data?urlR.data.publicUrl:null;
  } else {
    var fk2=0,iv2=setInterval(function(){fk2=Math.min(fk2+18,95);if(progressBar)progressBar.style.width=fk2+'%';},100);
    await new Promise(function(r){setTimeout(r,1000);});
    clearInterval(iv2);
  }
  if(progressBar)progressBar.style.width='100%';
  if(progressLbl)progressLbl.textContent='Completato';

  var docData={tipo:tipo,nome:desc||_uploadFile.name,file_name:_uploadFile.name,url:publicUrl,dimensione:(_uploadFile.size/1024).toFixed(0)+' KB',categoria:tipo,caricato_da:SESSION.user?SESSION.user.id:null};
  var resD=await _db.addDocumento(_currentPraticaId,docData);
  submitBtn.disabled=false;
  _uploadCatOverride=null;
  if(resD.error){_showResult(resultEl,'error','❌ '+resD.error);return;}
  _showResult(resultEl,'success','✅ Documento caricato: <strong>'+escHtml(_uploadFile.name)+'</strong>');
  var allDocs=await _db.getDocumenti(_currentPraticaId);
  _renderFascicoloCategorie(allDocs);
  setTimeout(function(){closeModal('modal-upload-doc');clearUploadState();},1800);
}

/* ── MODAL NUOVO SAL — apri con click ── */
document.addEventListener('DOMContentLoaded', function(){
  var btn = document.querySelector('[onclick="openModal(\'modal-nuovo-sal\')"]');
  if (btn) btn.setAttribute('onclick','openModalNuovoSAL()');
});
// Override per il button nel tab inserimento
function openNuovoSalModal() { openModalNuovoSAL(); }
</script>
</body>
