<style>
/* ── Tab Controllo Eleggibilità ── */
.ctrl-kpi { background:var(--bg-inverse);border:1px solid var(--bd-sec-light);border-top:3px solid var(--bd-prim-light);border-radius:var(--r-smooth);padding:14px 16px;display:flex;flex-direction:column;gap:6px; }
.ctrl-kpi__title { font-size:13px;font-weight:700;color:var(--tx-primary);margin-bottom:4px; }
.ctrl-kpi__row { display:flex;justify-content:space-between;align-items:center;font-size:12px; }
.ctrl-kpi__label { color:var(--tx-lighter); }
.ctrl-kpi__val { font-family:var(--ff-mono);font-weight:600;color:var(--tx-primary); }
.ctrl-table { width:100%;border-collapse:collapse;font-size:12px; }
.ctrl-table th { padding:10px 12px;text-align:left;font-size:11px;font-weight:600;color:var(--tx-lighter);text-transform:uppercase;letter-spacing:.05em;border-bottom:2px solid var(--bd-sec-light);background:var(--bg-sec-lighter);white-space:nowrap; }
.ctrl-table td { padding:10px 12px;border-bottom:1px solid var(--bd-sec-light);vertical-align:middle;white-space:nowrap; }
.ctrl-table tr:hover td { background:var(--bg-primary-light); }
.cd-cell { display:flex;align-items:center;gap:6px; }
.cd-link { color:var(--tx-secondary);font-weight:500;cursor:pointer;text-decoration:underline;font-size:12px; }
.cd-link:hover { color:var(--bg-emphasis); }
.cd-ok { color:var(--tx-success);font-size:14px; }
.flag-r { width:18px;height:18px;border-radius:50%;background:var(--bg-sec-light);color:var(--tx-lighter);font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0; }
.flag-r--active { background:var(--bg-primary-light);color:var(--tx-secondary); }
.btn-assegna { height:26px;padding:0 10px;font-size:11px;font-weight:700;background:var(--bg-primary);color:#fff;border:none;border-radius:var(--r-smooth);cursor:pointer;white-space:nowrap; }
.btn-assegna:hover { background:var(--bg-primary-hover); }
/* Wizard SAL step panels */
.sal-wiz-panel { }
/* Upload doc row */
.upload-doc-row { display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--bd-sec-light); }
.upload-doc-row:last-child { border-bottom:none; }
.upload-doc-row__label { font-size:13px;flex:1; }
.upload-btn { height:30px;padding:0 12px;font-size:12px;font-weight:600;border:1.5px solid var(--bd-prim-light);border-radius:var(--r-smooth);color:var(--tx-secondary);background:var(--bg-primary-light);cursor:pointer;flex-shrink:0;white-space:nowrap;transition:all .12s; }
.upload-btn:hover { background:var(--bg-primary);color:#fff;border-color:var(--bg-primary); }
.upload-btn.is-uploaded { background:var(--bg-success-lighter);color:var(--tx-success);border-color:var(--bd-success); }
</style>

