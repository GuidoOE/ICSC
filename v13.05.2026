<!-- ═══════════════════════════════════════════════════
     JAVASCRIPT
═══════════════════════════════════════════════════ -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
/* ── Preventivo di spesa — aggiungi voce ── */
function prev2AddRow() {
  var tbody = document.querySelector('#prev2-tbl tbody');
  var addRow = document.getElementById('prev2-add-row');
  var tr = document.createElement('tr');
  tr.innerHTML = '<td class="td-voce"><input type="text" placeholder="Voce di spesa…" style="width:100%;border:none;border-bottom:1.5px solid var(--bd-sec-light);background:transparent;font-family:var(--ff-body);font-size:13px;font-weight:600;padding:2px 4px;outline:none"></td>'
    + '<td class="td-stanz"><input class="prev-input" type="text" value="0,00" oninput="prev2Calc()"></td>'
    + '<td class="td-erog"><input class="prev-input" type="text" value="0,00" oninput="prev2Calc()"></td>'
    + '<td class="td-resid"><input class="prev-input ro" type="text" value="0,00" readonly tabindex="-1"></td>';
  tbody.insertBefore(tr, addRow);
  tr.querySelector('input[type=text]').focus();
  prev2Calc();
}

/* ── Preventivo di spesa calc ── */
function prev2Calc() {
  var rows = document.querySelectorAll('#prev2-tbl tbody tr:not(.prev-tot)');
  var totS=0, totE=0;
  function p(v){ return parseFloat((v||'0').replace(/\./g,'').replace(',','.')) || 0; }
  function f(n){ return n.toLocaleString('it-IT',{minimumFractionDigits:2,maximumFractionDigits:2}); }
  rows.forEach(function(tr){
    var ins = tr.querySelectorAll('input');
    if(ins.length<3) return;
    var s=p(ins[0].value), e=p(ins[1].value), r=s-e;
    ins[2].value = f(r);
    ins[2].style.color = r>0 ? 'var(--tx-warning)' : r<0 ? 'var(--tx-error)' : 'var(--tx-lighter)';
    ins[2].style.fontWeight = r!==0 ? '700' : '400';
    totS+=s; totE+=e;
  });
  var ts=document.getElementById('prev2-tot-stanz'); if(ts) ts.value=f(totS);
  var te=document.getElementById('prev2-tot-erog');  if(te) te.value=f(totE);
  var tr2=document.getElementById('prev2-tot-resid'); 
  if(tr2){ var r2=totS-totE; tr2.value=f(r2); tr2.style.color=r2>0?'var(--tx-warning)':r2<0?'var(--tx-error)':'var(--tx-lighter)'; tr2.style.fontWeight=r2!==0?'700':'400'; }
}

/* ── Quadro economico nuovo schema ── */
function qe2Calc() {
  var rows = document.querySelectorAll('#qe2-tbl tbody tr:not(.tot-row):not(.contr-row)');
  var totProg=0, totAmm=0, totAppr=0, totContr=0;
  rows.forEach(function(tr, i) {
    var inputs = tr.querySelectorAll('input');
    var prog  = parseFloat((inputs[0]?.value||'0').replace(/\./g,'').replace(',','.')) || 0;
    var amm   = parseFloat((inputs[1]?.value||'0').replace(/\./g,'').replace(',','.')) || 0;
    var appr  = parseFloat((inputs[2]?.value||'0').replace(/\./g,'').replace(',','.')) || 0;
    var intens= parseFloat((inputs[3]?.value||'0').replace(/\./g,'').replace(',','.')) || 0;
    var contr = appr * intens / 100;
    totProg += prog; totAmm += amm; totAppr += appr; totContr += contr;
    var el = document.getElementById('qe2-contr-' + i);
    if (el) el.textContent = contr.toLocaleString('it-IT',{minimumFractionDigits:2,maximumFractionDigits:2});
  });
  function fmt(n){ return n.toLocaleString('it-IT',{minimumFractionDigits:2,maximumFractionDigits:2}); }
  var tp=document.getElementById('qe2-tot-prog'); if(tp) tp.value=fmt(totProg);
  var ta=document.getElementById('qe2-tot-amm');  if(ta) ta.value=fmt(totAmm);
  var tpr=document.getElementById('qe2-tot-appr'); if(tpr) tpr.value=fmt(totAppr);
  var tc=document.getElementById('qe2-contributo'); if(tc) tc.textContent=fmt(totContr);
}

/* ── Quadro economico data-entry ── */
function qeParseNum(s) {
  if (!s || s.trim() === '' || s.trim() === '—') return 0;
  return parseFloat(s.replace(/\./g,'').replace(',','.')) || 0;
}
function qeFormat(n) {
  return n.toLocaleString('it-IT', {minimumFractionDigits:2, maximumFractionDigits:2});
}
function qeFocusIn(el) {
  // Strip formatting on focus for easy editing
  const raw = el.value.replace(/\./g,'').replace(',','.');
  el.value = raw || '';
}
function qeBlurOut(el) {
  const n = parseFloat(el.value) || 0;
  el.value = n !== 0 ? qeFormat(Math.abs(n)) * (n < 0 ? -1 : 1) : (el.placeholder === '—' ? '' : qeFormat(0));
  // Re-trigger calc
  if (el.classList.contains('qte-stanz') || el.classList.contains('qte-erog')) qteCalc();
  if (el.classList.contains('prev-stanz') || el.classList.contains('prev-erog')) prevCalc();
}

function qteCalc() {
  const rows = ['lavori','spese','impr','area','attr','mezzi','gar'];
  let totS = 0, totE = 0;
  rows.forEach(r => {
    const sEl = document.querySelector('.qte-stanz[data-row="'+r+'"]');
    const eEl = document.querySelector('.qte-erog[data-row="'+r+'"]');
    const rEl = document.querySelector('.qe-input[data-row="'+r+'"]:read-only');
    const s = sEl ? qeParseNum(sEl.value) : 0;
    const e = eEl ? qeParseNum(eEl.value) : 0;
    const resid = s - e;
    if (rEl && r !== 'gar') {
      rEl.value = qeFormat(resid);
      rEl.className = rEl.className.replace(/qe-input--resid-\w+/g,'');
      if (resid <= 0) rEl.classList.add('qe-input--resid-ok');
      else rEl.classList.add('qe-input--resid-warn');
    }
    if (r !== 'mezzi') { totS += s; totE += e; }
  });
  const totResid = totS - totE;
  const ts = document.getElementById('qte-tot-stanz');
  const te = document.getElementById('qte-tot-erog');
  const tr = document.getElementById('qte-tot-resid');
  if (ts) ts.value = qeFormat(totS);
  if (te) te.value = qeFormat(totE);
  if (tr) tr.value = qeFormat(totResid);
}

function qteSave() {
  const msg = document.getElementById('qte-saved-msg');
  if (msg) { msg.style.display='inline'; setTimeout(()=>msg.style.display='none', 2000); }
}

function prevCalc() {
  const rows = ['lav','st','impr','mezzi'];
  let totS = 0, totE = 0;
  rows.forEach(r => {
    const sEl = document.querySelector('.prev-stanz[data-row="'+r+'"]');
    const eEl = document.querySelector('.prev-erog[data-row="'+r+'"]');
    const rEl = document.querySelector('#prev-tbl .qe-input[data-row="'+r+'"]:read-only');
    const s = sEl ? qeParseNum(sEl.value) : 0;
    const e = eEl ? qeParseNum(eEl.value) : 0;
    const resid = s - e;
    if (rEl) {
      rEl.value = qeFormat(resid);
      rEl.className = rEl.className.replace(/qe-input--resid-\w+/g,'');
      if (resid <= 0) rEl.classList.add('qe-input--resid-ok');
      else rEl.classList.add('qe-input--resid-warn');
    }
    totS += s; totE += e;
  });
  const totResid = totS - totE;
  const ts = document.getElementById('prev-tot-stanz');
  const te = document.getElementById('prev-tot-erog');
  const tr = document.getElementById('prev-tot-resid');
  if (ts) ts.value = qeFormat(totS);
  if (te) te.value = qeFormat(totE);
  if (tr) { tr.value = qeFormat(totResid); tr.className = tr.className.replace(/qe-input--resid-\w+/g,''); tr.classList.add(totResid > 0 ? 'qe-input--resid-warn' : 'qe-input--resid-ok'); }
  const note = document.getElementById('prev-resid-note');
  if (note) note.textContent = '€ ' + qeFormat(totResid);
}

function prevSave() {
  const msg = document.getElementById('prev-saved-msg');
  if (msg) { msg.style.display='inline'; setTimeout(()=>msg.style.display='none', 2000); }
}


/* ── Inserimento richieste — step nav ── */
function insStep(n) {
  for (var i=1; i<=4; i++) {
    var p = document.getElementById('ip-'+i);
    var s = document.getElementById('is-'+i);
    if (p) p.style.display = i===n ? 'block' : 'none';
    if (s) {
      s.classList.remove('is-active','is-done');
      if (i < n) s.classList.add('is-done');
      if (i === n) s.classList.add('is-active');
    }
  }
}

/* ── Toggle upload button ── */
function insToggleUpload(btn) {
  if (btn.classList.contains('is-uploaded')) {
    btn.classList.remove('is-uploaded');
    btn.textContent = '⬆ Carica';
  } else {
    btn.classList.add('is-uploaded');
    btn.textContent = '✓ Caricato';
  }
}

/* ── Aggiungi riga generica ── */
function insAddProjRow(tableId) {
  var tbody = document.querySelector("#"+tableId+" tbody");
  var cols = tbody.querySelector("tr").cells.length;
  var tr = document.createElement("tr");
  var html = "";
  for (var i=0; i<cols-2; i++) html += "<td><input class=\"proj-input-sm\" type=\"text\" placeholder=\"—\"></td>";
  html += "<td><button class=\"upload-btn\" style=\"width:80px;font-size:11px\" onclick=\"insToggleUpload(this)\">⬆ Carica</button></td>";
  html += "<td><button onclick=\"this.parentElement.parentElement.remove()\" style=\"border:none;background:none;color:var(--tx-error);cursor:pointer;font-size:16px;padding:0\">×</button></td>";
  tr.innerHTML = html;
  tbody.appendChild(tr);
}

function insAddProcRow() {
  var tbody = document.querySelector("#ins-proc-table tbody");
  var tr = document.createElement("tr");
  tr.innerHTML = "<td><select class=\"proj-input-sm\"><option>Affidamento diretto</option><option>Proc. negoziata</option><option>Gara aperta</option><option>Cottimo</option></select></td>"
    +"<td><input class=\"proj-input-sm\" type=\"text\" placeholder=\"N. proc.\"></td>"
    +"<td><input class=\"proj-input-sm\" type=\"text\" placeholder=\"Stazione appaltante\"></td>"
    +"<td><input class=\"proj-input-sm\" type=\"text\" placeholder=\"0,00\" style=\"width:100px\"></td>"
    +"<td><input class=\"proj-input-sm\" type=\"date\" style=\"width:130px\"></td>"
    +"<td><button class=\"upload-btn\" style=\"width:80px;font-size:11px\" onclick=\"insToggleUpload(this)\">⬆ Carica</button></td>"
    +"<td><button onclick=\"this.parentElement.parentElement.remove()\" style=\"border:none;background:none;color:var(--tx-error);cursor:pointer;font-size:16px;padding:0\">×</button></td>";
  tbody.appendChild(tr);
}

function insAddFatRow() {
  var tbody = document.querySelector("#ins-fat-table tbody");
  var tr = document.createElement("tr");
  tr.innerHTML = "<td><input class=\"proj-input-sm\" type=\"text\" placeholder=\"N. fattura\"></td>"
    +"<td><input class=\"proj-input-sm\" type=\"text\" placeholder=\"Fornitore\"></td>"
    +"<td><select class=\"proj-input-sm\"><option>Lavori</option><option>Spese tecniche</option><option>Attrezzature</option><option>Oneri sicurezza</option></select></td>"
    +"<td><input class=\"proj-input-sm\" type=\"text\" placeholder=\"0,00\" style=\"width:110px\"></td>"
    +"<td><input class=\"proj-input-sm\" type=\"date\" style=\"width:130px\"></td>"
    +"<td><button class=\"upload-btn\" style=\"width:80px;font-size:11px\" onclick=\"insToggleUpload(this)\">⬆ Carica</button></td>"
    +"<td><button onclick=\"this.parentElement.parentElement.remove()\" style=\"border:none;background:none;color:var(--tx-error);cursor:pointer;font-size:16px;padding:0\">×</button></td>";
  tbody.appendChild(tr);
}

/* ── Modal dettaglio Item ── */
function openItemDetail(salId) {
  var data = {
    'SAL 1': {
      tag: '<span class="tag tag--sal">SAL 1</span>',
      tipo: 'SAL (intermedio)', progr:'1', data:'19/12/2024', importo:'€ 32.791,00',
      dl:'Arch. M. Cafulli', impresa:'Edilizia Bari SRL',
      oggetto:'Prima lavorazione campo calcetto — pavimentazione e fondamenta.',
      docs: [
        {nome:'SAL firmato DL', stato:'ok'},
        {nome:'Certificato di pagamento DL', stato:'ok'},
        {nome:'Dichiarazione SAL ICSC', stato:'ok'},
        {nome:'Bonifici / quietanze', stato:'ok'},
        {nome:'DURC', stato:'ok'},
        {nome:'Parcella tecnica', stato:'na'},
        {nome:'CRE / Collaudo', stato:'na'},
        {nome:'Parere CONI', stato:'na'},
      ],
      catene: [
        {proc:'ICSC-5978-001', contr:'CT-2024-001', fat:'FAT-27/2024', pag:'PAG-2024-027', imp:'32.791,00 €', pag_ok:true}
      ]
    },
    'Saldo': {
      tag: '<span class="tag tag--saldo">Saldo</span>',
      tipo: 'Saldo finale', progr:'2', data:'27/06/2025', importo:'€ 215.209,00',
      dl:'Arch. M. Cafulli', impresa:'Edilizia Bari SRL',
      oggetto:'Completamento riqualificazione campo calcetto e polivalente — pavimentazione e recinzione.',
      docs: [
        {nome:'SAL / CRE firmato DL', stato:'ok'},
        {nome:'Certificato di pagamento DL', stato:'ok'},
        {nome:'Dichiarazione SAL ICSC', stato:'ok'},
        {nome:'Bonifici / quietanze', stato:'missing'},
        {nome:'DURC', stato:'ok'},
        {nome:'Parcella tecnica', stato:'ok'},
        {nome:'CRE / Collaudo', stato:'missing'},
        {nome:'Parere CONI', stato:'missing'},
      ],
      catene: [
        {proc:'ICSC-5978-001', contr:'CT-2024-001', fat:'FAT-31/2025', pag:'PAG-2025-031', imp:'165.518,00 €', pag_ok:true},
        {proc:'ICSC-5978-001', contr:'CT-2024-001', fat:'FAT-PF-012/2025', pag:'—', imp:'4.500,00 €', pag_ok:false},
      ]
    }
  };
  var d = data[salId];
  if (!d) return;
  var el = document.getElementById('modal-item-detail');
  el.querySelector('#mid-title').innerHTML = 'Dettaglio Item — ' + d.tag;
  el.querySelector('#mid-tipo').textContent = d.tipo;
  el.querySelector('#mid-progr').textContent = d.progr;
  el.querySelector('#mid-data').textContent = d.data;
  el.querySelector('#mid-importo').textContent = d.importo;
  el.querySelector('#mid-dl').textContent = d.dl;
  el.querySelector('#mid-impresa').textContent = d.impresa;
  el.querySelector('#mid-oggetto').textContent = d.oggetto;

  // Semaforo globale
  var missing = d.docs.filter(function(x){return x.stato==='missing';}).length;
  var sem = el.querySelector('#mid-semaforo');
  if (missing === 0) {
    sem.innerHTML = '<span class="sem sem--verde" style="font-size:12px;padding:3px 10px"><span class="sem__dot"></span>Documentazione completa</span>';
  } else {
    sem.innerHTML = '<span class="sem sem--rosso" style="font-size:12px;padding:3px 10px"><span class="sem__dot"></span>' + missing + ' documento/i mancante/i</span>';
  }

  // Docs
  el.querySelector('#mid-docs').innerHTML = d.docs.map(function(doc) {
    var badge = doc.stato==='ok'
      ? '<span class="sem sem--verde" style="font-size:10px;padding:2px 8px;flex-shrink:0"><span class="sem__dot"></span>Presente</span>'
      : doc.stato==='missing'
        ? '<span class="sem sem--rosso" style="font-size:10px;padding:2px 8px;flex-shrink:0"><span class="sem__dot"></span>Mancante</span>'
        : '<span class="sem sem--grigio" style="font-size:10px;padding:2px 8px;flex-shrink:0"><span class="sem__dot"></span>N/A</span>';
    return '<div style="display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--bd-sec-light);gap:12px">'
      +'<span style="font-size:13px">'+doc.nome+'</span>'+badge+'</div>';
  }).join('');

  // Catene
  el.querySelector('#mid-catene').innerHTML = d.catene.map(function(c) {
    var pagCell = c.pag_ok
      ? '<span class="cd-link">'+c.pag+'</span> <span class="cd-ok">●</span>'
      : '<span style="color:var(--tx-warning);font-size:11px">⏳ '+c.pag+'</span>';
    return '<tr style="border-bottom:1px solid var(--bd-sec-light)">'
      +'<td style="padding:7px 12px"><span class="cd-link">'+c.proc+'</span></td>'
      +'<td style="padding:7px 12px"><span class="cd-link">'+c.contr+'</span></td>'
      +'<td style="padding:7px 12px"><span class="cd-link">'+c.fat+'</span></td>'
      +'<td style="padding:7px 12px">'+pagCell+'</td>'
      +'<td style="padding:7px 12px;text-align:right;font-family:var(--ff-mono);font-size:12px">'+c.imp+'</td>'
      +'</tr>';
  }).join('');

  openModal('modal-item-detail');
}

/* ── Modal edit pratica sub-tabs ── */
function meditSwitch(id, el) {
  document.querySelectorAll('.medit-body').forEach(b => b.classList.remove('is-active'));
  document.querySelectorAll('.medit-tab').forEach(t => t.classList.remove('is-active'));
  const body = document.getElementById('medit-' + id);
  if (body) body.classList.add('is-active');
  if (el) el.classList.add('is-active');
}

/* ── Fascicolo sezioni toggle ── */
function fascToggle(id) {
  const body = document.getElementById(id);
  const icon = document.getElementById(id + '-icon');
  if (!body) return;
  const open = body.style.display !== 'none';
  body.style.display = open ? 'none' : 'block';
  if (icon) {
    // Handle both class-based and text-based icons
    icon.classList.toggle('is-open', !open);
    if (icon.textContent === '▶' || icon.textContent === '▼') {
      icon.textContent = open ? '▶' : '▼';
    }
    // Rotation for class-based toggle icons
    icon.style.transform = (!open && icon.textContent === '') ? 'rotate(180deg)' : '';
  }
}

/* ══════════════════════════════════════════════════════
   NAVIGAZIONE PAGINE (override)
══════════════════════════════════════════════════════ */
function goDashboard() {
  document.querySelectorAll('.page').forEach(function(p){ p.classList.remove('is-visible'); });
  document.getElementById('page-dashboard').classList.add('is-visible');
  document.querySelectorAll('.sb-item').forEach(function(i){ i.classList.remove('is-active'); });
  var sbDash = document.getElementById('sb-dashboard');
  if (sbDash) sbDash.classList.add('is-active');
  renderDashboard();
}
function goPratica() {
  document.querySelectorAll('.page').forEach(function(p){ p.classList.remove('is-visible'); });
  document.getElementById('page-pratica').classList.add('is-visible');
  document.querySelectorAll('.sb-item').forEach(function(i){ i.classList.remove('is-active'); });
  document.getElementById('main').scrollTop = 0;
}

/* ── Tab switching (pratica) ── */
function switchTab(id, el) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('is-active'));
  document.getElementById('tab-' + id).classList.add('is-active');
  document.querySelectorAll('#pratica-tabs .tab').forEach(t => t.classList.remove('is-active'));
  el.classList.add('is-active');
  document.getElementById('main').scrollTop = 0;
}

/* ── Sidebar ── */
function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('is-collapsed');
}

/* ── FAB ── */
function fabToggle() {
  document.getElementById('fab-actions').classList.toggle('is-open');
}

/* ── Modals ── */
function openModal(id) { document.getElementById(id).classList.add('is-open'); }
function closeModal(id) { document.getElementById(id).classList.remove('is-open'); }
document.addEventListener('click', e => {
  if (e.target.classList.contains('overlay')) e.target.classList.remove('is-open');
});

/* ── Checklist ── */
function ckSet(itemId, val) {
  const item = document.getElementById(itemId);
  item.querySelectorAll('.cl-btn').forEach(b => b.classList.remove('is-on'));
  const map = { si: 'cl-btn--si', no: 'cl-btn--no', dv: 'cl-btn--dv', na: 'cl-btn--na' };
  const btn = item.querySelector('.' + map[val]);
  if (btn) btn.classList.add('is-on');
}

/* ── Monitoraggio sub-tabs ── */
function monTabSwitch(id) {
  ['overview', 'proc'].forEach(s => {
    const el = document.getElementById('mon-' + s);
    if (el) el.style.display = s === id ? 'block' : 'none';
    const tab = document.getElementById('mon-tab-' + s);
    if (tab) tab.classList.toggle('is-active', s === id);
  });
}

/* ── Dashboard row click ── */
document.addEventListener('DOMContentLoaded', () => {
  // Dashboard già impostata come is-visible
});

/* ── Wizard Richiesta ── */
function reqWizardOpen() {
  const w = document.getElementById('req-wizard');
  w.style.display = 'block';
  reqStep(1);
  setTimeout(() => w.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
}
function reqWizardClose() {
  document.getElementById('req-wizard').style.display = 'none';
}
function reqStep(n) {
  for (let i = 1; i <= 6; i++) {
    const body = document.getElementById('rp-' + i);
    const step = document.getElementById('rs-' + i);
    if (body) body.style.display = i === n ? 'block' : 'none';
    if (step) {
      step.classList.remove('is-active', 'is-done');
      if (i < n)  step.classList.add('is-done');
      if (i === n) step.classList.add('is-active');
    }
  }
  if (n === 5) step5Calc();
}

// Step 5 — calcolo totale fatture selezionate
const STEP5_DATA = [
  { id:'fsr-1', importo:32791,    label:'2 sel.' },
  { id:'fsr-2', importo:165518,   label:'' },
  { id:'fsr-3', importo:0,        label:'' },  // non conforme, disabled
  { id:'fsr-4', importo:0,        label:'' },
  { id:'fsr-5', importo:null,     label:'' },  // in lavorazione
];

function step5Calc() {
  let total = 0;
  let selCount = 0;
  let hasLav = false;

  STEP5_DATA.forEach(d => {
    const row = document.getElementById(d.id);
    if (!row) return;
    const cb = row.querySelector('input[type=checkbox]');
    if (cb && cb.checked && !cb.disabled) {
      selCount++;
      if (d.importo !== null) total += d.importo;
      else hasLav = true;
    }
  });

  const fmt = total.toLocaleString('it-IT', {minimumFractionDigits:2, maximumFractionDigits:2});
  const totalEl = document.getElementById('step5-total');
  const countEl = document.getElementById('step5-count');
  const warnEl  = document.getElementById('step5-warn-lav');
  const avantiEl = document.getElementById('step5-avanti');

  if (totalEl) totalEl.textContent = '€ ' + fmt;
  if (countEl) countEl.textContent = selCount + ' selezionat' + (selCount===1?'a':'e') + ' · € ' + fmt;
  if (warnEl)  warnEl.style.display = hasLav ? 'block' : 'none';
  if (avantiEl) avantiEl.disabled = selCount === 0;
}
</script>

