<script>
function openSalDetail(id) { openModal('modal-sal-' + id); }
function salTab(salId, n) {
  for (var i=1;i<=4;i++) {
    var p=document.getElementById(salId+'-panel-'+i);
    var t=document.getElementById(salId+'-tab-'+i);
    if(p){ p.className='sal-tab-panel'+(i===n?' active':''); }
    if(t){ t.classList.toggle('active',i===n); }
  }
}
var salStatiCfg = {
  pronto:      {label:'Pronto per erogazione', sem:'sem--verde'},
  firma:       {label:'In firma N.O.',          sem:'sem--viola'},
  disponibile: {label:'N.O. disponibile',       sem:'sem--verde'},
  erogato:     {label:'Erogato',                sem:'sem--verde'}
};
function salSetStato(salId, stato, clickedBtn) {
  var cfg = salStatiCfg[stato]; if(!cfg) return;
  var badge = document.getElementById('modal-'+salId+'-stato-badge');
  if(badge){ badge.className='sem '+cfg.sem; badge.innerHTML='<span class="sem__dot"></span>'+cfg.label; }
  document.querySelectorAll('#modal-sal-'+salId+' .sal-stato-btn').forEach(function(b){ b.classList.remove('active'); });
  if(clickedBtn){ clickedBtn.classList.add('active'); }
  else {
    document.querySelectorAll('#modal-sal-'+salId+' .sal-stato-btn').forEach(function(b){
      if(b.textContent.trim()===cfg.label) b.classList.add('active');
    });
  }
}
</script>


<!-- ═══════════════════════════════════════════════════
     MODAL: CREA GRUPPO
═══════════════════════════════════════════════════ -->


<script>


function cgStep(n) {
  for (var i=1; i<=3; i++) {
    var p = document.getElementById('cg-p'+i);
    var s = document.getElementById('cg-s'+i);
    if (p) p.style.display = i===n ? 'block' : 'none';
    if (s) {
      s.classList.remove('is-active','is-done');
      if (i < n) s.classList.add('is-done');
      if (i === n) s.classList.add('is-active');
    }
  }
}

document.addEventListener('DOMContentLoaded', function() {
});
</script>

