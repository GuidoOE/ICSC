<div class="overlay" id="modal-edit-pratica-info">
  <div class="modal modal--lg" style="max-height:92vh">
    <div class="modal__header">
      <div class="modal__title">Modifica anagrafica pratica</div>
      <button class="modal__close" onclick="closeModal('modal-edit-pratica-info')">&#10005;</button>
    </div>
    <div class="modal__body" style="overflow-y:auto">
      <div class="g2" style="gap:14px">
        <div class="field"><label class="field__label">N. Rapporto</label><div class="field__input"><input type="text" id="eap-rapporto" readonly style="background:var(--bg-sec-lighter);color:var(--tx-lighter)"></div></div>
        <div class="field"><label class="field__label">Beneficiario <span style="color:var(--tx-error)">*</span></label><div class="field__input"><input type="text" id="eap-beneficiario"></div></div>
        <div class="field"><label class="field__label">Comune</label><div class="field__input"><input type="text" id="eap-comune"></div></div>
        <div class="field"><label class="field__label">Tipo mutuo</label>
          <select class="field-select" style="width:100%" id="eap-tipo">
            <option value="Ordinario Privato">Ordinario Privato</option>
            <option value="Light Privato">Light Privato</option>
            <option value="Ordinario EELL">Ordinario EELL</option>
          </select>
        </div>
        <div class="field"><label class="field__label">Ambito</label>
          <select class="field-select" style="width:100%" id="eap-ambito">
            <option value="Sport">Sport</option>
            <option value="Cultura">Cultura</option>
          </select>
        </div>
        <div class="field"><label class="field__label">Legge di riferimento</label>
          <select class="field-select" style="width:100%" id="eap-legge">
            <option value="Legge 4101">Legge 4101</option>
            <option value="Legge 1461">Legge 1461</option>
            <option value="Altro">Altro</option>
          </select>
        </div>
        <div class="field"><label class="field__label">Importo deliberato (€)</label><div class="field__input"><input type="text" id="eap-importo" placeholder="0,00"></div></div>
        <div class="field"><label class="field__label">Data stipula</label><div class="field__input"><input type="date" id="eap-stipula"></div></div>
        <div class="field"><label class="field__label">Durata (mesi)</label><div class="field__input"><input type="number" id="eap-durata" min="12" max="360"></div></div>
        <div class="field"><label class="field__label">Inizio ammortamento</label><div class="field__input"><input type="date" id="eap-ammort"></div></div>
        <div class="field"><label class="field__label">Garanzia immobiliare</label>
          <select class="field-select" style="width:100%" id="eap-garanzia">
            <option value="Non prevista">Non prevista</option>
            <option value="Ipoteca di primo grado">Ipoteca di primo grado</option>
            <option value="Fideiussione">Fideiussione</option>
          </select>
        </div>
        <div class="field"><label class="field__label">CUP (solo EELL)</label><div class="field__input"><input type="text" id="eap-cup" placeholder="es. F69D22000940006"></div></div>
        <div class="field" style="grid-column:1/-1"><label class="field__label">Oggetto del finanziamento</label><div class="field__input field__input--area"><textarea id="eap-oggetto" style="min-height:60px"></textarea></div></div>
      </div>
    </div>
    <div class="modal__footer">
      <button class="btn btn--ghost" onclick="closeModal('modal-edit-pratica-info')">Annulla</button>
      <button class="btn btn--primary" onclick="saveEditAnagrafica()">Salva modifiche</button>
    </div>
  </div>
</div>

<!-- ════ MODAL: NUOVO SAL ════ -->
<div class="overlay" id="modal-nuovo-sal">
  <div class="modal modal--lg" style="max-width:900px;max-height:96vh;display:flex;flex-direction:column;padding:0">
    <div class="modal__header" style="flex-shrink:0">
      <div>
        <div class="modal__title">Inserisci nuovo SAL</div>
        <div style="font-size:12px;color:var(--tx-lighter);margin-top:2px" id="sal-modal-sub">Compila i dati, le catene documentali e carica i documenti.</div>
      </div>
      <button class="modal__close" onclick="closeModal('modal-nuovo-sal')">&#10005;</button>
    </div>

    <!-- Step bar -->
    <div style="display:flex;border-bottom:2px solid var(--bd-sec-light);flex-shrink:0;background:var(--bg-sec-lighter);overflow-x:auto">
      <div class="sal-wiz-step is-active" id="sal-ws-1" onclick="salWizStep(1)" style="padding:11px 20px;font-size:12px;font-weight:600;cursor:pointer;color:var(--tx-secondary);border-bottom:3px solid var(--bd-primary);white-space:nowrap;display:flex;align-items:center;gap:6px"><span style="width:18px;height:18px;border-radius:50%;background:var(--bg-primary);color:#fff;font-size:10px;font-weight:700;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0">1</span> Dati SAL</div>
      <div class="sal-wiz-step" id="sal-ws-2" onclick="salWizStep(2)" style="padding:11px 20px;font-size:12px;font-weight:500;cursor:pointer;color:var(--tx-lighter);border-bottom:3px solid transparent;white-space:nowrap;display:flex;align-items:center;gap:6px"><span style="width:18px;height:18px;border-radius:50%;background:var(--bg-sec-light);color:var(--tx-lighter);font-size:10px;font-weight:700;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0" id="sal-ws-2-num">2</span> Catene documentali <span class="tab__count" id="sal-catene-badge">0</span></div>
      <div class="sal-wiz-step" id="sal-ws-3" onclick="salWizStep(3)" style="padding:11px 20px;font-size:12px;font-weight:500;cursor:pointer;color:var(--tx-lighter);border-bottom:3px solid transparent;white-space:nowrap;display:flex;align-items:center;gap:6px"><span style="width:18px;height:18px;border-radius:50%;background:var(--bg-sec-light);color:var(--tx-lighter);font-size:10px;font-weight:700;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0" id="sal-ws-3-num">3</span> Documenti SAL</div>
      <div class="sal-wiz-step" id="sal-ws-4" onclick="salWizStep(4)" style="padding:11px 20px;font-size:12px;font-weight:500;cursor:pointer;color:var(--tx-lighter);border-bottom:3px solid transparent;white-space:nowrap;display:flex;align-items:center;gap:6px"><span style="width:18px;height:18px;border-radius:50%;background:var(--bg-sec-light);color:var(--tx-lighter);font-size:10px;font-weight:700;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0" id="sal-ws-4-num">4</span> Riepilogo</div>
    </div>

    <div style="flex:1;overflow-y:auto">

      <!-- ── STEP 1: Dati SAL ── -->
      <div class="sal-wiz-panel" id="sal-wp-1" style="padding:20px">
        <div id="sal-error" style="display:none;margin-bottom:14px;padding:10px 14px;background:var(--bg-error-lighter);border:1px solid var(--bd-error);border-radius:var(--r-smooth);font-size:12px;color:var(--tx-error)"></div>
        <div class="g2" style="gap:14px">
          <div class="field"><label class="field__label">Tipo richiesta <span style="color:var(--tx-error)">*</span></label>
            <select class="field-select" style="width:100%" id="sal-tipo">
              <option value="SAL intermedio">SAL (intermedio)</option>
              <option value="Saldo finale">Saldo finale</option>
              <option value="Anticipazione">Anticipazione</option>
            </select>
          </div>
          <div class="field"><label class="field__label">Progressivo SAL <span style="color:var(--tx-error)">*</span></label><div class="field__input"><input type="number" id="sal-progr" min="1" value="1"></div></div>
          <div class="field"><label class="field__label">Data presentazione <span style="color:var(--tx-error)">*</span></label><div class="field__input"><input type="date" id="sal-data"></div></div>
          <div class="field"><label class="field__label">Importo richiesto (€) <span style="color:var(--tx-error)">*</span></label><div class="field__input"><input type="text" id="sal-importo" placeholder="0,00"></div></div>
          <div class="field"><label class="field__label">Direttore dei Lavori</label><div class="field__input"><input type="text" id="sal-dl" placeholder="Arch. Mario Rossi"></div></div>
          <div class="field"><label class="field__label">Impresa esecutrice</label><div class="field__input"><input type="text" id="sal-impresa" placeholder="Edilizia Rossi SRL"></div></div>
          <div class="field" style="grid-column:1/-1"><label class="field__label">Oggetto / descrizione lavori</label><div class="field__input field__input--area"><textarea id="sal-oggetto" style="min-height:52px" placeholder="Descrizione delle lavorazioni del SAL…"></textarea></div></div>
          <div class="field" style="grid-column:1/-1"><label class="field__label">Note operative</label><div class="field__input field__input--area"><textarea id="sal-note" style="min-height:36px" placeholder="Note interne…"></textarea></div></div>
        </div>
        <div class="row-sb" style="margin-top:18px">
          <div></div>
          <button class="btn btn--primary btn--sm" onclick="salWizStep(2)">Avanti → Catene documentali</button>
        </div>
      </div>

      <!-- ── STEP 2: Catene documentali ── -->
      <div class="sal-wiz-panel" id="sal-wp-2" style="padding:20px;display:none">
        <div class="notice notice--info" style="margin-bottom:14px;font-size:12px">
          &#128279; Ogni catena collega i 5 elementi del percorso documentale: <strong>Procedura &#8594; Contratto aperto &#8594; Incarico/attingimento &#8594; Fattura &#8594; Pagamento</strong>.<br>
          Aggiungi una catena per ogni titolo di spesa incluso in questo SAL. I campi con &#9679; verde indicano un elemento verificato, &#9679; arancio in attesa.
        </div>

        <div id="sal-catene-container" style="display:flex;flex-direction:column;gap:12px"></div>

        <button class="btn btn--tertiary btn--sm" style="margin-top:12px" onclick="salAddCatena()">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Aggiungi catena documentale
        </button>

        <div class="row-sb" style="margin-top:18px">
          <button class="btn btn--ghost btn--sm" onclick="salWizStep(1)">&#8592; Indietro</button>
          <button class="btn btn--primary btn--sm" onclick="salWizStep(3)">Avanti → Documenti SAL</button>
        </div>
      </div>

      <!-- ── STEP 3: Documenti SAL ── -->
      <div class="sal-wiz-panel" id="sal-wp-3" style="padding:20px;display:none">
        <div class="notice notice--info" style="margin-bottom:14px;font-size:12px">
          Carica i documenti obbligatori del SAL. Potrai aggiungerne altri in seguito dal Fascicolo pratica.
        </div>
        <div id="sal-docs-checklist">
          <div class="upload-doc-row"><span class="upload-doc-row__label">SAL firmato dal Direttore dei Lavori</span><span style="font-size:10px;font-weight:600;padding:2px 6px;border-radius:40px;background:#ffe5e5;color:var(--tx-error);flex-shrink:0">Obbligatorio</span><button class="upload-btn" onclick="salUploadDoc(this,'SAL firmato DL')">&#11014; Carica</button></div>
          <div class="upload-doc-row"><span class="upload-doc-row__label">Certificato di pagamento firmato DL</span><span style="font-size:10px;font-weight:600;padding:2px 6px;border-radius:40px;background:#ffe5e5;color:var(--tx-error);flex-shrink:0">Obbligatorio</span><button class="upload-btn" onclick="salUploadDoc(this,'Cert. pagamento DL')">&#11014; Carica</button></div>
          <div class="upload-doc-row"><span class="upload-doc-row__label">Dichiarazione SAL (modulo ICSC) firmata DL</span><span style="font-size:10px;font-weight:600;padding:2px 6px;border-radius:40px;background:#ffe5e5;color:var(--tx-error);flex-shrink:0">Obbligatorio</span><button class="upload-btn" onclick="salUploadDoc(this,'Dichiarazione SAL ICSC')">&#11014; Carica</button></div>
          <div class="upload-doc-row"><span class="upload-doc-row__label">Fatture relative ai lavori del SAL</span><span style="font-size:10px;font-weight:600;padding:2px 6px;border-radius:40px;background:#ffe5e5;color:var(--tx-error);flex-shrink:0">Obbligatorio</span><button class="upload-btn" onclick="salUploadDoc(this,'Fatture lavori')">&#11014; Carica</button></div>
          <div class="upload-doc-row"><span class="upload-doc-row__label">Bonifici / quietanze di pagamento</span><span style="font-size:10px;font-weight:600;padding:2px 6px;border-radius:40px;background:#ffe5e5;color:var(--tx-error);flex-shrink:0">Obbligatorio</span><button class="upload-btn" onclick="salUploadDoc(this,'Bonifici')">&#11014; Carica</button></div>
          <div class="upload-doc-row"><span class="upload-doc-row__label">DURC in corso di validità</span><span style="font-size:10px;font-weight:600;padding:2px 6px;border-radius:40px;background:#ffe5e5;color:var(--tx-error);flex-shrink:0">Obbligatorio</span><button class="upload-btn" onclick="salUploadDoc(this,'DURC')">&#11014; Carica</button></div>
          <div class="upload-doc-row"><span class="upload-doc-row__label">Parcelle tecniche (se presenti spese tecniche)</span><span style="font-size:10px;font-weight:600;padding:2px 6px;border-radius:40px;background:#fff3e0;color:#92400e;flex-shrink:0">Se applicabile</span><button class="upload-btn" onclick="salUploadDoc(this,'Parcella tecnica')">&#11014; Carica</button></div>
          <div class="upload-doc-row"><span class="upload-doc-row__label">CRE / Collaudo (solo per saldo finale)</span><span style="font-size:10px;font-weight:600;padding:2px 6px;border-radius:40px;background:#fff3e0;color:#92400e;flex-shrink:0">Se applicabile</span><button class="upload-btn" onclick="salUploadDoc(this,'CRE Collaudo')">&#11014; Carica</button></div>
          <div class="upload-doc-row" style="border-bottom:none"><span class="upload-doc-row__label">Parere finale CONI (solo per saldo finale)</span><span style="font-size:10px;font-weight:600;padding:2px 6px;border-radius:40px;background:#fff3e0;color:#92400e;flex-shrink:0">Se applicabile</span><button class="upload-btn" onclick="salUploadDoc(this,'Parere CONI')">&#11014; Carica</button></div>
        </div>
        <input type="file" id="sal-file-input" style="display:none" onchange="salFileSelected(this)">
        <div class="row-sb" style="margin-top:18px">
          <button class="btn btn--ghost btn--sm" onclick="salWizStep(2)">&#8592; Indietro</button>
          <button class="btn btn--primary btn--sm" onclick="salWizStep(4)">Avanti → Riepilogo</button>
        </div>
      </div>

      <!-- ── STEP 4: Riepilogo ── -->
      <div class="sal-wiz-panel" id="sal-wp-4" style="padding:20px;display:none">
        <div class="section-label" style="margin-bottom:14px">Riepilogo SAL da inserire</div>

        <div class="g2" style="gap:14px;margin-bottom:16px">
          <div class="card" style="margin:0">
            <div class="card__header" style="padding:10px 14px"><span class="card__title" style="font-size:13px">Anagrafica SAL</span></div>
            <div class="card__body" style="padding:10px 14px" id="sal-riepilogo-anag"></div>
          </div>
          <div class="card" style="margin:0">
            <div class="card__header" style="padding:10px 14px"><span class="card__title" style="font-size:13px">Documenti caricati</span></div>
            <div class="card__body" style="padding:10px 14px;font-size:13px;line-height:2" id="sal-riepilogo-docs"></div>
          </div>
        </div>

        <div class="card" style="margin-bottom:14px">
          <div class="card__header" style="padding:10px 14px">
            <span class="card__title" style="font-size:13px">Catene documentali che verranno create</span>
            <span class="badge badge--gray" id="sal-riepilogo-catene-badge">0 catene</span>
          </div>
          <div class="card__body-0">
            <div style="overflow-x:auto">
              <table style="width:100%;border-collapse:collapse;font-size:12px" id="sal-riepilogo-catene-tbl">
                <thead>
                  <tr style="background:var(--bg-sec-lighter)">
                    <th style="padding:7px 12px;text-align:left;font-weight:700;color:var(--tx-lighter);font-size:10px;text-transform:uppercase">Procedura</th>
                    <th style="padding:7px 12px;text-align:left;font-weight:700;color:var(--tx-lighter);font-size:10px;text-transform:uppercase">Contratto aperto</th>
                    <th style="padding:7px 12px;text-align:left;font-weight:700;color:var(--tx-lighter);font-size:10px;text-transform:uppercase">Incarico / attingimento</th>
                    <th style="padding:7px 12px;text-align:left;font-weight:700;color:var(--tx-lighter);font-size:10px;text-transform:uppercase">Fattura</th>
                    <th style="padding:7px 12px;text-align:left;font-weight:700;color:var(--tx-lighter);font-size:10px;text-transform:uppercase">Pagamento</th>
                    <th style="padding:7px 12px;text-align:right;font-weight:700;color:var(--tx-lighter);font-size:10px;text-transform:uppercase">Imp. inerente</th>
                    <th style="padding:7px 12px;text-align:right;font-weight:700;color:var(--tx-lighter);font-size:10px;text-transform:uppercase">Imp. rendicontabile</th>
                  </tr>
                </thead>
                <tbody id="sal-riepilogo-catene-tbody"></tbody>
              </table>
            </div>
          </div>
        </div>

        <div class="notice notice--info" style="margin-bottom:16px;font-size:12px">
          &#128204; Confermando, le catene verranno aggiunte nel tab <strong>Controllo eleggibilità</strong> con stato <em>da lavorare</em>.
        </div>

        <div class="row-sb">
          <button class="btn btn--ghost btn--sm" onclick="salWizStep(3)">&#8592; Indietro</button>
          <div class="row gap-8">
            <button class="btn btn--tertiary btn--sm" onclick="doSaveSAL(true)">Salva bozza</button>
            <button class="btn btn--primary btn--sm" id="sal-submit-btn" onclick="doSaveSAL(false)">&#10003; Conferma e inserisci SAL</button>
          </div>
        </div>
      </div>

    </div><!-- /scroll -->
  </div>
</div>


