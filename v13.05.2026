<script>
function d1tab(n) {
  for(var i=1;i<=6;i++){
    document.getElementById('d1p'+i).style.display = i===n?'block':'none';
    var t=document.getElementById('d1t'+i);
    t.style.fontWeight=i===n?'600':'500';
    t.style.color=i===n?'var(--tx-secondary)':'var(--tx-lighter)';
    t.style.borderBottomColor=i===n?'var(--bd-primary)':'transparent';
  }
}
function d2tab(n) {
  for(var i=1;i<=6;i++){
    document.getElementById('d2p'+i).style.display = i===n?'block':'none';
    var t=document.getElementById('d2t'+i);
    t.style.fontWeight=i===n?'600':'500';
    t.style.color=i===n?'var(--tx-secondary)':'var(--tx-lighter)';
    t.style.borderBottomColor=i===n?'var(--bd-primary)':'transparent';
  }
}

/* ── QE3: Quadro economico personalizzabile ── */
function qe3DelCol(colIdx) {
  var ths = document.querySelectorAll('#qe3-thead-row th[data-col-idx]');
  var absIdx = -1;
  var allThs = document.querySelectorAll('#qe3-thead-row th');
  allThs.forEach(function(th,i){
    if(parseInt(th.getAttribute('data-col-idx'))===colIdx) absIdx=i;
  });
  if(absIdx<0) return;
  allThs[absIdx].remove();
  document.querySelectorAll('#qe3-tbody tr').forEach(function(tr){
    if(tr.cells[absIdx]) tr.cells[absIdx].remove();
  });
  document.querySelectorAll('#qe3-tbl tfoot tr').forEach(function(tr){
    if(tr.cells[absIdx]) tr.cells[absIdx].remove();
  });
  qe3Calc();
}
function qe3EditFormula(th) {
  var cur = th.getAttribute('data-formula')||'';
  var f = prompt('Formula per questa colonna (usa col0, col1, col2 per le colonne):\nEs: col2*col3/100  =  Costo approvato x Intensita / 100', cur);
  if(f===null) return;
  th.setAttribute('data-formula',f);
  qe3Calc();
}
function qe3p(v){ return parseFloat((v||'0').replace(/[.]/g,'').replace(',','.')) || 0; }
function qe3f(n){ return n.toLocaleString('it-IT',{minimumFractionDigits:2,maximumFractionDigits:2}); }
function qe3Calc() {
  var rows = document.querySelectorAll('#qe3-tbody tr');
  var tots = [0,0,0];
  var totContr = 0;
  rows.forEach(function(tr) {
    var inputs = Array.from(tr.querySelectorAll('input.qe3-input'));
    var editables = inputs.filter(function(i){ return !i.readOnly; });
    var readonly = inputs.filter(function(i){ return i.readOnly; });
    if (!editables.length) return;
    var vals = editables.map(function(c){ return qe3p(c.value); });
    var appr = vals[2] || 0;
    var intens = vals[3] !== undefined ? vals[3] : 50;
    var contr = appr * intens / 100;
    if (readonly.length) readonly[readonly.length-1].value = qe3f(contr);
    tots[0] += vals[0]||0; tots[1] += vals[1]||0; tots[2] += vals[2]||0;
    totContr += contr;
  });
  var t0=document.getElementById('qe3-tot-0'); if(t0) t0.value=qe3f(tots[0]);
  var t1=document.getElementById('qe3-tot-1'); if(t1) t1.value=qe3f(tots[1]);
  var t2=document.getElementById('qe3-tot-2'); if(t2) t2.value=qe3f(tots[2]);
  var tc=document.getElementById('qe3-tot-contr'); if(tc) tc.value=qe3f(totContr);
}
function qe3AddRow() {
  var tbody=document.getElementById('qe3-tbody'); if(!tbody) return;
  var tr=document.createElement('tr');
  var cols=document.querySelectorAll('#qe3-thead-row th').length-2;
  var html='<td><input class="qe3-voce-input" placeholder="Nuova voce..."></td>';
  for(var i=0;i<cols-1;i++){
    var last=i===cols-2;
    html+='<td><input class="qe3-input'+(last?' ro':'')+'" type="text" value="0,00"'+(last?' readonly tabindex="-1"':' oninput="qe3Calc()"')+'></td>';
  }
  html+='<td style="padding:0 4px"><button class="qe3-del-btn" onclick="qe3DelRow(this)">x</button></td>';
  tr.innerHTML=html; tbody.appendChild(tr);
}
function qe3DelRow(btn){ btn.closest('tr').remove(); qe3Calc(); }
function qe3AddCol() {
  var theadRow=document.getElementById('qe3-thead-row');
  var addColTh=theadRow.querySelector('th:last-child');
  var newTh=document.createElement('th'); newTh.className='r';
  newTh.innerHTML='<input class="qe3-col-input" value="Nuova colonna" style="text-align:right">';
  theadRow.insertBefore(newTh,addColTh);
  document.querySelectorAll('#qe3-tbody tr').forEach(function(tr){
    var del=tr.querySelector('td:last-child');
    var td=document.createElement('td');
    td.innerHTML='<input class="qe3-input" type="text" value="0,00" oninput="qe3Calc()">';
    tr.insertBefore(td,del);
  });
  document.querySelectorAll('#qe3-tbl tfoot tr').forEach(function(tr){
    var last=tr.querySelector('td:last-child');
    var td=document.createElement('td');
    td.innerHTML='<input class="qe3-input ro" type="text" value="0,00" readonly tabindex="-1">';
    tr.insertBefore(td,last);
  });
}
/* ── PREV3: Preventivo di spesa personalizzabile ── */
function prev3p(v){ return parseFloat((v||'0').replace(/[.]/g,'').replace(',','.')) || 0; }
function prev3f(n){ return n.toLocaleString('it-IT',{minimumFractionDigits:2,maximumFractionDigits:2}); }
function prev3Calc() {
  var rows=document.querySelectorAll('#prev3-tbody tr');
  var totS=0,totE=0;
  rows.forEach(function(tr){
    var editable=Array.from(tr.querySelectorAll('input.prev3-input:not(.ro)'));
    if(editable.length<2) return;
    var s=prev3p(editable[0].value),e=prev3p(editable[1].value),r=s-e;
    var ro=tr.querySelector('input.prev3-input.ro');
    if(ro){ro.value=prev3f(r);ro.style.color=r>0?'var(--tx-warning)':r<0?'var(--tx-error)':'var(--tx-lighter)';ro.style.fontWeight=r!==0?'700':'400';}
    totS+=s;totE+=e;
  });
  var ts=document.getElementById('prev3-tot-stanz'); if(ts) ts.value=prev3f(totS);
  var te=document.getElementById('prev3-tot-erog');  if(te) te.value=prev3f(totE);
  var tr2=document.getElementById('prev3-tot-resid');
  if(tr2){var r2=totS-totE;tr2.value=prev3f(r2);tr2.style.color=r2>0?'var(--tx-warning)':r2<0?'var(--tx-error)':'var(--tx-lighter)';tr2.style.fontWeight=r2!==0?'700':'400';}
}
function prev3AddRow(){
  var tbody=document.getElementById('prev3-tbody'); if(!tbody) return;
  var tr=document.createElement('tr');
  var cols=document.querySelectorAll('#prev3-thead-row th').length-2;
  var cls=['td-stanz','td-erog','td-resid','td-custom'];
  var html='<td><input class="prev3-voce-input" placeholder="Nuova voce..."></td>';
  for(var i=0;i<cols-1;i++){
    var isRo=i===cols-2;
    html+='<td class="'+(cls[i]||'td-custom')+'"><input class="prev3-input'+(isRo?' ro':'')+'" type="text" value="0,00"'+(isRo?' readonly tabindex="-1"':' oninput="prev3Calc()"')+'></td>';
  }
  html+='<td style="padding:0 4px"><button class="qe3-del-btn" onclick="prev3DelRow(this)">x</button></td>';
  tr.innerHTML=html; tbody.appendChild(tr);
}
function prev3DelRow(btn){btn.closest('tr').remove();prev3Calc();}
function prev3AddCol(){
  var theadRow=document.getElementById('prev3-thead-row');
  var addColTh=theadRow.querySelector('th:last-child');
  var newTh=document.createElement('th'); newTh.className='hd-custom';
  newTh.innerHTML='<input class="prev3-col-input" value="Nuova colonna" style="text-align:right;color:#4400b3">';
  theadRow.insertBefore(newTh,addColTh);
  document.querySelectorAll('#prev3-tbody tr').forEach(function(tr){
    var del=tr.querySelector('td:last-child');
    var td=document.createElement('td'); td.className='td-custom';
    td.innerHTML='<input class="prev3-input" type="text" value="0,00" oninput="prev3Calc()">';
    tr.insertBefore(td,del);
  });
  document.querySelectorAll('#prev3-tbl tfoot tr').forEach(function(tr){
    var last=tr.querySelector('td:last-child');
    var td=document.createElement('td'); td.className='td-custom';
    td.innerHTML='<input class="prev3-input ro" type="text" value="0,00" readonly tabindex="-1">';
    tr.insertBefore(td,last);
  });
}
/* ── Collegamento documenti ── */
var _insLinkCount=2;
function insAddLink(){
  _insLinkCount++;
  var container=document.getElementById('ins-links-container'); if(!container) return;
  var div=document.createElement('div'); div.className='ins-link-row';
  div.innerHTML='<div style="display:flex;align-items:center;gap:8px;padding:10px 14px;border-top:1px solid var(--bd-sec-light);flex-wrap:wrap">'
    +'<span style="font-size:11px;font-weight:600;color:var(--tx-lighter)">Catena '+_insLinkCount+'</span>'
    +'<div style="display:flex;align-items:center;gap:6px;flex:1;flex-wrap:wrap">'
    +'<select class="field-select" style="height:30px;font-size:12px;min-width:130px"><option value="">-- Procedura --</option><option>ICSC-5978-001</option></select>'
    +'<span style="color:var(--tx-lighter)">&#8594;</span>'
    +'<select class="field-select" style="height:30px;font-size:12px;min-width:130px"><option value="">-- Contratto --</option><option>CT-2024-001</option></select>'
    +'<span style="color:var(--tx-lighter)">&#8594;</span>'
    +'<select class="field-select" style="height:30px;font-size:12px;min-width:130px"><option value="">-- Fattura --</option><option>FAT-31/2025</option><option>FAT-PF-012/2025</option></select>'
    +'<span style="color:var(--tx-lighter)">&#8594;</span>'
    +'<select class="field-select" style="height:30px;font-size:12px;min-width:130px"><option value="">-- Pagamento --</option><option>PAG-2025-031</option></select>'
    +'</div>'
    +'<span class="sem sem--grigio" style="font-size:10px;padding:2px 8px;flex-shrink:0"><span class="sem__dot"></span>Da completare</span>'
    +'<button class="qe3-del-btn" onclick="this.closest(\'.ins-link-row\').remove()">x</button>'
    +'</div>';
  container.appendChild(div);
}
</script>




