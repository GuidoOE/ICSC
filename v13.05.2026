<!DOCTYPE html>
<html lang="it" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sonar — Riscontro Tecnico · ICSC</title>
<link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible+Next:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
/* ═══════════════════════════════════════════════════
   DS TOKENS
═══════════════════════════════════════════════════ */
:root {
  /* Background */
  --bg-primary:        #4400b3;
  --bg-primary-hover:  #340088;
  --bg-primary-active: #270065;
  --bg-primary-light:  #efe5ff;
  --bg-emphasis:       #6e1aff;
  --bg-secondary:      #545454;
  --bg-sec-dark:       #2c2c2c;
  --bg-sec-light:      #e7e7e7;
  --bg-sec-lighter:    #f1f1f1;
  --bg-accent:         #b9ff69;
  --bg-inverse:        #ffffff;
  --bg-disable:        #e7e7e7;
  --bg-success:        #007840;
  --bg-success-light:  #c9ffe6;
  --bg-success-lighter:#defff0;
  --bg-warning:        #ca8600;
  --bg-warning-lighter:#ffeecc;
  --bg-error:          #cc0000;
  --bg-error-lighter:  #ffe5e5;
  /* Text */
  --tx-primary:        #000000;
  --tx-light:          #545454;
  --tx-lighter:        #6e6e6e;
  --tx-secondary:      #4400b3;
  --tx-sec-light:      #6e1aff;
  --tx-inverse:        #ffffff;
  --tx-disable:        #999999;
  --tx-success:        #007840;
  --tx-warning:        #ca8600;
  --tx-error:          #cc0000;
  /* Border */
  --bd-primary:        #4400b3;
  --bd-prim-light:     #6e1aff;
  --bd-secondary:      #545454;
  --bd-sec-light:      #e7e7e7;
  --bd-focus:          #0000ff;
  --bd-success:        #007840;
  --bd-warning:        #ca8600;
  --bd-error:          #cc0000;
  /* Spacing */
  --sp-xxs: 4px;  --sp-xs: 8px;  --sp-s: 16px;
  --sp-m: 24px;   --sp-l: 32px;  --sp-xl: 40px;
  /* Radius */
  --r-smooth: 2px;  --r-rounded: 40px;  --r-circle: 80px;
  /* Border width */
  --bw-base: 1px;  --bw-double: 2px;  --bw-thick: 4px;
  /* Font */
  --ff-body: "Atkinson Hyperlegible Next", sans-serif;
  --ff-mono: "Atkinson Hyperlegible Next", monospace;
}

/* ═══════════════════════════════════════════════════
   RESET & BASE
═══════════════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; overflow: hidden; }
body { font-family: var(--ff-body); font-size: 14px; color: var(--tx-primary); background: var(--bg-sec-light); }

/* ═══════════════════════════════════════════════════
   LOGIN SCREEN
═══════════════════════════════════════════════════ */
.login-screen {
  position: fixed; inset: 0; z-index: 1000;
  display: flex; align-items: stretch;
  background: var(--bg-inverse);
}
.login-screen.is-hidden { display: none; }

/* Left panel — brand */
.login-brand {
  width: 44%; background: var(--bg-primary);
  display: flex; flex-direction: column;
  align-items: flex-start; justify-content: space-between;
  padding: 48px 52px;
  position: relative; overflow: hidden;
}
.login-brand::after {
  content: ''; position: absolute;
  bottom: -80px; right: -80px;
  width: 400px; height: 400px;
  border-radius: 50%;
  background: rgba(110,26,255,.25);
  pointer-events: none;
}
.login-brand__logo { display: flex; align-items: center; gap: 12px; }
.login-brand__mark {
  width: 36px; height: 36px; background: var(--bg-accent);
  border-radius: var(--r-smooth);
  display: flex; align-items: center; justify-content: center;
}
.login-brand__mark svg { width: 18px; height: 18px; fill: var(--bg-primary); }
.login-brand__name { font-size: 22px; font-weight: 700; color: #fff; letter-spacing: -.01em; }
.login-brand__tagline { color: rgba(255,255,255,.65); font-size: 13px; margin-top: 2px; }
.login-brand__body { flex: 1; display: flex; flex-direction: column; justify-content: center; padding: 40px 0; }
.login-brand__headline {
  font-size: 36px; font-weight: 700; color: #fff;
  line-height: 1.1; margin-bottom: 20px;
}
.login-brand__headline em { color: var(--bg-accent); font-style: normal; }
.login-brand__desc { font-size: 15px; color: rgba(255,255,255,.7); line-height: 1.6; max-width: 340px; }
.login-brand__pills { display: flex; gap: 8px; margin-top: 28px; flex-wrap: wrap; }
.login-brand__pill {
  background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.2);
  border-radius: var(--r-rounded); padding: 4px 12px;
  font-size: 11px; font-weight: 500; color: rgba(255,255,255,.85);
}
.login-brand__footer { font-size: 11px; color: rgba(255,255,255,.4); }

/* Right panel — form */
.login-form-wrap {
  flex: 1; display: flex; align-items: center; justify-content: center;
  padding: 48px;
  background: var(--bg-inverse);
}
.login-form {
  width: 100%; max-width: 380px;
  display: flex; flex-direction: column; gap: 0;
}
.login-form__header { margin-bottom: 36px; }
.login-form__title { font-size: 26px; font-weight: 700; color: var(--tx-primary); }
.login-form__sub { font-size: 14px; color: var(--tx-lighter); margin-top: 6px; }
.login-form__group { display: flex; flex-direction: column; gap: 5px; margin-bottom: 18px; }
.login-form__label { font-size: 12px; font-weight: 700; color: var(--tx-primary); }
.login-form__input {
  height: 44px; border: 1.5px solid var(--bd-sec-light);
  border-radius: var(--r-smooth); background: var(--bg-inverse);
  padding: 0 14px; font-family: var(--ff-body); font-size: 14px;
  color: var(--tx-primary); outline: none; transition: all .15s;
  width: 100%;
}
.login-form__input:focus {
  border-color: var(--bd-primary);
  box-shadow: 0 0 0 3px var(--bg-primary-light);
}
.login-form__input::placeholder { color: var(--tx-disable); }
.login-form__forgot { font-size: 12px; color: var(--tx-secondary); cursor: pointer; text-align: right; margin-top: -12px; margin-bottom: 18px; }
.login-form__forgot:hover { text-decoration: underline; }
.login-form__submit {
  height: 46px; background: var(--bg-primary); color: #fff;
  border: none; border-radius: var(--r-smooth);
  font-family: var(--ff-body); font-size: 14px; font-weight: 700;
  cursor: pointer; transition: background .15s; width: 100%;
  display: flex; align-items: center; justify-content: center; gap: 8px;
}
.login-form__submit:hover { background: var(--bg-primary-hover); }
.login-form__submit svg { width: 16px; height: 16px; stroke: #fff; fill: none; stroke-width: 2; }
.login-form__divider { display: flex; align-items: center; gap: 12px; margin: 20px 0; }
.login-form__divider::before, .login-form__divider::after { content: ''; flex: 1; height: 1px; background: var(--bd-sec-light); }
.login-form__divider span { font-size: 12px; color: var(--tx-disable); }
.login-form__sso {
  height: 44px; background: var(--bg-sec-lighter);
  border: 1.5px solid var(--bd-sec-light); border-radius: var(--r-smooth);
  font-family: var(--ff-body); font-size: 13px; font-weight: 500;
  color: var(--tx-light); cursor: pointer; transition: all .15s; width: 100%;
  display: flex; align-items: center; justify-content: center; gap: 8px;
}
.login-form__sso:hover { border-color: var(--bd-primary); color: var(--tx-secondary); background: var(--bg-primary-light); }
.login-form__footer { margin-top: 32px; text-align: center; font-size: 11px; color: var(--tx-disable); }
.login-error {
  background: var(--bg-error-lighter); border: 1px solid var(--bd-error);
  border-radius: var(--r-smooth); padding: 10px 14px;
  font-size: 12px; color: var(--tx-error);
  margin-bottom: 16px; display: none;
}
.login-error.is-visible { display: block; }
a { text-decoration: none; color: inherit; }
button { cursor: pointer; font-family: var(--ff-body); }
input, textarea, select { font-family: var(--ff-body); }

/* ── Pulsante NUOVA PRATICA (stile Sonar) ── */
.btn-nuovo-progetto {
  display: inline-flex; align-items: center; gap: 7px;
  height: 40px; padding: 0 20px;
  background: var(--bg-emphasis); color: #fff;
  border: none; border-radius: var(--r-rounded);
  font-family: var(--ff-body); font-size: 13px; font-weight: 700;
  letter-spacing: .04em; cursor: pointer;
  transition: background .12s, box-shadow .12s;
  white-space: nowrap; flex-shrink: 0;
}
.btn-nuovo-progetto:hover { background: var(--bg-primary); box-shadow: 0 3px 12px rgba(110,26,255,.35); }
.btn-nuovo-progetto svg { stroke: #fff; }

/* ── Matitina modifica pratica ── */
.btn-edit-pratica {
  width: 28px; height: 28px; border-radius: var(--r-smooth);
  border: 1.5px solid var(--bd-prim-light);
  background: var(--bg-primary-light); color: var(--tx-secondary);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; flex-shrink: 0;
  transition: all .12s;
}
.btn-edit-pratica:hover { background: var(--bg-emphasis); border-color: var(--bg-emphasis); }
.btn-edit-pratica:hover svg { stroke: #fff; }

/* ═══════════════════════════════════════════════════
   APP SHELL
═══════════════════════════════════════════════════ */
.shell          { display: flex; flex-direction: column; height: 100vh; overflow: hidden; }
.shell__nav     { flex-shrink: 0; height: 64px; background: var(--bg-inverse); border-bottom: 1px solid var(--bd-sec-light); display: flex; align-items: center; padding: 0 20px; gap: 16px; z-index: 100; }
.shell__accent  { flex-shrink: 0; height: 4px; background: var(--bg-accent); }
.shell__body    { flex: 1; display: flex; overflow: hidden; }
.shell__sidebar { flex-shrink: 0; width: 244px; background: var(--bg-inverse); border-right: var(--bw-double) solid var(--bd-sec-light); display: flex; flex-direction: column; overflow-y: auto; overflow-x: hidden; transition: width .2s ease; }
.shell__sidebar.is-collapsed { width: 60px; }
.shell__main    { flex: 1; overflow-y: auto; min-width: 0; }

/* ═══════════════════════════════════════════════════
   TOP NAV
═══════════════════════════════════════════════════ */
.nav-logo        { display: flex; align-items: center; gap: 8px; font-size: 17px; font-weight: 700; flex-shrink: 0; }
.nav-logo__mark  { width: 22px; height: 22px; background: var(--bg-primary); border-radius: var(--r-smooth); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.nav-logo__mark svg { width: 12px; height: 12px; fill: white; }
.nav-search      { flex: 1; max-width: 420px; display: flex; align-items: center; height: 36px; border: 1px solid var(--bd-sec-light); border-radius: var(--r-smooth); background: var(--bg-sec-lighter); padding: 0 10px; gap: 8px; transition: border-color .15s; }
.nav-search:focus-within { border-color: var(--bd-primary); background: var(--bg-inverse); box-shadow: 0 0 0 3px var(--bg-primary-light); }
.nav-search input { flex: 1; border: none; outline: none; background: transparent; font-size: 13px; color: var(--tx-lighter); }
.nav-search input:not(:placeholder-shown) { color: var(--tx-primary); }
.nav-right       { margin-left: auto; display: flex; align-items: center; gap: 4px; }
.nav-ico         { width: 34px; height: 34px; border: none; background: transparent; border-radius: var(--r-smooth); display: flex; align-items: center; justify-content: center; color: var(--tx-light); transition: background .12s; }
.nav-ico:hover   { background: var(--bg-sec-lighter); }
.nav-ico svg     { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 1.8; }
.nav-user        { display: flex; align-items: center; gap: 7px; padding: 4px 8px; border-radius: var(--r-smooth); cursor: pointer; }
.nav-user:hover  { background: var(--bg-sec-lighter); }
.nav-avatar      { width: 28px; height: 28px; border-radius: var(--r-circle); background: var(--bg-primary); color: #fff; font-size: 10px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.nav-username    { font-size: 13px; color: var(--tx-primary); }
.nav-role        { font-size: 11px; color: var(--tx-lighter); }

/* ═══════════════════════════════════════════════════
   SIDEBAR
═══════════════════════════════════════════════════ */
.sb-section      { font-size: 10px; font-weight: 500; color: var(--tx-lighter); text-transform: uppercase; letter-spacing: .08em; padding: 14px 16px 4px; border-top: 1px solid var(--bd-sec-light); flex-shrink: 0; }
.sb-section:first-child { border-top: none; }
.sb-item         { display: flex; align-items: center; height: 46px; padding: 0 14px; gap: 9px; cursor: pointer; border-left: 3px solid transparent; transition: all .12s; white-space: nowrap; overflow: hidden; }
.sb-item:hover   { background: var(--bg-sec-lighter); }
.sb-item.is-active { background: var(--bg-primary-light); border-left-color: var(--bg-primary); }
.sb-item.is-active .sb-label { color: var(--tx-secondary); font-weight: 500; }
.sb-item.is-active .sb-icon  { color: var(--tx-secondary); }
.sb-icon         { width: 18px; height: 18px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; color: var(--tx-light); }
.sb-icon svg     { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 1.8; }
.sb-label        { font-size: 13px; color: var(--tx-primary); flex: 1; overflow: hidden; text-overflow: ellipsis; }
.sb-badge        { flex-shrink: 0; font-size: 10px; font-weight: 700; background: var(--bg-primary-light); color: var(--tx-secondary); border-radius: var(--r-rounded); padding: 1px 6px; }
.sb-sub-item     { padding-left: 38px; height: 40px; }
.sb-sub-label    { font-size: 12px; }
.sb-resize       { height: 48px; display: flex; align-items: center; justify-content: flex-end; padding: 0 14px; margin-top: auto; border-top: 1px solid var(--bd-sec-light); cursor: pointer; flex-shrink: 0; }
.sb-resize:hover .sb-resize-lbl { color: var(--tx-secondary); }
.sb-resize-lbl   { font-size: 12px; color: var(--tx-lighter); display: flex; align-items: center; gap: 4px; }
.sb-resize-lbl svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 2; }
.shell__sidebar.is-collapsed .sb-section,
.shell__sidebar.is-collapsed .sb-label,
.shell__sidebar.is-collapsed .sb-badge,
.shell__sidebar.is-collapsed .sb-resize-lbl span { display: none; }
.shell__sidebar.is-collapsed .sb-item { justify-content: center; padding: 0; border-left: none; border-bottom: none; }
.shell__sidebar.is-collapsed .sb-item.is-active { background: var(--bg-primary-light); border-radius: var(--r-smooth); margin: 2px 4px; }
.shell__sidebar.is-collapsed .sb-resize { justify-content: center; padding: 0; }

/* ═══════════════════════════════════════════════════
   PAGE LAYOUT
═══════════════════════════════════════════════════ */
.page            { display: none; }
.page.is-visible { display: block; }

/* Page header */
.pghdr           { background: var(--bg-inverse); border-bottom: 1px solid var(--bd-sec-light); padding: 18px 28px; display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; }
.pghdr__left {}
.breadcrumb      { font-size: 11px; color: var(--tx-lighter); margin-bottom: 4px; display: flex; align-items: center; gap: 4px; }
.breadcrumb a    { color: var(--tx-secondary); cursor: pointer; }
.breadcrumb a:hover { text-decoration: underline; }
.pgtitle         { font-size: 20px; font-weight: 700; line-height: 1.15; color: var(--tx-primary); }
.pgmeta          { display: flex; align-items: center; gap: 8px; margin-top: 6px; flex-wrap: wrap; }
.pghdr__actions  { display: flex; gap: 8px; flex-shrink: 0; align-items: flex-start; padding-top: 2px; }

/* Tabs bar */
.tabs            { background: var(--bg-inverse); border-bottom: 2px solid var(--bd-sec-light); padding: 0 28px; display: flex; gap: 0; overflow-x: auto; -ms-overflow-style: none; scrollbar-width: none; }
.tabs::-webkit-scrollbar { display: none; }
.tab             { display: flex; align-items: center; gap: 5px; padding: 11px 18px; font-size: 13px; font-weight: 500; cursor: pointer; color: var(--tx-lighter); border-bottom: 3px solid transparent; white-space: nowrap; transition: all .12s; position: relative; top: 2px; flex-shrink: 0; }
.tab:hover       { color: var(--tx-primary); }
.tab.is-active   { color: var(--tx-secondary); border-bottom-color: var(--bd-primary); }
.tab__count      { font-size: 10px; font-weight: 700; background: var(--bg-primary-light); color: var(--tx-secondary); border-radius: var(--r-rounded); padding: 1px 5px; }
.tab__new        { font-size: 9px; font-weight: 700; background: #fff3e0; color: #c45000; border-radius: var(--r-rounded); padding: 1px 5px; text-transform: uppercase; letter-spacing: .02em; }

/* Tab panels */
.panel           { display: none; padding: 24px 28px; }
.panel.is-active { display: block; }

/* ═══════════════════════════════════════════════════
   GRID UTILITIES
═══════════════════════════════════════════════════ */
.g2  { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.g3  { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; }
.g4  { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
.gs  { display: grid; grid-template-columns: 1fr 256px; gap: 20px; }  /* main+side */
.gsc { display: grid; grid-template-columns: 1fr 220px; gap: 20px; }
.span-full { grid-column: 1 / -1; }
.stack   { display: flex; flex-direction: column; gap: 20px; }
.stack-s { display: flex; flex-direction: column; gap: 12px; }
.row     { display: flex; align-items: center; gap: 8px; }
.row-sb  { display: flex; align-items: center; justify-content: space-between; gap: 8px; }

/* ═══════════════════════════════════════════════════
   CARD
═══════════════════════════════════════════════════ */
.card          { background: var(--bg-inverse); border-radius: var(--r-smooth); border: 1px solid var(--bd-sec-light); overflow: hidden; }
.card__header  { padding: 14px 20px; border-bottom: 1px solid var(--bd-sec-light); display: flex; align-items: center; justify-content: space-between; gap: 8px; flex-wrap: wrap; }
.card__title   { font-size: 14px; font-weight: 700; color: var(--tx-primary); }
.card__body    { padding: 20px; }
.card__body-0  { padding: 0; }
.card__footer  { padding: 12px 20px; border-top: 1px solid var(--bd-sec-light); background: var(--bg-sec-lighter); }

/* Card con bordo top accent */
.card--accent-top   { border-top: var(--bw-thick) solid var(--bd-prim-light); }
.card--accent-green { border-top: var(--bw-thick) solid var(--bd-success); }
.card--accent-amber { border-top: var(--bw-thick) solid var(--bd-warning); }
.card--accent-red   { border-top: var(--bw-thick) solid var(--bd-error); }

/* ═══════════════════════════════════════════════════
   KPI CARD
═══════════════════════════════════════════════════ */
.kpi           { background: var(--bg-inverse); border-radius: var(--r-smooth); border: 1px solid var(--bd-sec-light); padding: 16px 18px; display: flex; flex-direction: column; gap: 5px; }
.kpi--primary  { border-top: var(--bw-thick) solid var(--bg-primary); }
.kpi--success  { border-top: var(--bw-thick) solid var(--bg-success); }
.kpi--warning  { border-top: var(--bw-thick) solid var(--bg-warning); }
.kpi--error    { border-top: var(--bw-thick) solid var(--bg-error); }
.kpi__label    { font-size: 11px; font-weight: 500; color: var(--tx-lighter); text-transform: uppercase; letter-spacing: .05em; }
.kpi__value    { font-family: var(--ff-mono); font-size: 26px; font-weight: 700; line-height: 1.1; color: var(--tx-primary); }
.kpi__value--sm { font-size: 20px; }
.kpi__sub      { font-size: 12px; color: var(--tx-lighter); }
.kpi__bar      { height: 5px; background: var(--bg-sec-light); border-radius: var(--r-smooth); overflow: hidden; margin-top: 4px; }
.kpi__bar-fill { height: 100%; border-radius: var(--r-smooth); }

/* ═══════════════════════════════════════════════════
   SEMAFORI
═══════════════════════════════════════════════════ */
.sem           { display: inline-flex; align-items: center; gap: 5px; font-size: 11px; font-weight: 500; padding: 3px 9px; border-radius: var(--r-rounded); flex-shrink: 0; }
.sem__dot      { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
.sem--verde    { background: var(--bg-success-lighter); color: var(--tx-success); }
.sem--verde .sem__dot    { background: var(--bg-success); }
.sem--arancio  { background: var(--bg-warning-lighter); color: var(--tx-warning); }
.sem--arancio .sem__dot  { background: var(--bg-warning); }
.sem--rosso    { background: var(--bg-error-lighter); color: var(--tx-error); }
.sem--rosso .sem__dot    { background: var(--bg-error); }
.sem--grigio   { background: var(--bg-sec-light); color: var(--tx-lighter); }
.sem--grigio .sem__dot   { background: var(--tx-disable); }
.sem--viola    { background: var(--bg-primary-light); color: var(--tx-secondary); }
.sem--viola .sem__dot    { background: var(--bg-primary); }

/* ═══════════════════════════════════════════════════
   BADGE / TAG / PILL
═══════════════════════════════════════════════════ */
.badge         { display: inline-flex; align-items: center; gap: 3px; font-size: 11px; font-weight: 500; padding: 2px 8px; border-radius: var(--r-rounded); }
.badge--violet { background: var(--bg-primary-light); color: var(--tx-secondary); }
.badge--green  { background: var(--bg-success-lighter); color: var(--tx-success); }
.badge--amber  { background: var(--bg-warning-lighter); color: var(--tx-warning); }
.badge--blue   { background: #e3f2fd; color: #1565c0; }
.badge--gray   { background: var(--bg-sec-light); color: var(--tx-lighter); }

.tag           { display: inline-flex; align-items: center; font-size: 11px; font-weight: 500; padding: 2px 7px; border-radius: var(--r-rounded); }
.tag--sal      { background: #dbeafe; color: #1e40af; }
.tag--saldo    { background: var(--bg-primary-light); color: var(--tx-secondary); }
.tag--ant      { background: #fef3c7; color: #92400e; }
.tag--eell     { background: #e0f2fe; color: #075985; }
.tag--doc      { background: var(--bg-warning-lighter); color: var(--tx-warning); }
.tag--pec      { background: var(--bg-success-lighter); color: var(--tx-success); }

/* ═══════════════════════════════════════════════════
   BUTTONS
═══════════════════════════════════════════════════ */
.btn           { display: inline-flex; align-items: center; justify-content: center; gap: 5px; height: 38px; padding: 0 14px; font-family: var(--ff-body); font-size: 13px; font-weight: 500; border-radius: var(--r-smooth); border: var(--bw-double) solid transparent; cursor: pointer; transition: all .12s; white-space: nowrap; line-height: 1; }
.btn:focus-visible { outline: none; box-shadow: 0 0 0 3px var(--bd-focus); }
.btn--primary  { background: var(--bg-primary); color: #fff; }
.btn--primary:hover  { background: var(--bg-primary-hover); }
.btn--secondary{ background: var(--bg-secondary); color: #fff; }
.btn--secondary:hover{ background: var(--bg-sec-dark); }
.btn--tertiary { background: transparent; color: var(--tx-secondary); border-color: var(--bd-primary); }
.btn--tertiary:hover { background: var(--bg-primary-light); }
.btn--ghost    { background: transparent; color: var(--tx-light); border-color: transparent; }
.btn--ghost:hover    { background: var(--bg-sec-lighter); }
.btn--success  { background: var(--bg-success); color: #fff; border-color: transparent; }
.btn--success:hover  { background: #005c30; }
.btn--danger   { background: var(--bg-error); color: #fff; border-color: transparent; }
.btn--sm       { height: 30px; padding: 0 10px; font-size: 12px; }
.btn--xs       { height: 24px; padding: 0 8px; font-size: 11px; }
.btn--icon     { width: 30px; padding: 0; }
.btn[disabled] { opacity: .45; pointer-events: none; }

/* ═══════════════════════════════════════════════════
   FORM / INPUTS
═══════════════════════════════════════════════════ */
.field         { display: flex; flex-direction: column; gap: 5px; }
.field__label  { font-size: 12px; font-weight: 700; color: var(--tx-primary); }
.field__hint   { font-size: 11px; color: var(--tx-lighter); }
.field__input  { display: flex; align-items: center; height: 38px; border: 1px solid var(--bd-secondary); border-radius: var(--r-smooth); background: var(--bg-inverse); padding: 0 10px; gap: 6px; transition: all .12s; }
.field__input:focus-within { border-color: var(--bd-primary); box-shadow: 0 0 0 3px var(--bg-primary-light); }
.field__input input,
.field__input select,
.field__input textarea { flex: 1; border: none; outline: none; background: transparent; font-family: var(--ff-body); font-size: 13px; color: var(--tx-primary); }
.field__input--area { height: auto; align-items: flex-start; padding: 8px 10px; }
.field__input--area textarea { min-height: 64px; resize: vertical; line-height: 1.5; }
select.field-select { height: 38px; border: 1px solid var(--bd-secondary); border-radius: var(--r-smooth); background: var(--bg-inverse); padding: 0 10px; font-family: var(--ff-body); font-size: 13px; color: var(--tx-primary); cursor: pointer; outline: none; transition: border-color .12s; }
select.field-select:focus { border-color: var(--bd-primary); box-shadow: 0 0 0 3px var(--bg-primary-light); }
.field-row     { display: flex; align-items: center; justify-content: space-between; padding: 9px 0; border-bottom: 1px solid var(--bd-sec-light); gap: 12px; }
.field-row:last-child { border-bottom: none; }
.field-row__label { font-size: 12px; color: var(--tx-lighter); font-weight: 500; flex-shrink: 0; width: 144px; }
.field-row__value { font-size: 13px; font-weight: 500; color: var(--tx-primary); text-align: right; flex: 1; }
.field-row__value--mono { font-family: var(--ff-mono); font-size: 12px; }

/* ═══════════════════════════════════════════════════
   TABLE
═══════════════════════════════════════════════════ */
.tbl           { width: 100%; border-collapse: collapse; font-size: 13px; }
.tbl th        { text-align: left; padding: 9px 16px; font-size: 11px; font-weight: 500; color: var(--tx-lighter); text-transform: uppercase; letter-spacing: .05em; border-bottom: 2px solid var(--bd-sec-light); background: var(--bg-sec-lighter); white-space: nowrap; }
.tbl td        { padding: 11px 16px; border-bottom: 1px solid var(--bd-sec-light); color: var(--tx-primary); vertical-align: middle; }
.tbl tr:last-child td { border-bottom: none; }
.tbl tr.tbl-row:hover td { background: var(--bg-primary-light); cursor: pointer; }
.tbl .mono     { font-family: var(--ff-mono); font-size: 12px; }
.tbl .actions  { display: flex; align-items: center; gap: 4px; }

/* Totale row */
.tbl-total td  { font-weight: 700; background: var(--bg-primary-light); color: var(--tx-secondary); border-top: 2px solid var(--bd-prim-light); }

/* ═══════════════════════════════════════════════════
   CHECKLIST
═══════════════════════════════════════════════════ */
.cl-item       { display: flex; align-items: flex-start; gap: 10px; padding: 10px 0; border-bottom: 1px solid var(--bd-sec-light); }
.cl-item:last-child { border-bottom: none; }
.cl-item__text { flex: 1; }
.cl-item__label { font-size: 13px; color: var(--tx-primary); line-height: 1.45; }
.cl-item__sub  { font-size: 11px; color: var(--tx-lighter); margin-top: 2px; }
.cl-item__ai   { font-size: 9px; font-weight: 700; background: var(--bg-primary-light); color: var(--tx-secondary); border-radius: var(--r-rounded); padding: 1px 5px; margin-left: 4px; vertical-align: middle; }
.cl-item__btns { display: flex; gap: 3px; flex-shrink: 0; padding-top: 2px; }
.cl-btn        { height: 24px; padding: 0 8px; font-size: 11px; font-weight: 500; font-family: var(--ff-body); border-radius: var(--r-smooth); border: 1px solid; cursor: pointer; transition: all .12s; }
.cl-btn--si    { border-color: var(--bd-success); color: var(--tx-success); background: transparent; }
.cl-btn--si.is-on { background: var(--bg-success); color: #fff; border-color: transparent; }
.cl-btn--no    { border-color: var(--bd-error); color: var(--tx-error); background: transparent; }
.cl-btn--no.is-on  { background: var(--bg-error); color: #fff; border-color: transparent; }
.cl-btn--dv    { border-color: var(--bd-warning); color: var(--tx-warning); background: transparent; }
.cl-btn--dv.is-on  { background: var(--bg-warning); color: #fff; border-color: transparent; }
.cl-btn--na    { border-color: var(--bd-sec-light); color: var(--tx-disable); background: transparent; }
.cl-btn--na.is-on  { background: var(--bg-sec-light); color: var(--tx-light); border-color: transparent; }

/* ═══════════════════════════════════════════════════
   STEPPER
═══════════════════════════════════════════════════ */
.stepper       { display: flex; flex-direction: column; }
.step          { display: flex; gap: 10px; padding: 0 6px; }
.step__spine   { display: flex; flex-direction: column; align-items: center; flex-shrink: 0; }
.step__dot     { width: 30px; height: 30px; border-radius: var(--r-circle); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; flex-shrink: 0; }
.step__dot--done   { background: var(--bg-success); color: #fff; }
.step__dot--active { background: var(--bg-emphasis); color: #fff; }
.step__dot--todo   { background: var(--bg-disable); color: var(--tx-disable); }
.step__line    { width: 2px; flex: 1; min-height: 16px; background: var(--bd-sec-light); margin: 3px 0; }
.step__line--done { background: var(--bg-success); }
.step__info    { padding-top: 4px; padding-bottom: 12px; flex: 1; }
.step__title   { font-size: 13px; font-weight: 700; }
.step__title--todo { color: var(--tx-disable); }
.step__sub     { font-size: 11px; color: var(--tx-lighter); margin-top: 2px; }

/* ═══════════════════════════════════════════════════
   ALERT / NOTICE
═══════════════════════════════════════════════════ */
.notice        { display: flex; align-items: flex-start; gap: 8px; padding: 10px 14px; border-radius: var(--r-smooth); border-left: var(--bw-thick) solid; font-size: 12px; line-height: 1.5; }
.notice--info  { background: var(--bg-primary-light); border-color: var(--bd-primary); color: var(--tx-secondary); }
.notice--ok    { background: var(--bg-success-lighter); border-color: var(--bd-success); color: var(--tx-success); }
.notice--warn  { background: var(--bg-warning-lighter); border-color: var(--bd-warning); color: var(--tx-warning); }
.notice--error { background: var(--bg-error-lighter); border-color: var(--bd-error); color: var(--tx-error); }
.notice__icon  { flex-shrink: 0; margin-top: 1px; }

/* ═══════════════════════════════════════════════════
   UPLOAD ZONE
═══════════════════════════════════════════════════ */
.drop-zone     { border: 2px dashed var(--bd-prim-light); border-radius: var(--r-smooth); padding: 28px 20px; text-align: center; cursor: pointer; background: var(--bg-primary-light); transition: all .15s; }
.drop-zone:hover { background: #e4d5ff; border-color: var(--bd-primary); }
.drop-zone__title { font-size: 13px; font-weight: 700; color: var(--tx-secondary); margin-bottom: 3px; }
.drop-zone__sub   { font-size: 11px; color: var(--tx-lighter); }

/* ═══════════════════════════════════════════════════
   QTE TABLE (special styling)
═══════════════════════════════════════════════════ */
.qte-table     { width: 100%; border-collapse: collapse; font-size: 13px; }
.qte-table thead tr { background: var(--bg-primary); }
.qte-table th  { padding: 9px 14px; color: #fff; font-size: 11px; font-weight: 500; text-align: right; }
.qte-table th:first-child { text-align: left; }
.qte-table td  { padding: 9px 14px; border-bottom: 1px solid var(--bd-sec-light); text-align: right; }
.qte-table td:first-child { text-align: left; font-weight: 500; }
.qte-table tr.qte-gar td  { background: #fffbeb; }
.qte-table tr.qte-tot td  { font-weight: 700; background: var(--bg-primary-light); color: var(--tx-secondary); border-top: 2px solid var(--bd-prim-light); }
.qte-num       { font-family: var(--ff-mono); font-size: 12px; }
.qte-erog      { color: var(--tx-secondary); }
.qte-resid     { color: var(--tx-success); font-weight: 600; }
.qte-warn      { color: var(--tx-warning); }

/* ═══════════════════════════════════════════════════
   MODAL
═══════════════════════════════════════════════════ */
.overlay       { position: fixed; inset: 0; background: rgba(0,0,0,.42); z-index: 900; display: none; align-items: center; justify-content: center; padding: 20px; }
.overlay.is-open { display: flex; }
.modal         { background: #fff; border-radius: var(--r-smooth); width: 560px; max-height: 90vh; overflow: hidden; display: flex; flex-direction: column; box-shadow: 0 20px 60px rgba(0,0,0,.22); }
.modal--lg     { width: 720px; }
.modal__header { padding: 16px 20px; border-bottom: 1px solid var(--bd-sec-light); display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; }
.modal__title  { font-size: 16px; font-weight: 700; }
.modal__close  { width: 28px; height: 28px; border: none; background: none; border-radius: var(--r-smooth); cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--tx-lighter); font-size: 16px; }
.modal__close:hover { background: var(--bg-sec-lighter); }
.modal__body   { padding: 20px; overflow-y: auto; flex: 1; }
.modal__footer { padding: 12px 20px; border-top: 1px solid var(--bd-sec-light); display: flex; justify-content: flex-end; gap: 8px; flex-shrink: 0; background: var(--bg-sec-lighter); }

/* ═══════════════════════════════════════════════════
   FLOATING ACTION PANEL
═══════════════════════════════════════════════════ */
.fab           { position: fixed; bottom: 24px; right: 24px; z-index: 400; display: flex; align-items: center; background: #fff; border-radius: var(--r-smooth); box-shadow: 0 4px 18px rgba(0,0,0,.14); overflow: hidden; }
.fab__toggle   { width: 46px; height: 46px; border: none; background: var(--bg-primary); color: #fff; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: background .12s; flex-shrink: 0; }
.fab__toggle:hover { background: var(--bg-primary-hover); }
.fab__toggle svg { width: 18px; height: 18px; stroke: #fff; fill: none; stroke-width: 2; }
.fab__actions  { display: flex; overflow: hidden; max-width: 0; transition: max-width .22s ease; }
.fab__actions.is-open { max-width: 240px; }
.fab__action   { width: 46px; height: 46px; border: none; background: transparent; color: var(--tx-light); display: flex; align-items: center; justify-content: center; cursor: pointer; flex-shrink: 0; border-left: 1px solid var(--bd-sec-light); transition: background .12s; }
.fab__action:hover { background: var(--bg-sec-lighter); }
.fab__action svg { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 1.8; }
.fab__action-label { font-size: 11px; color: var(--tx-lighter); padding: 0 4px; white-space: nowrap; }

/* ═══════════════════════════════════════════════════
   PROGRESS BAR
═══════════════════════════════════════════════════ */
.progress      { height: 6px; background: var(--bg-sec-light); border-radius: var(--r-smooth); overflow: hidden; }
.progress__fill { height: 100%; border-radius: var(--r-smooth); transition: width .4s ease; }
.progress__fill--primary { background: var(--bg-primary); }
.progress__fill--success { background: var(--bg-success); }
.progress__fill--warning { background: var(--bg-warning); }
.progress__fill--error   { background: var(--bg-error); }

/* ═══════════════════════════════════════════════════
   MISC UTILITIES
═══════════════════════════════════════════════════ */
.divider       { height: 1px; background: var(--bd-sec-light); }
.section-label { font-size: 11px; font-weight: 500; color: var(--tx-lighter); text-transform: uppercase; letter-spacing: .06em; margin-bottom: 10px; }
.mono          { font-family: var(--ff-mono); font-size: 12px; }
.text-muted    { color: var(--tx-lighter); font-size: 12px; }
.text-right    { text-align: right; }
.text-success  { color: var(--tx-success); }
.text-warning  { color: var(--tx-warning); }
.text-error    { color: var(--tx-error); }
.text-violet   { color: var(--tx-secondary); }
.mt-4  { margin-top: 4px; }
.mt-8  { margin-top: 8px; }
.mt-12 { margin-top: 12px; }
.mt-16 { margin-top: 16px; }
.mt-20 { margin-top: 20px; }
.gap-4 { gap: 4px; }
.gap-8 { gap: 8px; }

/* ── Timeline (Monitoraggio) ── */
.timeline      { display: flex; flex-direction: column; gap: 0; }
.tl-item       { display: flex; gap: 12px; }
.tl-spine      { display: flex; flex-direction: column; align-items: center; flex-shrink: 0; width: 32px; }
.tl-dot        { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; margin-top: 3px; }
.tl-dot--done  { background: var(--bg-success); }
.tl-dot--active { background: var(--bg-emphasis); box-shadow: 0 0 0 3px var(--bg-primary-light); }
.tl-dot--todo  { background: var(--bg-disable); border: 2px solid var(--tx-disable); background: transparent; }
.tl-dot--warn  { background: var(--bg-warning); }
.tl-connector  { flex: 1; width: 2px; background: var(--bd-sec-light); min-height: 20px; margin: 4px 0; }
.tl-connector--done { background: var(--bg-success); }
.tl-body       { flex: 1; padding-bottom: 16px; }
.tl-title      { font-size: 13px; font-weight: 700; }
.tl-meta       { font-size: 11px; color: var(--tx-lighter); margin-top: 2px; }
.tl-content    { margin-top: 6px; }

/* ── Documento row ── */
.doc-row       { display: flex; align-items: center; gap: 10px; padding: 10px 16px; border-bottom: 1px solid var(--bd-sec-light); }
.doc-row:last-child { border-bottom: none; }
.doc-icon      { width: 34px; height: 34px; border-radius: var(--r-smooth); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 16px; }
.doc-icon--pdf { background: #ffe5e5; }
.doc-icon--zip { background: #fff3e0; }
.doc-icon--doc { background: #e3f2fd; }
.doc-info      { flex: 1; min-width: 0; }
.doc-name      { font-size: 13px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.doc-meta      { font-size: 11px; color: var(--tx-lighter); margin-top: 2px; }
.doc-actions   { display: flex; gap: 4px; flex-shrink: 0; }

/* ── Richiesta card ── */
.req-card      { border: 1px solid var(--bd-sec-light); border-radius: var(--r-smooth); background: var(--bg-inverse); overflow: hidden; }
.req-card__head { display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; border-bottom: 1px solid var(--bd-sec-light); background: var(--bg-sec-lighter); }
.req-card__body { padding: 14px 16px; }

/* ── Monitoring item ── */
.mon-item      { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; padding: 12px 0; border-bottom: 1px solid var(--bd-sec-light); }
.mon-item:last-child { border-bottom: none; }
.mon-item__label { font-size: 13px; font-weight: 500; }
.mon-item__sub { font-size: 11px; color: var(--tx-lighter); margin-top: 2px; }
.mon-item__right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
</style>
</head>
<body>

<!-- ═══════════════════════════════════════════════════
     LOGIN SCREEN
═══════════════════════════════════════════════════ -->
<div class="login-screen" id="login-screen">
  <div class="login-brand">
    <div class="login-brand__logo">
      <div class="login-brand__mark">
        <svg viewBox="0 0 18 18"><rect x="1" y="1" width="6" height="6"/><rect x="11" y="1" width="6" height="6"/><rect x="1" y="11" width="6" height="6"/><rect x="11" y="11" width="6" height="6"/></svg>
      </div>
      <div>
        <div class="login-brand__name">Sonar</div>
        <div class="login-brand__tagline">Riscontro Tecnico · ICSC</div>
      </div>
    </div>
    <div class="login-brand__body">
      <div class="login-brand__headline">Gestione <em>integrata</em><br>del riscontro<br>tecnico ICSC</div>
      <div class="login-brand__desc">Piattaforma centralizzata per la verifica documentale, il controllo di eleggibilità e la gestione delle erogazioni sui mutui sportivi e culturali.</div>
      <div class="login-brand__pills">
        <span class="login-brand__pill">Mutui ordinari privati</span>
        <span class="login-brand__pill">Mutui light</span>
        <span class="login-brand__pill">Mutui EELL</span>
        <span class="login-brand__pill">Checklist eleggibilità</span>
        <span class="login-brand__pill">N.O. tecnico</span>
      </div>
    </div>
    <div class="login-brand__footer">© 2026 ICSC — Istituto per il Credito Sportivo e Culturale · Powered by OpenEconomics</div>
  </div>
  <div class="login-form-wrap">
    <div class="login-form">
      <div class="login-form__header">
        <div class="login-form__title">Accedi a Sonar</div>
        <div class="login-form__sub">Inserisci le tue credenziali per continuare</div>
      </div>
      <div class="login-error" id="login-error">⚠ Credenziali non valide. Verifica email e password e riprova.</div>
      <div class="login-form__group">
        <label class="login-form__label">Indirizzo e-mail</label>
        <input class="login-form__input" type="email" id="login-email" placeholder="nome@icsc.it" value="admin@icsc.it">
      </div>
      <div class="login-form__group">
        <label class="login-form__label">Password</label>
        <input class="login-form__input" type="password" id="login-password" placeholder="••••••••" value="admin123">
      </div>
      <div class="login-form__forgot">Password dimenticata?</div>
      <button class="login-form__submit" onclick="doLogin()">
        Accedi
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </button>
      <div class="login-form__divider"><span>oppure</span></div>
      <button class="login-form__sso" onclick="doLogin()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>
        Accedi con l'account dell'organizzazione (SSO)
      </button>
      <div class="login-form__footer">Accedendo accetti i termini di servizio e la privacy policy ICSC.<br><span style="color:var(--tx-lighter);font-size:10px">&#128274; Demo: admin@icsc.it / admin123</span></div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════
     SET PASSWORD SCREEN (primo accesso via invite)
═══════════════════════════════════════════════════ -->
<div class="login-screen is-hidden" id="setpwd-screen">
  <div class="login-brand">
    <div class="login-brand__logo">
      <div class="login-brand__mark">
        <svg viewBox="0 0 18 18"><rect x="1" y="1" width="6" height="6"/><rect x="11" y="1" width="6" height="6"/><rect x="1" y="11" width="6" height="6"/><rect x="11" y="11" width="6" height="6"/></svg>
      </div>
      <div>
        <div class="login-brand__name">Sonar</div>
        <div class="login-brand__tagline">Riscontro Tecnico · ICSC</div>
      </div>
    </div>
    <div class="login-brand__body">
      <div class="login-brand__headline">Benvenuto<br>in <em>Sonar</em></div>
      <div class="login-brand__desc">Hai ricevuto un invito. Imposta la tua password per completare la registrazione e accedere alla piattaforma.</div>
    </div>
    <div class="login-brand__footer">© 2026 ICSC — Powered by OpenEconomics</div>
  </div>
  <div class="login-form-wrap">
    <div class="login-form">
      <div class="login-form__header">
        <div class="login-form__title">Imposta la tua password</div>
        <div class="login-form__sub" id="setpwd-email-label">Stai configurando l'accesso per il tuo account.</div>
      </div>
      <div class="login-error" id="setpwd-error"></div>
      <div class="login-form__group">
        <label class="login-form__label">Nome e Cognome</label>
        <input class="login-form__input" type="text" id="setpwd-name" placeholder="es. Mario Rossi">
      </div>
      <div class="login-form__group">
        <label class="login-form__label">Nuova password</label>
        <input class="login-form__input" type="password" id="setpwd-pwd1" placeholder="Minimo 8 caratteri">
      </div>
      <div class="login-form__group">
        <label class="login-form__label">Conferma password</label>
        <input class="login-form__input" type="password" id="setpwd-pwd2" placeholder="Ripeti la password">
      </div>
      <button class="login-form__submit" onclick="doSetPassword()">
        Attiva account e accedi
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </button>
      <div class="login-form__footer" style="margin-top:20px">L'account sarà attivo dopo questa configurazione.<br>Usa sempre queste credenziali per i prossimi accessi.</div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════
     APP SHELL
═══════════════════════════════════════════════════ -->
<div class="shell" id="app-shell" style="display:none">

  <!-- TOP NAV -->
  <header class="shell__nav">
    <div class="nav-logo" style="gap:6px">
      <div class="nav-logo__mark" style="background:#000;border-radius:3px;width:20px;height:20px">
        <svg viewBox="0 0 12 12" style="width:9px;height:9px"><rect x="1" y="1" width="10" height="10" fill="white"/></svg>
      </div>
      <span style="font-size:17px;font-weight:800;letter-spacing:-.02em;color:#000">Sonar</span>
    </div>

    <div class="nav-search">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <input type="text" placeholder="Cerca pratica, beneficiario, comune…">
    </div>

    <div class="nav-right">
      <button class="nav-ico" title="Notifiche">
        <svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
      </button>
      <button class="nav-ico" id="btn-admin-gear" title="Gestione utenti" onclick="goAdmin()" style="display:none">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      </button>
      <div class="nav-user" id="nav-user-btn" onclick="toggleProfiloDropdown(event)" style="cursor:pointer;user-select:none">
        <div class="nav-avatar" id="nav-avatar">—</div>
        <div>
          <div class="nav-username" id="nav-username">—</div>
          <div class="nav-role" id="nav-role">—</div>
        </div>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-left:4px;opacity:.5"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
    </div>
  </header>

  <div class="shell__accent"></div>

  <!-- BODY -->
  <div class="shell__body">

    <!-- SIDEBAR -->
    <nav class="shell__sidebar" id="sidebar">
      <div class="sb-section">Sezioni</div>
      <div class="sb-item is-active" id="sb-dashboard" onclick="goDashboard()">
        <div class="sb-icon"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg></div>
        <span class="sb-label">Dashboard pratiche</span>
      </div>
      <div class="sb-resize" onclick="toggleSidebar()">
        <div class="sb-resize-lbl">
          <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
          <span>Comprimi</span>
        </div>
      </div>
    </nav>

    <!-- MAIN AREA -->
    <main class="shell__main" id="main">

<!-- ═══════════════════════════════════════════════════
     PAGE: DASHBOARD
═══════════════════════════════════════════════════ -->
<style>
  /* ── Dashboard gruppi ── */
  .dash-section-hdr {
    display:flex; align-items:center; justify-content:space-between;
    padding:10px 0 8px; margin-bottom:4px;
  }
  .dash-section-title { font-size:11px; font-weight:700; color:var(--tx-lighter); text-transform:uppercase; letter-spacing:.07em; }

  /* Gruppo card */
  .gruppo-card { border:1.5px solid var(--bd-sec-light); border-radius:var(--r-smooth); background:var(--bg-inverse); margin-bottom:10px; overflow:hidden; }
  .gruppo-card--privato { border-left:4px solid var(--bg-emphasis); }
  .gruppo-card--pubblico { border-left:4px solid var(--bg-success); }
  .gruppo-hdr {
    display:flex; align-items:center; gap:12px; padding:12px 16px;
    cursor:pointer; user-select:none; transition:background .1s;
  }
  .gruppo-hdr:hover { background:var(--bg-sec-lighter); }
  .gruppo-hdr__toggle { font-size:11px; color:var(--tx-lighter); transition:transform .15s; flex-shrink:0; }
  .gruppo-hdr__toggle.is-open { transform:rotate(90deg); }
  .gruppo-hdr__name { font-size:14px; font-weight:700; color:var(--tx-primary); flex:1; }
  .gruppo-hdr__meta { font-size:11px; color:var(--tx-lighter); }
  .gruppo-hdr__badges { display:flex; gap:5px; flex-shrink:0; }
  .gruppo-metrics {
    display:grid; grid-template-columns:repeat(6,1fr); gap:0;
    border-top:1px solid var(--bd-sec-light); border-bottom:1px solid var(--bd-sec-light);
    background:var(--bg-sec-lighter);
  }
  .gm-cell { padding:10px 14px; border-right:1px solid var(--bd-sec-light); }
  .gm-cell:last-child { border-right:none; }
  .gm-label { font-size:10px; font-weight:700; color:var(--tx-lighter); text-transform:uppercase; letter-spacing:.05em; margin-bottom:3px; }
  .gm-value { font-size:18px; font-weight:700; color:var(--tx-primary); font-family:var(--ff-mono); }
  .gm-sub { font-size:10px; color:var(--tx-lighter); margin-top:1px; }
  .gm-bar { height:3px; background:var(--bg-sec-light); border-radius:2px; margin-top:5px; overflow:hidden; }
  .gm-bar-fill { height:100%; border-radius:2px; background:var(--bg-primary); }
  /* Pratiche nel gruppo (collapsed) */
  .gruppo-body { display:none; }
  .gruppo-body.is-open { display:block; }
  .gruppo-pratica-row {
    display:flex; align-items:center; gap:12px; padding:9px 16px 9px 36px;
    border-bottom:1px solid var(--bd-sec-light); cursor:pointer; transition:background .1s;
    font-size:13px;
  }
  .gruppo-pratica-row:last-child { border-bottom:none; }
  .gruppo-pratica-row:hover { background:var(--bg-primary-light); }
  .gpr-rap { font-family:var(--ff-mono); font-weight:700; color:var(--tx-secondary); width:70px; flex-shrink:0; }
  .gpr-ben { flex:1; font-weight:500; }
  .gpr-comune { width:130px; font-size:12px; color:var(--tx-lighter); flex-shrink:0; }
  .gpr-badges { display:flex; gap:4px; flex-shrink:0; width:160px; }
  .gpr-fase { width:90px; flex-shrink:0; }
  .gpr-proc { display:flex; flex-direction:column; gap:2px; width:110px; flex-shrink:0; }
  .gpr-proc-bar { height:4px; background:var(--bg-sec-light); border-radius:2px; overflow:hidden; }
  .gpr-no { width:100px; flex-shrink:0; }
  .gpr-scad { width:70px; font-family:var(--ff-mono); font-size:12px; text-align:right; flex-shrink:0; }
</style>

<div class="page is-visible" id="page-dashboard">
  <div class="pghdr">
    <div class="pghdr__left">
      <div class="pgtitle">Lista pratiche — Riscontro Tecnico</div>
      <div style="font-size:13px;color:var(--tx-lighter);margin-top:3px">Qui troverai la lista di tutti i tuoi progetti assegnati.</div>
    </div>
    <div class="pghdr__actions">
      <button class="btn-nuovo-progetto" onclick="openModal('modal-nuova-pratica')">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Nuova pratica
      </button>
    </div>
  </div>

  <div style="padding:16px 28px">
    <div style="margin-bottom:20px;border:1px solid var(--bd-sec-light);border-radius:var(--r-smooth);background:var(--bg-inverse);padding:10px 16px;display:flex;align-items:center;gap:10px">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--tx-lighter)" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <input type="text" id="dash-search" placeholder="Cerca per beneficiario, comune, rapporto…" style="border:none;outline:none;font-family:var(--ff-body);font-size:13px;color:var(--tx-primary);flex:1;background:transparent" oninput="renderDashboard()">
    </div>

    <!-- Pratiche list — populated dynamically -->
    <div id="dash-list">
      <div style="text-align:center;padding:48px 0;color:var(--tx-lighter);font-size:13px">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="display:block;margin:0 auto 10px;opacity:.4"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        Nessuna pratica assegnata. Crea la prima pratica con il tasto "Nuova pratica".
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════
     PAGE: ADMIN — GESTIONE UTENTI
═══════════════════════════════════════════════════ -->
<div class="page" id="page-admin">
  <div class="pghdr">
    <div class="pghdr__left">
      <div class="pgtitle">Gestione utenti</div>
      <div style="font-size:13px;color:var(--tx-lighter);margin-top:3px">Invita operatori, assegna ruoli e gestisci l'accesso alla piattaforma.</div>
    </div>
    <div class="pghdr__actions">
      <button class="btn-nuovo-progetto" onclick="openModal('modal-invita-utente')">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Invita utente
      </button>
    </div>
  </div>

  <div style="padding:20px 28px">
    <div class="card">
      <div class="card__header">
        <span class="card__title">Utenti del sistema</span>
        <span class="badge badge--gray" id="admin-user-count">— utenti</span>
      </div>
      <div class="card__body-0">
        <!-- Table header -->
        <div style="display:grid;grid-template-columns:1fr 200px 120px 140px 90px;gap:0;padding:9px 20px;background:var(--bg-sec-lighter);border-bottom:2px solid var(--bd-sec-light);font-size:11px;font-weight:700;color:var(--tx-lighter);text-transform:uppercase;letter-spacing:.05em">
          <div>Utente</div>
          <div>Email</div>
          <div>Ruolo</div>
          <div>Stato</div>
          <div></div>
        </div>
        <div id="admin-user-list">
          <div style="padding:32px;text-align:center;color:var(--tx-lighter);font-size:13px">Caricamento…</div>
        </div>
      </div>
    </div>

    <!-- Sezione SQL export -->
    <div class="card" style="margin-top:20px">
      <div class="card__header">
        <span class="card__title">Setup database Supabase</span>
        <button class="btn btn--ghost btn--sm" onclick="copySql()">&#128203; Copia SQL</button>
      </div>
      <div class="card__body">
        <div class="notice notice--info" style="margin-bottom:14px;font-size:12px">
          &#128279; Esegui questo SQL nel <strong>SQL Editor</strong> del tuo progetto Supabase per creare tutte le tabelle necessarie.
        </div>
        <pre id="sql-export" style="background:var(--bg-sec-lighter);border:1px solid var(--bd-sec-light);border-radius:var(--r-smooth);padding:14px;font-size:11px;font-family:monospace;overflow-x:auto;max-height:320px;overflow-y:auto;color:var(--tx-primary);line-height:1.6;white-space:pre-wrap"></pre>
      </div>
    </div>
  </div>
</div>

<div class="page" id="page-pratica">

  <!-- Header -->
  <div class="pghdr">
    <div class="pghdr__left">
      <div class="breadcrumb">
        <a onclick="goDashboard()">Pratiche</a>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        <span id="pratica-breadcrumb">—</span>
      </div>
      <div style="display:flex;align-items:center;gap:8px">
        <div class="pgtitle" id="pratica-title">—</div>
      </div>
      <div class="pgmeta" id="pratica-meta"></div>
    </div>
    <div class="pghdr__actions">
      <button class="btn btn--ghost btn--sm" onclick="openModal('modal-edit-pratica-info')" id="btn-edit-pratica">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4z"/></svg>
        Modifica anagrafica
      </button>
    </div>
  </div>

  <!-- Tabs -->
  <div class="tabs" id="pratica-tabs">
    <div class="tab is-active" onclick="switchTab('anagrafica',this)">Dashboard pratica</div>
    <div class="tab" onclick="switchTab('quadro',this)">Quadro economico</div>
    <div class="tab" onclick="switchTab('inserimento',this)">Gestione svincolo</div>
    <div class="tab" onclick="switchTab('controllo',this)">Controllo eleggibilità</div>

    <div class="tab" onclick="switchTab('fascicolo',this)">Fascicolo pratica</div>
    <div class="tab" onclick="switchTab('monitoraggio',this)">Monitoraggio</div>
  </div>

  <!-- ═══ TAB 1: DASHBOARD PRATICA ═══ -->
  <div class="panel is-active" id="tab-anagrafica">
    <div class="stack">

      <!-- KPI row -->
      <div class="g4" id="pratica-kpi">
        <div class="kpi kpi--primary"><div class="kpi__label">Importo deliberato</div><div class="kpi__value kpi__value--sm" id="kpi-importo">—</div></div>
        <div class="kpi kpi--success"><div class="kpi__label">Erogato totale</div><div class="kpi__value kpi__value--sm" id="kpi-erogato">—</div></div>
        <div class="kpi kpi--warning"><div class="kpi__label">Residuo da erogare</div><div class="kpi__value kpi__value--sm" id="kpi-residuo">—</div></div>
        <div class="kpi kpi--primary"><div class="kpi__label">N. SAL inseriti</div><div class="kpi__value kpi__value--sm" id="kpi-sal">0</div></div>
      </div>

      <div class="g2">
        <!-- Anagrafica -->
        <div class="card">
          <div class="card__header">
            <span class="card__title">Anagrafica pratica</span>
            <span class="sem" id="pratica-stato-badge"><span class="sem__dot"></span><span id="pratica-stato-txt">—</span></span>
          </div>
          <div class="card__body" id="anagrafica-fields">
            <div style="text-align:center;padding:24px;color:var(--tx-lighter);font-size:12px">Caricamento…</div>
          </div>
        </div>

        <!-- Stato e note editabili -->
        <div class="card">
          <div class="card__header">
            <span class="card__title">Stato operativo</span>
          </div>
          <div class="card__body">
            <div class="field" style="margin-bottom:14px">
              <label class="field__label">Fase corrente</label>
              <select class="field-select" style="width:100%" id="edit-fase" onchange="markDirty('anagrafica')">
                <option value="Pre-ammortamento">Pre-ammortamento</option>
                <option value="Ammortamento">Ammortamento</option>
                <option value="In lavorazione">In lavorazione</option>
                <option value="Chiusa">Chiusa</option>
              </select>
            </div>
            <div class="field" style="margin-bottom:14px">
              <label class="field__label">Stato lavorazione</label>
              <select class="field-select" style="width:100%" id="edit-stato" onchange="markDirty('anagrafica')">
                <option value="In lavorazione">In lavorazione</option>
                <option value="In attesa documenti">In attesa documenti</option>
                <option value="In verifica">In verifica</option>
                <option value="In firma N.O.">In firma N.O.</option>
                <option value="Chiusa">Chiusa</option>
              </select>
            </div>
            <div class="field" style="margin-bottom:14px">
              <label class="field__label">Note operative</label>
              <div class="field__input field__input--area">
                <textarea id="edit-note" style="min-height:80px" placeholder="Note interne della pratica…" oninput="markDirty('anagrafica')"></textarea>
              </div>
            </div>
            <div style="display:flex;align-items:center;justify-content:space-between">
              <span id="anagrafica-save-msg" style="font-size:11px;color:var(--tx-success);display:none">✓ Salvato</span>
              <span id="anagrafica-dirty-msg" style="font-size:11px;color:var(--tx-warning);display:none">● Modifiche non salvate</span>
              <button class="btn btn--primary btn--sm" onclick="saveAnagrafica()">Salva</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Avanzamento procedurale -->
      <div class="card">
        <div class="card__header"><span class="card__title">Avanzamento procedurale</span></div>
        <div class="card__body" id="avanzamento-steps">
          <div style="color:var(--tx-lighter);font-size:12px;text-align:center;padding:12px">Inserisci il primo SAL per avviare il monitoraggio procedurale.</div>
        </div>
      </div>

    </div>
  </div>

  <!-- ═══ TAB 2: QUADRO ECONOMICO ═══ -->
  <div class="panel" id="tab-quadro">
    <div class="stack">
      <div class="card">
        <div class="card__header">
          <span class="card__title">Quadro economico</span>
          <div style="display:flex;gap:8px;align-items:center">
            <span id="qte-save-msg" style="font-size:11px;color:var(--tx-success);display:none">✓ Salvato</span>
            <span id="qte-dirty-msg" style="font-size:11px;color:var(--tx-warning);display:none">● Modifiche non salvate</span>
            <button class="btn btn--ghost btn--xs" onclick="qteAddRow()">+ Voce</button>
            <button class="btn btn--primary btn--sm" onclick="saveQTE()">Salva QTE</button>
          </div>
        </div>
        <div class="card__body-0" style="overflow-x:auto">
          <table style="width:100%;border-collapse:collapse;font-size:13px" id="qte-table">
            <thead>
              <tr style="background:var(--bg-primary)">
                <th style="padding:9px 14px;color:#fff;font-size:11px;font-weight:600;text-align:left;min-width:180px">Voce di spesa</th>
                <th style="padding:9px 14px;color:#fff;font-size:11px;font-weight:600;text-align:right;min-width:130px">Costo progetto (€)</th>
                <th style="padding:9px 14px;color:#fff;font-size:11px;font-weight:600;text-align:right;min-width:130px">Costo ammissibile (€)</th>
                <th style="padding:9px 14px;color:#fff;font-size:11px;font-weight:600;text-align:right;min-width:130px">Costo approvato (€)</th>
                <th style="padding:9px 14px;color:#fff;font-size:11px;font-weight:600;text-align:right;min-width:100px">Intensità (%)</th>
                <th style="padding:9px 14px;color:#fff;font-size:11px;font-weight:600;text-align:right;min-width:130px">Contributo (€)</th>
                <th style="padding:9px 14px;width:32px"></th>
              </tr>
            </thead>
            <tbody id="qte-tbody"></tbody>
            <tfoot id="qte-tfoot"></tfoot>
          </table>
        </div>
        <div class="card__footer" style="font-size:11px;color:var(--tx-lighter)">
          Il contributo per riga si calcola automaticamente: Costo approvato × Intensità d'aiuto.
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ TAB 3: GESTIONE SVINCOLO ═══ -->
  <div class="panel" id="tab-inserimento">
    <div class="stack">
      <div class="row-sb" style="margin-bottom:4px">
        <div style="font-size:13px;font-weight:600;color:var(--tx-primary)">SAL inseriti</div>
        <button class="btn-nuovo-progetto" style="height:34px;font-size:12px" onclick="openModalNuovoSAL()">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Nuovo SAL
        </button>
      </div>
      <div id="sal-list">
        <div class="card">
          <div class="card__body" style="text-align:center;color:var(--tx-lighter);font-size:13px;padding:32px">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="display:block;margin:0 auto 8px;opacity:.4"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
            Nessun SAL inserito. Clicca "Nuovo SAL" per iniziare.
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ TAB 4: CONTROLLO ELEGGIBILITÀ ═══ -->
  <div class="panel" id="tab-controllo">
    <div class="stack">
      <div class="row-sb" style="margin-bottom:4px">
        <div style="font-size:13px;font-weight:600;color:var(--tx-primary)">Catene documentali</div>
      </div>
      <div id="catene-list">
        <div class="card">
          <div class="card__body" style="text-align:center;color:var(--tx-lighter);font-size:13px;padding:32px">
            Le catene documentali vengono create automaticamente quando si inserisce un SAL. Inserisci prima un SAL nel tab "Gestione svincolo".
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ TAB 5: RICHIESTE ED EROGAZIONI ═══ -->
  <div class="panel" id="tab-fascicolo">
    <div class="stack">
      <div class="row-sb" style="margin-bottom:4px">
        <div style="font-size:13px;font-weight:600;color:var(--tx-primary)">Fascicolo documenti</div>
        <button class="btn btn--tertiary btn--sm" onclick="openModal('modal-upload-doc')">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          Carica documento
        </button>
      </div>
      <div id="fascicolo-categorie"></div>
    </div>
  </div>

  <!-- ═══ TAB 7: MONITORAGGIO ═══ -->
  <div class="panel" id="tab-monitoraggio">
    <div class="stack">
      <div class="g2">
        <!-- Timeline fasi -->
        <div class="card">
          <div class="card__header">
            <span class="card__title">Fasi procedurali</span>
          </div>
          <div class="card__body" id="monit-fasi">
            <div style="color:var(--tx-lighter);font-size:12px">Caricamento…</div>
          </div>
        </div>
        <!-- Aggiornamenti manuali -->
        <div class="card">
          <div class="card__header">
            <span class="card__title">Aggiornamenti</span>
            <button class="btn btn--tertiary btn--xs" onclick="openModal('modal-nuovo-aggiornamento')">+ Nuovo</button>
          </div>
          <div class="card__body-0" id="monit-aggiornamenti">
            <div style="padding:24px;text-align:center;color:var(--tx-lighter);font-size:12px">Nessun aggiornamento inserito.</div>
          </div>
        </div>
      </div>
    </div>
  </div>

</div>



<!-- Modal: Report controllo -->
